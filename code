        function renderScheduleTimeline() {
            const now = new Date();
            const nm = now.getHours() * 60 + now.getMinutes();

            function parseT(s) {
                const m = s.match(/(\d+):(\d+)/);
                return m ? parseInt(m[1]) * 60 + parseInt(m[2]) : null;
            }
            const catMap = {
                'm': 'cat-m',
                'g': 'cat-g',
                'b': 'cat-b',
                's': 'cat-s',
                'r': 'cat-r',
                'c': 'cat-c'
            };
            document.getElementById('scheduleTimeline').innerHTML = SCHEDULE.map(s => {
                const st = parseT(s.t.split('–')[0]);
                const en = parseT(s.t.split('–')[1] || '');
                const isNow = st && nm >= st && (!en || nm < en);
                return `<div class="sched-item ${isNow?'active-now':''}">
      <div style="width:85px;flex-shrink:0;">
        <div class="si-time" style="color:${isNow?'var(--orange)':'var(--muted)'};">${s.t}</div>
        <div class="si-dur">${s.dur}</div>
      </div>
      <div>
        <div class="si-title">${s.icon} ${s.title} <span class="si-cat ${catMap[s.cat]||'cat-r'}">${s.cat.toUpperCase()}</span></div>
