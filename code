        let aiHistory = [];
        async function sendAI() {
            const inp = document.getElementById('aiInp');
            const text = inp.value.trim();
            if (!text) return;
            inp.value = '';
            const btn = document.getElementById('aiSend');
            btn.disabled = true;
            appendAI('user', text);
            aiHistory.push({
                role: 'user',
                content: text
            });
            const typing = appendTyping();
            const sys = `${BASE_SYS}\n\n${AI_MODES[S.aiMode]||AI_MODES.mentor}`;
            try {
                const res = await fetch('https://api.anthropic.com/v1/messages', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        model: 'claude-sonnet-4-20250514',
                        max_tokens: 1000,
                        system: sys,
                        messages: aiHistory.slice(-20)
                    })
                });
                const data = await res.json();
                typing.remove();
                const reply = data.content?. [0]?.text || 'Could not get a response right now.';
                aiHistory.push({
                    role: 'assistant',
                    content: reply
                });
                appendAI('ai', reply);
            } catch (e) {
                typing.remove();
                appendAI('ai', '⚠️ Connection error. Check your network and try again.');
            }
            btn.disabled = false;
        }

        function appendAI(role, text) {
            const msgs = document.getElementById('aiMsgs');
            const div = document.createElement('div');
            div.className = `msg ${role}`;
            const time = new Date().toLocaleTimeString('en', {
                hour: '2-digit',
                minute: '2-digit'
            });
            const av = role === 'ai' ? '🤖' : '→';
            const fmt = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\*(.*?)\*/g, '<em>$1</em>')
                .replace(/`([^`\n]+)`/g, '<code>$1</code>').replace(/\n/g, '<br>');
            div.innerHTML = `<div class="msg-av">${av}</div><div><div class="msg-bub"><p>${fmt}</p></div><div class="msg-time">${time}</div></div>`;
            msgs.appendChild(div);
            msgs.scrollTop = msgs.scrollHeight;
        }

        function appendTyping() {
            const msgs = document.getElementById('aiMsgs');
            const div = document.createElement('div');
            div.className = 'msg ai';
            div.innerHTML = `<div class="msg-av">🤖</div><div class="typing"><div class="td"></div><div class="td"></div><div class="td"></div></div>`;
            msgs.appendChild(div);
            msgs.scrollTop = msgs.scrollHeight;
            return div;
        }

