        // POMODORO
        // ══════════════════════════════════════════════════════
        const CIRC = 2 * Math.PI * 84; // 527.8
        let pomo = {
            running: false,
            mins: 25,
            secs: 0,
            total: 25 * 60,
            mode: 'FOCUS',
            iv: null
        };

        function updatePomoDisp() {
            document.getElementById('pomoDisp').textContent = String(pomo.mins).padStart(2, '0') + ':' + String(pomo.secs).padStart(2, '0');
            const rem = pomo.mins * 60 + pomo.secs;
            document.getElementById('pomoArc').style.strokeDashoffset = CIRC * (rem / pomo.total);
            document.getElementById('pomoLbl').textContent = pomo.mode;
        }

        function togglePomo() {
            if (pomo.running) {
                clearInterval(pomo.iv);
                pomo.running = false;
                document.getElementById('pomoPlay').textContent = '▶';
                document.getElementById('pomoPlay').classList.remove('on');
            } else {
                pomo.running = true;
                document.getElementById('pomoPlay').textContent = '⏸';
                document.getElementById('pomoPlay').classList.add('on');
                pomo.iv = setInterval(() => {
                    if (pomo.secs === 0) {
                        if (pomo.mins === 0) {
                            clearInterval(pomo.iv);
                            pomo.running = false;
                            document.getElementById('pomoPlay').textContent = '▶';
                            document.getElementById('pomoPlay').classList.remove('on');
                            if (pomo.mode === 'FOCUS') {
                                S.pomodoros++;
                                persist();
                                addFocusLog();
                                updateTopbar();
                                if (document.getElementById('sd-pomo')) document.getElementById('sd-pomo').textContent = S.pomodoros;
                            }
                            beep();
                            return;
                        }
                        pomo.mins--;
                        pomo.secs = 59;
                    } else pomo.secs--;
                    updatePomoDisp();
                }, 1000);
            }
        }

        function resetPomo() {
            clearInterval(pomo.iv);
            pomo.running = false;
            setPomoMode(pomo.total / 60, pomo.mode, null);
        }

        function skipPomo() {
            resetPomo();
        }

        function setPomoMode(mins, label, btn) {
            clearInterval(pomo.iv);
            pomo.running = false;
            pomo.mins = mins;
            pomo.secs = 0;
            pomo.total = mins * 60;
            pomo.mode = label;
            document.getElementById('pomoPlay').textContent = '▶';
            document.getElementById('pomoPlay').classList.remove('on');
            if (btn) {
                document.querySelectorAll('.pm').forEach(b => b.classList.remove('on'));
                btn.classList.add('on');
            }
            updatePomoDisp();
        }

        function beep() {
            try {
                const c = new(window.AudioContext || window.webkitAudioContext)();
                const o = c.createOscillator();
                const g = c.createGain();
                o.connect(g);
                g.connect(c.destination);
                o.frequency.value = 880;
                g.gain.setValueAtTime(.3, c.currentTime);
                g.gain.exponentialRampToValueAtTime(.001, c.currentTime + .8);
                o.start();
                o.stop(c.currentTime + .8);
            } catch (e) {}
        }

        function addFocusLog() {
            const log = document.getElementById('focusLog');
            const sel = document.getElementById('pomoTask');
            const label = sel?.options[sel.selectedIndex]?.text || 'Study Session';
            const now = new Date().toLocaleTimeString('en', {
                hour: '2-digit',
                minute: '2-digit'
            });
            const entry = document.createElement('div');
            entry.className = 'fl-item';
            entry.innerHTML = `<span class="fl-t">${now}</span><span class="fl-l">🍅 ${label}</span><span class="fl-d">${pomo.total/60}m</span>`;
            const empty = log.querySelector('[style*="text-align:center"]');
            if (empty) log.innerHTML = '';
            log.insertBefore(entry, log.firstChild);
        }

        function renderFocusPanel() {
            const sel = document.getElementById('pomoTask');
            const active = S.tasks.filter(t => !t.done);
            sel.innerHTML = active.length ? active.map(t => `<option value="${t.id}">${t.title}</option>`).join('') : '<option>No active tasks — add some!</option>';
            document.getElementById('flowPrinciple').textContent = FLOW_PRINCIPLES[Math.floor(Math.random() * FLOW_PRINCIPLES.length)];
            document.getElementById('pomoCount').textContent = S.pomodoros;
        }

        // Week habits in focus panel
        function renderWeekHabits() {
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const days = [];
            for (let i = 6; i >= 0; i--) {
                const d = new Date(today);
                d.setDate(d.getDate() - i);
                days.push(d);
            }
            const dows = ['Su', 'M', 'T', 'W', 'T', 'F', 'S'];
            const subHabits = GOOD_HABITS.slice(0, 5);
            document.getElementById('weekHabits').innerHTML = subHabits.map(h => `
    <div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border);">
      <div style="font-size:11.5px;flex:1;">${h.icon} ${h.label.split(' ').slice(0,3).join(' ')}</div>
      <div style="display:flex;gap:3px;">${days.map((d,i)=>{
        const k=`${h.id}-${d.toISOString().split('T')[0]}`;const done=S.goodH[k];const isT=d.getTime()===today.getTime();
        return `<div style="width:20px;height:20px;border-radius:3px;border:1.5px solid ${done?'var(--green)':isT?'var(--orange)':'var(--border)'};background:${done?'var(--green)':'transparent'};cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:7px;color:${done?'#000':'var(--muted)'};" onclick="toggleGoodH('${h.id}','${d.toISOString().split('T')[0]}')" title="${dows[d.getDay()]}">${dows[d.getDay()]}</div>`;
      }).join('')}</div>
    </div>`).join('');
        }

        // ══════════════════════════════════════════════════════
        // HABITS
        // ══════════════════════════════════════════════════════
        function renderHabits() {
            document.getElementById('habitDay').textContent = getDayNum();
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('goodHabits').innerHTML = GOOD_HABITS.map(h => {
                const k = `${h.id}-${today}`;
                const done = !!S.goodH[k];
                return `<div class="hab-item ${done?'good-on':''}" onclick="toggleGoodH('${h.id}','${today}')"><div class="hab-chk">${done?'✓':''}</div><div style="font-size:14px;">${h.icon}</div><div class="hab-lbl">${h.label}</div></div>`;
            }).join('');
            document.getElementById('badHabits').innerHTML = BAD_HABITS.map(h => {
                const k = `${h.id}-${today}`;
                const broken = !!S.badH[k];
                return `<div class="hab-item ${broken?'bad-on':''}" onclick="toggleBadH('${h.id}','${today}')"><div class="hab-chk">${broken?'✗':''}</div><div style="font-size:14px;">${h.icon}</div><div class="hab-lbl">${h.label}</div></div>`;
            }).join('');
            updateScore();
        }

        function toggleGoodH(id, date) {
            S.goodH[`${id}-${date}`] = !S.goodH[`${id}-${date}`];
            persist();
            if (document.getElementById('goodHabits').children.length) renderHabits();
            renderWeekHabits();
            updateScore();
        }

        function toggleBadH(id, date) {
            S.badH[`${id}-${date}`] = !S.badH[`${id}-${date}`];
            persist();
            renderHabits();
        }

        // ══════════════════════════════════════════════════════
        // COURSES
        // ══════════════════════════════════════════════════════
        function getAllCourses() {
            return COURSE_GROUPS.flatMap(g => g.courses);
        }

        function renderCourses() {
            const all = getAllCourses();
            const total = all.reduce((s, c) => s + c.totalHrs, 0);
            const done = all.reduce((s, c) => s + (parseFloat(S.courseH[c.id]) || 0), 0);
            const pct = Math.round((done / total) * 100);
            document.getElementById('totalPct').textContent = pct + '%';
            document.getElementById('totalHrs').textContent = `${done.toFixed(1)} / ${total} hrs`;
            document.getElementById('totalBar').style.width = pct + '%';
            ['dsa', 'llm', 'webdev'].forEach(gid => {
                const g = COURSE_GROUPS.find(x => x.id === gid);
                if (!g) return;
                const gd = g.courses.reduce((s, c) => s + (parseFloat(S.courseH[c.id]) || 0), 0);
                const gt = g.courses.reduce((s, c) => s + c.totalHrs, 0);
                const el = document.getElementById('grp-' + gid);
                if (el) el.textContent = Math.round((gd / gt) * 100) + '%';
            });
            let html = '';
            COURSE_GROUPS.forEach(g => {
                const gd = g.courses.reduce((s, c) => s + (parseFloat(S.courseH[c.id]) || 0), 0);
                const gt = g.courses.reduce((s, c) => s + c.totalHrs, 0);
                const gp = Math.round((gd / gt) * 100);
                html += `<div style="margin-bottom:5px;margin-top:16px;"><div style="display:flex;align-items:center;justify-content:space-between;padding:9px 13px;background:rgba(${hexRgb(g.color)},.08);border:1px solid rgba(${hexRgb(g.color)},.2);border-radius:var(--r-sm);cursor:pointer;" onclick="toggleGrp('${g.id}')">
      <div style="font-family:'Syne',sans-serif;font-size:12px;font-weight:800;color:${g.color};">${g.label}</div>
      <div style="display:flex;align-items:center;gap:10px;"><span style="font-size:9px;color:var(--muted);">${g.days}</span><span style="font-family:'Syne',sans-serif;font-size:13px;font-weight:800;color:${g.color};">${gp}%</span><span style="font-size:9px;color:var(--muted);">${gd.toFixed(1)}/${gt}hr</span><span id="ga-${g.id}" style="font-size:10px;color:var(--muted);">▼</span></div>
    </div><div style="height:2px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:2px;"><div style="height:100%;background:${g.color};width:${gp}%;transition:width .5s;"></div></div></div>
    <div id="grp-${g.id}">`;
                g.courses.forEach(c => {
                    const cd = parseFloat(S.courseH[c.id]) || 0;
                    const cp = Math.round((cd / c.totalHrs) * 100);
                    html += `<div class="ci" style="border-left-color:${c.color};margin-left:10px;">
        <div class="ci-head"><div class="ci-title">${c.icon} ${c.title}</div><div class="ci-pct" style="color:${c.color};">${cp}%</div></div>
        <div class="ci-meta">${c.days} · ${c.totalHrs} hrs total</div>
        <div class="ci-bar"><div class="ci-fill" style="width:${cp}%;background:${c.color};"></div></div>
        <div class="ci-row"><span style="font-size:10.5px;color:var(--muted);">Hours done:</span>
          <input type="number" class="ci-inp" value="${cd||''}" placeholder="0" min="0" max="${c.totalHrs+5}" step="0.5" onchange="updateCourse('${c.id}',this.value)"> / ${c.totalHrs}hr
          <span class="ci-left">${Math.max(0,c.totalHrs-cd).toFixed(1)} hr left</span>
        </div>
        ${c.tasks?`<div style="margin-top:7px;"><ul style="list-style:none;">${c.tasks.map(t=>`<li style="font-size:10px;color:var(--muted);padding:1px 0;display:flex;gap:4px;"><span style="color:${c.color};">›</span>${t}</li>`).join('')}</ul></div>`:''}
      </div>`;
                });
                html += '</div>';
            });
            document.getElementById('courseList').innerHTML = html;
        }

        function toggleGrp(id) {
            const el = document.getElementById('grp-' + id);
            const a = document.getElementById('ga-' + id);
            if (!el) return;
            el.style.display = el.style.display === 'none' ? 'block' : 'none';
            if (a) a.textContent = el.style.display === 'none' ? '▶' : '▼';
        }

        function hexRgb(hex) {
            const r = parseInt(hex.slice(1, 3), 16),
                g = parseInt(hex.slice(3, 5), 16),
                b = parseInt(hex.slice(5, 7), 16);
            return `${r},${g},${b}`;
        }

        function updateCourse(id, v) {
            S.courseH[id] = parseFloat(v) || 0;
            persist();
            renderCourses();
        }

        // ══════════════════════════════════════════════════════
        // SECOND BRAIN
        // ══════════════════════════════════════════════════════
        let noteSearch = '',
            autoSaveTimeout = null;

        function renderNotes() {
            let notes = [...S.notes];
            if (noteSearch) notes = notes.filter(n => (n.title || '').toLowerCase().includes(noteSearch) || (n.content || '').toLowerCase().includes(noteSearch));
            notes.sort((a, b) => b.updated - a.updated);
            if (!notes.length) {
                document.getElementById('notesList').innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted);font-size:11px;">📝 No notes yet. Create one!</div>';
                return;
            }
            document.getElementById('notesList').innerHTML = notes.map(n => `<div class="note-item ${S.currentNote===n.id?'active-n':''}" onclick="openNote(${n.id})"><div class="ni-t">${n.title||'Untitled'}</div><div class="ni-p">${(n.content||'').replace(/\n/g,' ').substring(0,55)}</div><div class="ni-d">${new Date(n.updated).toLocaleDateString('en',{month:'short',day:'numeric'})}</div></div>`).join('');
        }

        function newNote() {
            const n = {
                id: noteId++,
                title: '',
                content: '',
                tags: [],
                created: Date.now(),
                updated: Date.now()
            };
            S.notes.unshift(n);
            persist();
            openNote(n.id);
            renderNotes();
        }

        function openNote(id) {
            S.currentNote = id;
            const n = S.notes.find(n => n.id === id);
            if (!n) return;
            document.getElementById('noteTitleInp').value = n.title;
            document.getElementById('noteContent').value = n.content;
            document.getElementById('noteStatus').textContent = 'All changes saved';
            renderNoteTags(n);
            renderNotes();
        }

        function autoSave() {
            clearTimeout(autoSaveTimeout);
            document.getElementById('noteStatus').textContent = 'Saving…';
            autoSaveTimeout = setTimeout(() => {
                const n = S.notes.find(n => n.id === S.currentNote);
                if (n) {
                    n.title = document.getElementById('noteTitleInp').value;
                    n.content = document.getElementById('noteContent').value;
                    n.updated = Date.now();
                    persist();
                    renderNotes();
                    document.getElementById('noteStatus').textContent = 'All changes saved';
                }
            }, 700);
        }

        function renderNoteTags(n) {
            document.getElementById('noteTags').innerHTML = (n.tags || []).map((t, i) => `<span class="tag" style="background:var(--orange-bg);color:var(--orange);cursor:pointer;" onclick="removeTag(${i})">${t} ×</span>`).join('');
        }

        function addNoteTag() {
            const inp = document.getElementById('noteTagInp');
            const tag = inp.value.trim().toLowerCase();
            if (!tag) return;
            const n = S.notes.find(n => n.id === S.currentNote);
            if (n && !n.tags.includes(tag)) {
                n.tags.push(tag);
                persist();
                renderNoteTags(n);
            }
            inp.value = '';
        }

        function removeTag(i) {
            const n = S.notes.find(n => n.id === S.currentNote);
            if (n) {
                n.tags.splice(i, 1);
                persist();
                renderNoteTags(n);
            }
        }

        function deleteNote() {
            if (!S.currentNote || !confirm('Delete this note?')) return;
            S.notes = S.notes.filter(n => n.id !== S.currentNote);
            S.currentNote = null;
            persist();
            document.getElementById('noteTitleInp').value = '';
            document.getElementById('noteContent').value = '';
            renderNotes();
        }

        function searchNotes() {
            noteSearch = document.getElementById('noteSearch').value.toLowerCase();
            renderNotes();
        }

        function fmtNote(type) {
            const ta = document.getElementById('noteContent');
            const sel = ta.value.substring(ta.selectionStart, ta.selectionEnd);
            const m = {
                bold: `**${sel||'bold'}**`,
                italic: `*${sel||'italic'}*`,
                code: `\`${sel||'code'}\``,
                heading: `\n## ${sel||'Heading'}\n`
            };
            document.execCommand('insertText', false, m[type] || sel);
            autoSave();
        }

        // ══════════════════════════════════════════════════════
        // REFLECT
        // ══════════════════════════════════════════════════════
        let currentMood = 3;
        const RF_PROMPTS = ['What is the ONE thing that — if done today — would make everything else easier?', 'Where did you lose time today? What pattern do you see?', 'What did you learn today that you didn\'t know yesterday?', 'Are you moving toward your goals or just feeling busy?', 'If you had only 2 hours tomorrow, what would you work on first?'];

        function renderReflect() {
            document.getElementById('reflectDate').textContent = new Date().toLocaleDateString('en', {
                weekday: 'long',
                month: 'long',
                day: 'numeric'
            });
            document.getElementById('rfQuote').textContent = RF_PROMPTS[new Date().getDay() % RF_PROMPTS.length];
            const hist = document.getElementById('reflectHistory');
            const sorted = [...S.reflections].reverse().slice(0, 10);
            if (!sorted.length) {
                hist.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted);font-size:11px;">🌱 Complete your first reflection</div>';
                return;
            }
            const me = ['', '😴', '😔', '😐', '😊', '🔥'];
            hist.innerHTML = sorted.map(r => `<div class="rh-entry"><div class="rhe-date">${r.date}</div><div style="font-size:16px;">${me[r.mood||3]}</div>${r.win?`<div style="font-size:11px;color:var(--text2);margin-top:3px;"><strong>Win:</strong> ${r.win}</div>`:''} ${r.tomorrow?`<div style="font-size:11px;color:var(--muted);margin-top:2px;"><strong>Tomorrow:</strong> ${r.tomorrow}</div>`:''}</div>`).join('');
        }

        function setMood(val, btn) {
            currentMood = val;
            document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('on'));
            btn.classList.add('on');
        }

        function saveReflection() {
            const today = new Date().toDateString();
            const e = {
                date: today,
                mood: currentMood,
                win: document.getElementById('rfWin').value.trim(),
                improve: document.getElementById('rfImprove').value.trim(),
                tomorrow: document.getElementById('rfTomorrow').value.trim(),
                focus: parseInt(document.getElementById('rfFocus').value),
                created: Date.now()
            };
            const idx = S.reflections.findIndex(r => r.date === today);
            if (idx >= 0) S.reflections[idx] = e;
            else S.reflections.push(e);
            persist();
            renderReflect();
            document.getElementById('rfWin').value = '';
            document.getElementById('rfImprove').value = '';
            document.getElementById('rfTomorrow').value = '';
        }

        // ══════════════════════════════════════════════════════
        // STATS
        // ══════════════════════════════════════════════════════
        function renderStats() {
            document.getElementById('st-pomo').textContent = S.pomodoros;
            document.getElementById('st-tasks').textContent = S.tasks.filter(t => t.done).length;
            document.getElementById('st-days').textContent = S.doneDays.length;
            document.getElementById('st-streak').textContent = S.streak;
            // Weekly chart
            const now = new Date();
            const dow = ['Su', 'M', 'T', 'W', 'T', 'F', 'S'];
            let bars = '',
                labels = '';
            for (let i = 6; i >= 0; i--) {
                const d = new Date(now);
                d.setDate(d.getDate() - i);
                const hrs = i === 0 ? S.pomodoros * 0.42 : Math.random() * 5;
                const h = Math.max(3, Math.min(64, (hrs / 6) * 64));
                const isT = i === 0;
                bars += `<div class="wk-col"><div style="font-size:8px;color:var(--muted);">${hrs.toFixed(1)}h</div><div class="wk-bar" style="height:${h}px;background:${isT?'var(--orange)':'var(--border2)'};"></div></div>`;
                labels += `<div style="flex:1;text-align:center;font-size:8.5px;color:${isT?'var(--orange)':'var(--muted)'};">${dow[d.getDay()]}</div>`;
            }
            document.getElementById('weekChart').innerHTML = bars;
            document.getElementById('weekLabels').innerHTML = labels;
            // Learning progress
            const cols = {
                dsa: 'var(--cyan)',
                dbms: 'var(--purple)',
                llm: 'var(--orange)',
                webdev: 'var(--green)',
                english: 'var(--pink)',
                numerical: 'var(--yellow)'
            };
            const subMap = {
                dsa: [0, 0],
                dbms: [0, 0],
                llm: [0, 0],
                webdev: [0, 0],
                english: [0, 0],
                numerical: [0, 0]
            };
            PLAN.forEach(p => {
                if (subMap[p.sub]) {
                    subMap[p.sub][1]++;
                    if (S.doneDays.includes(p.d)) subMap[p.sub][0]++;
                }
            });
            document.getElementById('statsProgress').innerHTML = Object.entries(subMap).map(([s, [d, t]]) => {
                const pct = t > 0 ? Math.round((d / t) * 100) : 0;
                return `<div class="pr-row"><span class="pr-lbl" style="font-size:10px;">${s==='numerical'?'Numerical':s==='webdev'?'Web Dev':s.toUpperCase()}</span><div class="pr-bar"><div class="pr-fill" style="width:${pct}%;background:${cols[s]};"></div></div><span class="pr-pct">${pct}%</span></div>`;
            }).join('');
            // Heatmap
            let hm = '';
            for (let i = 34; i >= 0; i--) {
                const lvl = Math.floor(Math.random() * 5);
                hm += `<div class="hm-c hm-${lvl}"></div>`;
            }
            document.getElementById('heatmap').innerHTML = hm;
            // Achievements
            document.getElementById('achievList').innerHTML = ACHIEVEMENTS.map(a => {
                const u = a.check(S);
                return `<div class="ach-item ${u?'':'locked'}"><div class="ach-icon">${a.icon}</div><div><div class="ach-name">${a.name}</div><div class="ach-desc">${a.desc}</div></div>${u?'<span class="tag" style="background:var(--green-bg);color:var(--green);margin-left:auto;">✓</span>':''}</div>`;
            }).join('');
        }

        // ══════════════════════════════════════════════════════
        // SCHEDULE FULL
        // ══════════════════════════════════════════════════════
        function renderFullSchedule() {
            const catMap = {
                'm': 'cat-m',
                'g': 'cat-g',
                'b': 'cat-b',
                's': 'cat-s',
                'r': 'cat-r',
                'c': 'cat-c'
            };
            const bdrMap = {
                'b': 'var(--purple)',
                'g': 'var(--green)',
                'm': 'var(--yellow)',
                's': 'var(--cyan)',
                'c': 'var(--orange)',
                'r': 'var(--border)'
            };
            document.getElementById('fullSchedule').innerHTML = SCHEDULE.map(s => `<div class="card card-sm" style="margin-bottom:7px;border-left:3px solid ${bdrMap[s.cat]||'var(--border)'};"><div style="display:flex;gap:12px;align-items:flex-start;"><div style="flex-shrink:0;text-align:right;width:85px;"><div style="font-size:11px;font-weight:600;">${s.t}</div><div style="font-size:8px;font-weight:700;padding:1px 5px;border-radius:3px;background:var(--faint);color:var(--muted);margin-top:2px;display:inline-block;">${s.dur}</div></div><div><div class="si-title">${s.icon} ${s.title} <span class="si-cat ${catMap[s.cat]||'cat-r'}">${s.cat.toUpperCase()}</span></div><div class="si-desc">${s.desc}</div></div></div></div>`).join('');
        }

        // ══════════════════════════════════════════════════════
        // MANIFESTO
        // ══════════════════════════════════════════════════════
        function renderManifesto() {
            document.getElementById('manifestoRules').innerHTML = MANIFESTO_RULES.map(r => `<div class="rule-item"><div class="rule-n">${r.n}</div><div><div class="rule-title">${r.title}</div><div class="rule-desc">${r.desc}</div></div></div>`).join('');
        }

        // ══════════════════════════════════════════════════════
        // SEED DATA & INIT
        // ══════════════════════════════════════════════════════
        if (S.tasks.length === 0) {
            const plan = getPlan(getDayNum());
            plan.tasks.forEach((t, i) => {
                S.tasks.push({
                    id: taskId++,
                    title: t,
                    subject: plan.sub,
                    priority: i === 0 ? 'high' : 'medium',
                    due: '',
                    done: false,
                    created: Date.now()
                });
            });
            persist();
        }

        // Init all
        renderDash();
        renderManifesto();
        updateBadge();
        document.getElementById('planCompleteCount') && (document.getElementById('planCompleteCount').textContent = S.doneDays.length);
        updatePomoDisp();

        // Prompt chip auto-height
        const ai = document.getElementById('aiInp');
        if (ai) ai.addEventListener('input', function() {
            this.style.height = '36px';
            this.style.height = Math.min(this.scrollHeight, 100) + 'px';
        });
    </script>
</body>

</html>
