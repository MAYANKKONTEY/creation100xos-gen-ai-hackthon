        function renderTasks() {
            let tasks = [...S.tasks];
            const f = S.taskFilter;
            if (f === 'active') tasks = tasks.filter(t => !t.done);
            else if (f === 'done') tasks = tasks.filter(t => t.done);
            else if (f === 'high') tasks = tasks.filter(t => t.priority === 'high');
            else if (['dsa', 'dbms', 'llm', 'webdev', 'english', 'numerical'].includes(f)) tasks = tasks.filter(t => t.subject === f);
            tasks.sort((a, b) => {
                if (a.done !== b.done) return a.done ? 1 : -1;
                const p = {
                    high: 0,
                    medium: 1,
                    low: 2
                };
                return (p[a.priority] || 1) - (p[b.priority] || 1);
            });
            if (!tasks.length) {
                document.getElementById('taskList').innerHTML = '<div style="text-align:center;padding:36px;color:var(--muted);font-size:12px;">No tasks here. Add one above ✨</div>';
                return;
            }
            document.getElementById('taskList').innerHTML = tasks.map(t => `<div class="task-item ${t.done?'done':''}"><div class="ti-chk ${t.done?'checked':''}" onclick="toggleTask(${t.id})"></div><div class="ti-body"><div class="ti-title">${t.title}</div><div class="ti-meta"><span class="tag tag-${t.subject}">${t.subject==='numerical'?'Num':t.subject==='webdev'?'Web':t.subject.toUpperCase()}</span><span class="tag tag-${t.priority}">${t.priority}</span>${t.due?`<span class="ti-due">📅 ${t.due}</span>`:''}</div></div><button class="btn btn-danger" onclick="deleteTask(${t.id})">✕</button></div>`).join('');
        }

