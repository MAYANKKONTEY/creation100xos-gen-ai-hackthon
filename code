<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MAYANK OS — Ultimate Academic Domination System</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,700;1,9..144,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #07080F;
            --surface: #0c0e17;
            --card: #111420;
            --card2: #161a28;
            --border: #1d2438;
            --border2: #263050;
            --text: #e4e8f5;
            --text2: #a8b4d0;
            --muted: #4e5a7a;
            --faint: #1a2035;
            --orange: #ff6b35;
            --cyan: #00d4ff;
            --green: #22d984;
            --purple: #9b72f8;
            --pink: #ff4fa3;
            --yellow: #ffc93d;
            --red: #ff4757;
            --blue: #4f8ef7;
            --amber: #e8a02a;
            --orange-bg: rgba(255, 107, 53, .1);
            --cyan-bg: rgba(0, 212, 255, .08);
            --green-bg: rgba(34, 217, 132, .08);
            --purple-bg: rgba(155, 114, 248, .08);
            --pink-bg: rgba(255, 79, 163, .08);
            --yellow-bg: rgba(255, 201, 61, .08);
            --red-bg: rgba(255, 71, 87, .08);
            --amber-bg: rgba(232, 160, 42, .09);
            --blue-bg: rgba(79, 142, 247, .08);
            --r: 12px;
            --r-sm: 8px;
            --sidebar: 220px;
            --hdr: 52px;
            --shadow: 0 8px 32px rgba(0, 0, 0, .5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-font-smoothing: antialiased;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Mono', monospace;
            height: 100vh;
            overflow: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 80% 50% at 5% -10%, rgba(255, 107, 53, .06), transparent),
                radial-gradient(ellipse 60% 40% at 95% 110%, rgba(155, 114, 248, .05), transparent);
            pointer-events: none;
            z-index: 0;
        }

        button,
        input,
        textarea,
        select {
            font-family: 'DM Mono', monospace;
        }

        button {
            cursor: pointer;
        }

        ::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border2);
            border-radius: 2px;
        }

        /* ── TICKER ── */
        .ticker {
            background: linear-gradient(90deg, var(--orange), #ff9a00, var(--orange));
            height: 28px;
            overflow: hidden;
            display: flex;
            align-items: center;
            position: relative;
            z-index: 100;
        }

        .ticker-inner {
            display: flex;
            gap: 0;
            white-space: nowrap;
            animation: tick 40s linear infinite;
        }

        .ticker-inner span {
            font-family: 'Syne', sans-serif;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 2.5px;
            color: #000;
            padding: 0 20px;
        }

        .ticker-inner span::after {
            content: '◆';
            margin-left: 20px;
        }

        @keyframes tick {
            from {
                transform: translateX(0);
            }

            to {
                transform: translateX(-50%);
            }
        }

        /* ── LAYOUT ── */
        .shell {
            display: flex;
            height: calc(100vh - 28px);
            overflow: hidden;
            position: relative;
            z-index: 1;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar);
            flex-shrink: 0;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .sidebar-logo {
            padding: 16px 14px 12px;
            border-bottom: 1px solid var(--border);
        }

        .logo-row {
            display: flex;
            align-items: center;
            gap: 9px;
        }

        .logo-mark {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, var(--orange), #ff9a00);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .logo-name {
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 800;
            line-height: 1;
        }

        .logo-sub {
            font-size: 8px;
            color: var(--muted);
            letter-spacing: 1.5px;
            margin-top: 2px;
        }

        .sidebar-nav {
            flex: 1;
            padding: 8px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 1px;
        }

        .nav-sec {
            font-size: 8px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2.5px;
            color: var(--muted);
            padding: 10px 8px 4px;
        }

        .ni {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 10px;
            border-radius: var(--r-sm);
            font-size: 11.5px;
            font-weight: 500;
            color: var(--muted);
            cursor: pointer;
            transition: all .13s;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }

        .ni:hover {
            background: var(--faint);
            color: var(--text2);
        }

        .ni.active {
            background: var(--orange-bg);
            color: var(--orange);
            border: 1px solid rgba(255, 107, 53, .2);
        }

        .ni .ic {
            font-size: 14px;
            width: 16px;
            text-align: center;
            flex-shrink: 0;
        }

        .ni .nb {
            margin-left: auto;
            background: var(--orange);
            color: #000;
            font-size: 8px;
            font-weight: 800;
            padding: 1px 5px;
            border-radius: 6px;
            min-width: 16px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 10px;
            border-top: 1px solid var(--border);
        }

        .day-widget {
            background: linear-gradient(135deg, rgba(255, 107, 53, .12), rgba(255, 154, 0, .06));
            border: 1px solid rgba(255, 107, 53, .2);
            border-radius: var(--r-sm);
            padding: 12px;
            text-align: center;
        }

        .dw-num {
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 800;
            color: var(--orange);
            line-height: 1;
        }

        .dw-lbl {
            font-size: 8px;
            color: var(--muted);
            letter-spacing: 2px;
            font-weight: 700;
            margin-top: 1px;
        }

        .dw-bar {
            height: 3px;
            background: var(--border);
            border-radius: 2px;
            margin-top: 8px;
            overflow: hidden;
        }

        .dw-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--orange), #ff9a00);
            border-radius: 2px;
            transition: width .5s ease;
        }

        /* ── MAIN ── */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .topbar {
            height: var(--hdr);
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 18px;
            gap: 10px;
            flex-shrink: 0;
        }

        .tb-title {
            font-family: 'Syne', sans-serif;
            font-size: 14px;
            font-weight: 800;
            flex: 1;
        }

        .tb-date {
            font-size: 10px;
            color: var(--muted);
        }

        .tb-pill {
            display: flex;
            align-items: center;
            gap: 4px;
            border-radius: 20px;
            padding: 4px 10px;
            font-size: 10px;
            font-weight: 700;
            border: 1px solid;
        }

        .pill-orange {
            background: var(--orange-bg);
            border-color: rgba(255, 107, 53, .25);
            color: var(--orange);
        }

        .pill-cyan {
            background: var(--cyan-bg);
            border-color: rgba(0, 212, 255, .2);
            color: var(--cyan);
        }

        .pill-green {
            background: var(--green-bg);
            border-color: rgba(34, 217, 132, .2);
            color: var(--green);
        }

        .content {
            flex: 1;
            overflow-y: auto;
            padding: 18px;
        }

        /* ── PANELS ── */
        .panel {
            display: none;
        }

        .panel.active {
            display: block;
            animation: panelIn .2s ease both;
        }

        @keyframes panelIn {
            from {
                opacity: 0;
                transform: translateY(5px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── BASE COMPONENTS ── */
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 16px;
        }

        .card-sm {
            padding: 12px 14px;
        }

        .ct {
            font-family: 'Syne', sans-serif;
            font-size: 9px;
            font-weight: 800;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .g2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .g3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 12px;
        }

        .g4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        /* stat cards */
        .sc {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 14px;
            position: relative;
            overflow: hidden;
        }

        .sc::after {
            content: '';
            position: absolute;
            top: -15px;
            right: -15px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            filter: blur(22px);
            opacity: .35;
        }

        .sc.orange::after {
            background: var(--orange);
        }

        .sc.cyan::after {
            background: var(--cyan);
        }

        .sc.green::after {
            background: var(--green);
        }

        .sc.purple::after {
            background: var(--purple);
        }

        .sc.amber::after {
            background: var(--amber);
        }

        .sc-icon {
            font-size: 18px;
            margin-bottom: 6px;
        }

        .sc-val {
            font-family: 'Syne', sans-serif;
            font-size: 24px;
            font-weight: 800;
            line-height: 1;
        }

        .sc.orange .sc-val {
            color: var(--orange);
        }

        .sc.cyan .sc-val {
            color: var(--cyan);
        }

        .sc.green .sc-val {
            color: var(--green);
        }

        .sc.purple .sc-val {
            color: var(--purple);
        }

        .sc.amber .sc-val {
            color: var(--amber);
        }

        .sc-lbl {
            font-size: 10px;
            color: var(--muted);
            margin-top: 3px;
        }

        /* buttons */
        .btn {
            padding: 7px 14px;
            border-radius: var(--r-sm);
            font-size: 11.5px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all .13s;
            letter-spacing: .3px;
        }

        .btn-orange {
            background: var(--orange);
            color: #000;
        }

        .btn-orange:hover {
            opacity: .85;
            transform: translateY(-1px);
        }

        .btn-ghost {
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--text2);
        }

        .btn-ghost:hover {
            border-color: var(--orange);
            color: var(--orange);
        }

        .btn-sm {
            padding: 4px 10px;
            font-size: 10.5px;
        }

        .btn-danger {
            background: var(--red-bg);
            border: 1px solid rgba(255, 71, 87, .2);
            color: var(--red);
            padding: 3px 8px;
            font-size: 10px;
        }

        /* inputs */
        .inp {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            padding: 7px 11px;
            font-size: 11.5px;
            color: var(--text);
            outline: none;
            transition: border-color .13s;
        }

        .inp:focus {
            border-color: var(--orange);
        }

        .inp::placeholder {
            color: var(--muted);
        }

        .sel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            padding: 7px 10px;
            font-size: 11.5px;
            color: var(--text);
            outline: none;
            cursor: pointer;
        }

        /* progress */
        .pr-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 7px;
        }

        .pr-lbl {
            font-size: 10.5px;
            width: 75px;
            flex-shrink: 0;
            color: var(--text2);
        }

        .pr-bar {
            flex: 1;
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            overflow: hidden;
        }

        .pr-fill {
            height: 100%;
            border-radius: 2px;
            transition: width .5s;
        }

        .pr-pct {
            font-size: 9px;
            color: var(--muted);
            width: 28px;
            text-align: right;
        }

        /* tags */
        .tag {
            font-size: 9px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .tag-dsa {
            background: var(--cyan-bg);
            color: var(--cyan);
        }

        .tag-dbms {
            background: var(--purple-bg);
            color: var(--purple);
        }

        .tag-llm {
            background: var(--orange-bg);
            color: var(--orange);
        }

        .tag-webdev {
            background: var(--green-bg);
            color: var(--green);
        }

        .tag-english {
            background: var(--pink-bg);
            color: var(--pink);
        }

        .tag-numerical {
            background: var(--yellow-bg);
            color: var(--yellow);
        }

        .tag-personal {
            background: var(--faint);
            color: var(--muted);
        }

        .tag-high {
            background: var(--red-bg);
            color: var(--red);
        }

        .tag-medium {
            background: var(--orange-bg);
            color: var(--orange);
        }

        .tag-low {
            background: var(--green-bg);
            color: var(--green);
        }

        /* tasks */
        .task-item {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            padding: 9px 12px;
            display: flex;
            align-items: center;
            gap: 9px;
            transition: all .13s;
            margin-bottom: 5px;
            animation: slideIn .15s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-4px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .task-item:hover {
            border-color: var(--border2);
        }

        .task-item.done {
            opacity: .4;
        }

        .task-item.done .ti-title {
            text-decoration: line-through;
            color: var(--muted);
        }

        .ti-chk {
            width: 17px;
            height: 17px;
            border: 2px solid var(--border);
            border-radius: 4px;
            flex-shrink: 0;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .12s;
        }

        .ti-chk:hover {
            border-color: var(--green);
        }

        .ti-chk.checked {
            background: var(--green);
            border-color: var(--green);
        }

        .ti-chk.checked::after {
            content: '✓';
            font-size: 9px;
            color: #000;
            font-weight: 800;
        }

        .ti-body {
            flex: 1;
        }

        .ti-title {
            font-size: 12px;
            font-weight: 500;
            margin-bottom: 3px;
        }

        .ti-meta {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            align-items: center;
        }

        .ti-due {
            font-size: 9px;
            color: var(--muted);
        }

        /* filter chips */
        .fc-bar {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .fc {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 600;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--muted);
            cursor: pointer;
            transition: all .12s;
        }

        .fc.on {
            border-color: var(--orange);
            color: var(--orange);
            background: var(--orange-bg);
        }

        .fc:hover {
            border-color: var(--border2);
            color: var(--text2);
        }

        /* battle items */
        .battle {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
        }

        .battle:last-child {
            border-bottom: none;
        }

        .btl-chk {
            width: 17px;
            height: 17px;
            border: 1.5px solid var(--border);
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all .12s;
        }

        .btl-chk:hover {
            border-color: var(--orange);
        }

        .btl-chk.done {
            background: var(--green);
            border-color: var(--green);
        }

        .btl-chk.done::after {
            content: '✓';
            font-size: 9px;
            color: #000;
            font-weight: 800;
        }

        .btl-title {
            font-size: 11.5px;
            flex: 1;
        }

        /* schedule */
        .sched-item {
            display: flex;
            gap: 12px;
            padding: 9px 0;
            border-bottom: 1px solid var(--border);
        }

        .sched-item:last-child {
            border-bottom: none;
        }

        .sched-item.active-now {
            background: rgba(255, 107, 53, .04);
            border-left: 2px solid var(--orange);
            padding-left: 10px;
            margin-left: -12px;
        }

        .si-time {
            font-size: 10px;
            color: var(--muted);
            width: 80px;
            flex-shrink: 0;
            padding-top: 1px;
        }

        .si-dur {
            display: inline-block;
            font-size: 8px;
            font-weight: 700;
            padding: 1px 5px;
            border-radius: 3px;
            background: var(--faint);
            color: var(--muted);
            margin-top: 2px;
        }

        .si-title {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 1px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .si-desc {
            font-size: 10.5px;
            color: var(--muted);
            line-height: 1.5;
        }

        .si-cat {
            font-size: 8px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            padding: 1px 6px;
            border-radius: 3px;
        }

        .cat-m {
            background: var(--yellow-bg);
            color: var(--yellow);
        }

        .cat-g {
            background: var(--green-bg);
            color: var(--green);
        }

        .cat-b {
            background: var(--purple-bg);
            color: var(--purple);
        }

        .cat-s {
            background: var(--cyan-bg);
            color: var(--cyan);
        }

        .cat-r {
            background: var(--faint);
            color: var(--muted);
        }

        .cat-c {
            background: var(--orange-bg);
            color: var(--orange);
        }

        /* habits */
        .hab-item {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 8px 12px;
            border-radius: var(--r-sm);
            border: 1px solid var(--border);
            background: var(--card);
            margin-bottom: 5px;
            cursor: pointer;
            transition: all .13s;
        }

        .hab-item.good-on {
            background: rgba(34, 217, 132, .06);
            border-color: rgba(34, 217, 132, .3);
        }

        .hab-item.bad-on {
            background: rgba(255, 71, 87, .06);
            border-color: rgba(255, 71, 87, .3);
        }

        .hab-chk {
            width: 19px;
            height: 19px;
            border: 2px solid var(--border);
            border-radius: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all .12s;
            font-size: 10px;
            font-weight: 800;
        }

        .good-on .hab-chk {
            background: var(--green);
            border-color: var(--green);
            color: #000;
        }

        .bad-on .hab-chk {
            background: var(--red);
            border-color: var(--red);
            color: #fff;
        }

        .hab-lbl {
            font-size: 11.5px;
            flex: 1;
        }

        .hab-sec {
            font-family: 'Syne', sans-serif;
            font-size: 11px;
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 5px;
            margin-bottom: 10px;
            padding: 7px 12px;
            border-radius: var(--r-sm);
        }

        .hab-sec-good {
            background: var(--green-bg);
            color: var(--green);
        }

        .hab-sec-bad {
            background: var(--red-bg);
            color: var(--red);
        }

        /* plan grid */
        .plan-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 7px;
        }

        .plan-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            padding: 9px;
            cursor: pointer;
            transition: all .14s;
            position: relative;
        }

        .plan-card:hover {
            border-color: var(--orange);
            transform: translateY(-1px);
