        // ===================== TIMERS =====================
        const timers = {};

        function startTimer(id) {
            if (timers[id]?.interval) return;
            const el = document.getElementById(id + 'Timer');
            if (!el) return;
            const [m, s] = el.textContent.split(':').map(Number);
            let secs = m * 60 + s;
            timers[id] = {
                interval: setInterval(() => {
                    secs--;
                    if (secs <= 0) {
                        clearInterval(timers[id].interval);
                        timers[id].interval = null;
                        el.textContent = '00:00';
                        el.style.color = 'var(--red)';
                        alert(`${id} timer done! 🔥`);
                        return;
                    }
                    const mm = Math.floor(secs / 60).toString().padStart(2, '0');
                    const ss = (secs % 60).toString().padStart(2, '0');
                    el.textContent = `${mm}:${ss}`;
                }, 1000)
            };
        }

        function pauseTimer(id) {
            if (timers[id]?.interval) {
                clearInterval(timers[id].interval);
                timers[id].interval = null;
            }
        }

        function resetTimer(id) {
            pauseTimer(id);
            const defaults = {
                cardio: '25:00',
                music: '30:00',
                meditation: '10:00',
                writing: '10:00'
            };
            const el = document.getElementById(id + 'Timer');
            if (el) {
                el.textContent = defaults[id] || '10:00';
                el.style.color = 'var(--green)';
            }
        }

        function setTimer(id, minutes) {
            pauseTimer(id);
            const el = document.getElementById(id + 'Timer');
            if (el) {
                el.textContent = `${String(minutes).padStart(2,'0')}:00`;
                el.style.color = 'var(--green)';
            }
