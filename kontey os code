                        <div class="card-title"><span class="icon">💪</span> Drills Library</div>
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;">
                        <div style="padding:12px;background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);">
                            <div style="font-weight:600;font-size:13px;margin-bottom:6px;">Footwork Drill</div>
                            <div style="font-size:11px;color:var(--text-muted);">4-corner drill · 3x10 reps · 15 min</div>
                        </div>
                        <div style="padding:12px;background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);">
                            <div style="font-weight:600;font-size:13px;margin-bottom:6px;">Shadow Badminton</div>
                            <div style="font-size:11px;color:var(--text-muted);">Move to all 6 corners · No shuttle · 10 min</div>
                        </div>
                        <div style="padding:12px;background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);">
                            <div style="font-weight:600;font-size:13px;margin-bottom:6px;">Wall Rally</div>
                            <div style="font-size:11px;color:var(--text-muted);">Hit shuttle on wall · Count rallies · Beat your record</div>
                        </div>
                        <div style="padding:12px;background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);">
                            <div style="font-weight:600;font-size:13px;margin-bottom:6px;">Jump Smash</div>
                            <div style="font-size:11px;color:var(--text-muted);">Explosive power · 5x10 reps · Max height</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <script>
        // ===================== STATE =====================
        let state = JSON.parse(localStorage.getItem('konteyOS') || '{}');

        // Defaults
        state.streakDay = state.streakDay || 1;
        state.dayCount = state.dayCount || 1;
        state.currentWeight = state.currentWeight || 100;
        state.startWeight = state.startWeight || 100;
        state.targetWeight = state.targetWeight || 70;
        state.totalProtein = state.totalProtein || 0;
        state.todaySteps = state.todaySteps || 0;
        state.journalEntries = state.journalEntries || [];
        state.savedLyrics = state.savedLyrics || [];
        state.sleepLog = state.sleepLog || [];
        state.badHistory = state.badHistory || [];
        state.thoughts = state.thoughts || [];
        state.habits = state.habits || [{
                name: 'Wake up early (no snooze)',
                done: false,
                streak: 0,
                icon: '⏰'
            },
            {
                name: 'Walk 8–10k steps',
                done: false,
                streak: 0,
                icon: '🚶'
            },
            {
                name: 'Gym / workout',
                done: false,
                streak: 0,
                icon: '🏋️'
            },
            {
                name: 'Drink 3L water',
                done: false,
                streak: 0,
                icon: '💧'
            },
            {
                name: 'Read 30 min',
                done: false,
                streak: 0,
                icon: '📚'
            },
            {
                name: 'No junk food',
                done: true,
                streak: 0,
                icon: '🚫'
            },
            {
                name: 'Write daily bars',
                done: false,
                streak: 0,
                icon: '🎤'
            },
            {
                name: 'Meditate 10 min',
                done: false,
                streak: 0,
                icon: '🧘'
            },
        ];
        // Default Badminton Mini-Habits state
        state.badmintonHabits = state.badmintonHabits || [{
                name: 'Footwork drills (15 min)',
                done: false,
                streak: 0
            },
            {
                name: 'Match play or rallying',
                done: false,
                streak: 0
            },
            {
                name: 'Smash practice (50 reps)',
                done: false,
                streak: 0
            },
            {
                name: 'Agility ladder warmup',
                done: false,
                streak: 0
            },
        ];

        const saveState = () => localStorage.setItem('konteyOS', JSON.stringify(state));

        // ===================== CLOCK =====================
        const updateClock = () => {
            const now = new Date();
            const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
            const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            document.getElementById('clockStr').textContent =
                now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
            document.getElementById('dateStr').textContent =
                `${days[now.getDay()]}, ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()}`;
            document.getElementById('streakDay').textContent = state.streakDay;
        };
        setInterval(updateClock, 1000);
        updateClock();

        // ===================== NAVIGATION =====================
        function showSection(id) {
            document.querySelectorAll('[id^="section-"]').forEach(el => el.style.display = 'none');
            document.getElementById('section-' + id).style.display = '';
            document.querySelectorAll('.nav-icon').forEach(el => el.classList.remove('active'));
            const icons = ['dashboard', 'gym', 'habits', 'sleep', 'journal', 'eat', 'music', 'persona', 'badminton', 'writing'];
            const idx = icons.indexOf(id);
            if (idx >= 0) document.querySelectorAll('.nav-icon')[idx + 1].classList.add('active');
            renderSection(id);
        }

        function renderSection(id) {
            if (id === 'dashboard') renderDashboard();
            else if (id === 'gym') renderGym();
            else if (id === 'habits') renderHabits();
            else if (id === 'journal') renderJournal();
            else if (id === 'eat') renderNutrition(); // Added this missing call!
            else if (id === 'music') renderMusic();
            else if (id === 'persona') renderPersona();
            else if (id === 'sleep') renderSleep();
            else if (id === 'badminton') renderBadminton();
            else if (id === 'writing') renderWriting();
        }

        // ===================== DASHBOARD =====================
        function renderDashboard() {
            // Weight
            const lost = state.startWeight - state.currentWeight;
            let targetDiff = state.startWeight - state.targetWeight;
            if (targetDiff <= 0) targetDiff = 1; // Prevent NaN
            const pct = Math.max(0, Math.min(100, Math.round((lost / targetDiff) * 100)));

            document.getElementById('currentWeight').textContent = state.currentWeight;
            document.getElementById('weightLost').textContent = Math.max(0, lost).toFixed(1);
            document.getElementById('weightPct').textContent = pct + '%';
            document.getElementById('weightBar').style.width = pct + '%';

            // Day count
            const dayPct = Math.min(100, Math.round((state.dayCount / 180) * 100));
            document.getElementById('dayCount').textContent = state.dayCount;
            document.getElementById('dayPct').textContent = dayPct + '%';
            document.getElementById('dayBar').style.width = dayPct + '%';

            let phaseName = 'Phase 1: Fat Loss Foundation';
            let phaseGoal = 'Lose 8–12 kg · Build discipline';
            if (state.dayCount > 60 && state.dayCount <= 120) {
                phaseName = 'Phase 2: Fat Loss + Muscle';
                phaseGoal = 'Lose 6–8 kg + build muscle';
            } else if (state.dayCount > 120) {
                phaseName = 'Phase 3: Athletic Shape';
                phaseGoal = 'Sharp physique + abs + jawline';
            }
            document.getElementById('phaseName').textContent = phaseName;
            document.getElementById('phaseGoal').textContent = phaseGoal;

            // Habits score
            const done = state.habits.filter(h => h.done).length;
            const score = Math.round((done / state.habits.length) * 10);
            document.getElementById('scoreNum').textContent = score;
            document.getElementById('habitsDone').textContent = done + '/' + state.habits.length;
            document.getElementById('habitsBar').style.width = ((done / state.habits.length) * 100) + '%';
            document.getElementById('scoreTip').textContent = score >= 8 ? '🔥 White Room Mode' : score >= 5 ? 'Keep going!' : 'Complete habits to score';

            // Quick habits
            const qh = document.getElementById('quickHabits');
            qh.innerHTML = state.habits.map((h, i) => `
    <div class="habit-row ${h.done ? 'done' : ''}" onclick="toggleHabit(${i})">
      <div class="habit-toggle">${h.done ? '✓' : ''}</div>
      <div class="habit-name">${h.icon} ${h.name}</div>
      <div class="habit-streak ${h.streak >= 7 ? 'hot' : ''}">🔥${h.streak}</div>
    </div>
  `).join('');

            // Protein updates
            document.getElementById('todayProtein').textContent = state.totalProtein;
            document.getElementById('proteinBar').style.width = Math.min(100, (state.totalProtein / 80) * 100) + '%';

            // Sleep mini
            renderSleepMini();
        }

        function renderSleepMini() {
            const last7 = state.sleepLog.slice(-7);
            const days = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
            const chart = document.getElementById('sleepMiniChart');
            const labels = document.getElementById('sleepMiniLabels');
            if (!chart || !labels) return;
            if (last7.length === 0) {
                chart.innerHTML = '<div style="font-size:11px;color:var(--text-muted)">No sleep data yet</div>';
                return;
            }
            const maxH = 9;
            chart.innerHTML = last7.map(s => {
                const h = s.hours;
                const cls = h >= 7 ? 'good' : h >= 5 ? 'ok' : 'bad';
                const heightPct = Math.min(100, (h / maxH) * 100);
                return `<div class="sleep-bar ${cls}" style="height:${heightPct}%" title="${h}h"></div>`;
            }).join('');
            labels.innerHTML = last7.map((_, i) => `<div class="sleep-label">${days[i % 7]}</div>`).join('');
            const avg = last7.reduce((a, b) => a + b.hours, 0) / last7.length;
            document.getElementById('todaySleep').textContent = avg.toFixed(1);
        }

        function toggleHabit(i) {
            state.habits[i].done = !state.habits[i].done;
            if (state.habits[i].done) state.habits[i].streak++;
            else state.habits[i].streak = Math.max(0, state.habits[i].streak - 1);
            saveState();
            renderDashboard();
            renderHabits();
        }

        function logWeight() {
            const val = parseFloat(document.getElementById('weightInput').value);
            if (isNaN(val) || val < 40 || val > 200) return alert('Enter valid weight (40-200 kg)');
            state.currentWeight = val;
            saveState();
            renderDashboard();
            document.getElementById('weightInput').value = '';
        }

        function addProtein() {
            const val = parseInt(document.getElementById('proteinInput').value);
            if (isNaN(val) || val < 0) return;
            state.totalProtein = (state.totalProtein || 0) + val;
            saveState();
            renderDashboard();
            renderNutrition(); // Keeps the Nutrition section synced!
            document.getElementById('proteinInput').value = '';
        }

        function advanceDay() {
            state.dayCount = Math.min(180, (state.dayCount || 1) + 1);
            state.streakDay = (state.streakDay || 1) + 1;
            // Reset daily variables
            state.habits = state.habits.map(h => ({
                ...h,
                done: false
            }));
            state.badmintonHabits = state.badmintonHabits.map(h => ({
                ...h,
                done: false
            }));
            state.totalProtein = 0;
            state.todaySteps = 0;
            saveState();

            renderDashboard();
            renderGym(); // Re-render gym so steps clear out
            alert(`Day ${state.dayCount} marked complete! 🔥 Streak: ${state.streakDay} days`);
        }

        function saveBars() {
            const bars = document.getElementById('todayBars').value.trim();
            if (!bars) return;
            state.savedLyrics = state.savedLyrics || [];
            state.savedLyrics.unshift({
                text: bars,
                date: new Date().toLocaleDateString(),
                tech: 'Daily Practice'
            });
            if (state.savedLyrics.length > 50) state.savedLyrics = state.savedLyrics.slice(0, 50); // Memory leak fix
            saveState();
            document.getElementById('todayBars').value = '';
            renderMusic();
            alert('Bars saved! 🎵 Keep going.');
        }

        // ===================== GYM =====================
        function renderGym() {
            const split = [{
                    day: 'Day 1',
                    focus: 'Chest + Triceps',
                    exercises: 'Bench Press, Push-ups, Dips, Overhead Press'
                },
                {
                    day: 'Day 2',
                    focus: 'Back + Biceps',
                    exercises: 'Pull-ups, Rows, Deadlift, Curls'
                },
                {
                    day: 'Day 3',
                    focus: 'Legs',
                    exercises: 'Squats, Lunges, Leg Press, Calf Raises'
                },
                {
                    day: 'Day 4',
                    focus: 'Shoulders + Core',
                    exercises: 'OHP, Lateral Raises, Plank, Leg Raises'
                },
                {
                    day: 'Day 5',
                    focus: 'Full Body + HIIT',
                    exercises: 'Compound lifts + Cardio intervals'
                },
                {
                    day: 'Day 6',
                    focus: 'Cardio + Abs',
                    exercises: '30min walk/run + Ab circuit + Badminton'
                },
            ];
            document.getElementById('gymSplit').innerHTML = split.map(s => `
    <div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);">
      <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--green);background:var(--green-glow);border:1px solid var(--green-dim);padding:2px 8px;border-radius:4px;white-space:nowrap;">${s.day}</div>
      <div style="flex:1;">
        <div style="font-size:13px;font-weight:600;color:var(--text);">${s.focus}</div>
        <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">${s.exercises}</div>
      </div>
    </div>
  `).join('');

            const timeline = [{
                    day: 'Day 0',
                    weight: '100kg',
                    result: 'Start today'
                },
                {
                    day: 'Day 60',
                    weight: '88–92kg',
                    result: 'Noticeable change'
                },
                {
                    day: 'Day 120',
                    weight: '80–85kg',
                    result: '🔥 Athletic look'
                },
                {
                    day: 'Day 180',
                    weight: '72–78kg',
                    result: '⚡ Abs + sharp face'
                },
            ];
            document.getElementById('transformTimeline').innerHTML = timeline.map((t, i) => `
    <div style="display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:${i<3 ? '1px solid var(--border)' : 'none'};">
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text-muted);width:55px;">${t.day}</div>
      <div style="flex:1;">
        <div style="font-size:13px;font-weight:600;">${t.weight}</div>
        <div style="font-size:11px;color:var(--text-muted);">${t.result}</div>
      </div>
    </div>
  `).join('');

            // Persisting Badminton Habits in the Gym
            const badHabitsContainer = document.getElementById('badmintonHabitsContainer');
            if (badHabitsContainer) {
                badHabitsContainer.innerHTML = state.badmintonHabits.map((h, i) => `
      <div class="habit-row ${h.done ? 'done' : ''}" onclick="toggleBadmintonHabit(${i})">
        <div class="habit-toggle">${h.done ? '✓' : ''}</div>
        <div class="habit-name">${h.name}</div>
        <div class="habit-streak ${h.streak > 0 ? 'hot' : ''}">🔥${h.streak}</div>
      </div>
    `).join('');
            }

            // Proper Step Tracking from State
            const stepPct = Math.min(100, ((state.todaySteps || 0) / 10000) * 100);
            const stepsCountEl = document.getElementById('stepsCount');
            if (stepsCountEl) stepsCountEl.textContent = (state.todaySteps || 0).toLocaleString() + ' / 10,000';
            const stepsBarEl = document.getElementById('stepsBar');
            if (stepsBarEl) stepsBarEl.style.width = stepPct + '%';
        }

        function logSteps() {
            const v = parseInt(document.getElementById('stepsInput').value);
            if (isNaN(v)) return;
            state.todaySteps = v;
            saveState();
            renderGym();
            document.getElementById('stepsInput').value = '';
        }

        function toggleBadmintonHabit(i) {
            state.badmintonHabits[i].done = !state.badmintonHabits[i].done;
            if (state.badmintonHabits[i].done) state.badmintonHabits[i].streak++;
            else state.badmintonHabits[i].streak = Math.max(0, state.badmintonHabits[i].streak - 1);
            saveState();
            renderGym();
        }

        // ===================== HABITS =====================
        function renderHabits() {
            const el = document.getElementById('allHabits');
            if (!el) return;
            el.innerHTML = state.habits.map((h, i) => `
    <div class="habit-row ${h.done ? 'done' : ''}" onclick="toggleHabit(${i})">
      <div class="habit-toggle">${h.done ? '✓' : ''}</div>
      <div class="habit-name">${h.icon} ${h.name}</div>
      <div class="habit-streak ${h.streak >= 7 ? 'hot' : ''}">🔥${h.streak} days</div>
    </div>
  `).join('');

            const dots = document.getElementById('activityDots');
            if (dots) {
                dots.innerHTML = Array.from({
                    length: 30
                }, (_, i) => {
                    const cls = i < state.dayCount ? (i % 3 === 0 ? 'partial' : 'done') : '';
                    return `<div class="dot ${cls}" title="Day ${i+1}"></div>`;
                }).join('');
            }
        }

        // ===================== SLEEP =====================
        function logSleep() {
            const bed = document.getElementById('bedtime').value;
            const wake = document.getElementById('waketime').value;
            const qual = document.getElementById('sleepQuality').value;
            if (!bed || !wake) return alert('Enter bedtime and wake time');

            const [bh, bm] = bed.split(':').map(Number);
            const [wh, wm] = wake.split(':').map(Number);
            let hours = (wh + wm / 60) - (bh + bm / 60);
            if (hours < 0) hours += 24;

            state.sleepLog = state.sleepLog || [];
            state.sleepLog.push({
                hours: parseFloat(hours.toFixed(1)),
                quality: qual,
                date: new Date().toLocaleDateString()
            });
            if (state.sleepLog.length > 50) state.sleepLog = state.sleepLog.slice(-50); // limit to 50
            saveState();
            renderSleep();
            renderDashboard(); // Re-sync mini chart
            alert(`Sleep logged: ${hours.toFixed(1)} hours`);
        }

        function renderSleep() {
            const last7 = state.sleepLog.slice(-7);
            const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            const chart = document.getElementById('sleepChart');
            const labels = document.getElementById('sleepChartLabels');
            if (!chart) return;

            if (last7.length === 0) {
                chart.innerHTML = '<div style="font-size:11px;color:var(--text-muted)">No sleep data yet. Log your first sleep above.</div>';
                return;
            }

            const maxH = 10;
            chart.style.height = '100px';
            chart.innerHTML = last7.map(s => {
                const h = s.hours;
                const cls = h >= 7 ? 'good' : h >= 5 ? 'ok' : 'bad';
                const pct = Math.min(100, (h / maxH) * 100);
                return `<div class="sleep-bar ${cls}" style="height:${pct}%;position:relative;" title="${h}h ${s.quality}">
      <span style="position:absolute;top:-16px;left:50%;transform:translateX(-50%);font-size:9px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;">${h}</span>
    </div>`;
            }).join('');

            if (labels) labels.innerHTML = last7.map((s, i) => `<div class="sleep-label">${s.date || days[i % 7]}</div>`).join('');

            const avg = last7.reduce((a, b) => a + b.hours, 0) / last7.length;
            const debt = last7.reduce((a, b) => a + Math.max(0, 7 - b.hours), 0);
            const streak = [...last7].reverse().findIndex(s => s.hours < 7);

            const avgEl = document.getElementById('avgSleep');
            const debtEl = document.getElementById('sleepDebt');
            const strkEl = document.getElementById('sleepStreak');
            if (avgEl) avgEl.textContent = avg.toFixed(1);
            if (debtEl) debtEl.textContent = debt.toFixed(1);
            if (strkEl) strkEl.textContent = streak === -1 ? last7.length : streak;
        }

