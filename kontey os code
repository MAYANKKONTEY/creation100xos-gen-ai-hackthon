<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KonteyOS — Your Life Operating System</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0e1010;
            --surface: #161a19;
            --surface2: #1d2422;
            --border: #2a3330;
            --green: #4eca8b;
            --green-dim: #2a7a54;
            --green-glow: rgba(78, 202, 139, 0.12);
            --gold: #f0c040;
            --blue: #5bb8f5;
            --red: #f06060;
            --text: #e8ede9;
            --text-dim: #7a8f85;
            --text-muted: #4a5e57;
            --radius: 14px;
            --radius-sm: 8px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Ambient background */
        body::before {
            content: '';
            position: fixed;
            top: -200px;
            left: -200px;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(78, 202, 139, 0.06) 0%, transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        /* SIDEBAR */
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: 64px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px 0;
            gap: 8px;
            z-index: 100;
        }

        .logo {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 13px;
            color: var(--green);
            letter-spacing: 0.1em;
            writing-mode: vertical-rl;
            text-orientation: mixed;
            transform: rotate(180deg);
            margin-bottom: 20px;
            margin-top: 10px;
        }

        .nav-icon {
            width: 42px;
            height: 42px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 18px;
            color: var(--text-muted);
            transition: all 0.2s;
            border: 1px solid transparent;
            position: relative;
        }

        .nav-icon:hover,
        .nav-icon.active {
            background: var(--green-glow);
            border-color: var(--green-dim);
            color: var(--green);
        }

        .nav-icon .tooltip {
            position: absolute;
            left: 54px;
            background: var(--surface2);
            border: 1px solid var(--border);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11px;
            font-family: 'DM Sans', sans-serif;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s;
            color: var(--text);
        }

        .nav-icon:hover .tooltip {
            opacity: 1;
        }

        /* MAIN */
        .main {
            margin-left: 64px;
            padding: 28px;
            min-height: 100vh;
            position: relative;
            z-index: 1;
        }

        /* TOP BAR */
        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
        }

        .topbar-left h1 {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
        }

        .topbar-left p {
            font-size: 13px;
            color: var(--text-dim);
            margin-top: 2px;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .date-chip {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 12px;
            font-family: 'JetBrains Mono', monospace;
            color: var(--green);
        }

        .streak-badge {
            background: linear-gradient(135deg, #f0c040, #f08040);
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 12px;
            font-weight: 600;
            color: #1a1200;
        }

        /* GRID */
        .grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 16px;
        }

        .col-4 {
            grid-column: span 4;
        }

        .col-3 {
            grid-column: span 3;
        }

        .col-6 {
            grid-column: span 6;
        }

        .col-8 {
            grid-column: span 8;
        }

        .col-12 {
            grid-column: span 12;
        }

        /* CARD */
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            position: relative;
            overflow: hidden;
            transition: border-color 0.2s;
        }

        .card:hover {
            border-color: var(--green-dim);
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--green-dim), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .card:hover::before {
            opacity: 1;
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .card-title {
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .card-title .icon {
            font-size: 14px;
        }

        /* STATS ROW */
        .stat-big {
            font-family: 'Syne', sans-serif;
            font-size: 42px;
            font-weight: 800;
            color: var(--green);
            line-height: 1;
        }

        .stat-label {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 4px;
        }

        /* PROGRESS BAR */
        .progress-wrap {
            margin-bottom: 12px;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: var(--text-dim);
            margin-bottom: 6px;
        }

        .progress-bar {
            height: 6px;
            background: var(--surface2);
            border-radius: 3px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .fill-green {
            background: linear-gradient(90deg, var(--green-dim), var(--green));
        }

        .fill-gold {
            background: linear-gradient(90deg, #c09000, var(--gold));
        }

        .fill-blue {
            background: linear-gradient(90deg, #3080c0, var(--blue));
        }

        .fill-red {
            background: linear-gradient(90deg, #c02020, var(--red));
        }

        /* HABIT GRID */
        .habit-grid {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .habit-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            background: var(--surface2);
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.2s;
        }

        .habit-row:hover {
            border-color: var(--green-dim);
        }

        .habit-toggle {
            width: 22px;
            height: 22px;
            border-radius: 50%;
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .habit-row.done .habit-toggle {
            background: var(--green);
            border-color: var(--green);
            color: #0e1010;
        }

        .habit-name {
            font-size: 13px;
            font-weight: 500;
            flex: 1;
        }

        .habit-streak {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px;
            color: var(--text-muted);
        }

        .habit-streak.hot {
            color: var(--gold);
        }

        /* DOTS CALENDAR */
        .dots-row {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 2px;
            background: var(--surface2);
            border: 1px solid var(--border);
        }

        .dot.done {
            background: var(--green);
            border-color: var(--green);
        }

        .dot.partial {
            background: var(--green-dim);
            border-color: var(--green-dim);
        }

        /* JOURNAL */
        .journal-entry {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 14px;
            margin-bottom: 10px;
        }

        .journal-meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .journal-text {
            font-size: 13px;
            line-height: 1.6;
            color: var(--text-dim);
        }

        .journal-input {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 12px 14px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            color: var(--text);
            resize: none;
            outline: none;
            transition: border-color 0.2s;
            min-height: 80px;
        }

        .journal-input:focus {
            border-color: var(--green-dim);
        }

        .journal-input::placeholder {
            color: var(--text-muted);
        }

        /* SLEEP */
        .sleep-visual {
            display: flex;
            align-items: flex-end;
            gap: 4px;
            height: 60px;
            margin-top: 8px;
        }

        .sleep-bar {
            flex: 1;
            border-radius: 3px 3px 0 0;
            background: var(--surface2);
            min-height: 6px;
            transition: height 0.8s;
            position: relative;
        }

        .sleep-bar.good {
            background: linear-gradient(180deg, var(--green), var(--green-dim));
        }

        .sleep-bar.ok {
            background: linear-gradient(180deg, var(--gold), #a08020);
        }

        .sleep-bar.bad {
            background: linear-gradient(180deg, var(--red), #902020);
        }

        .sleep-labels {
            display: flex;
            gap: 4px;
            margin-top: 6px;
        }

        .sleep-label {
            flex: 1;
            font-size: 9px;
            color: var(--text-muted);
            text-align: center;
            font-family: 'JetBrains Mono', monospace;
        }

        /* GOALS */
        .goal-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }

        .goal-item:last-child {
            border-bottom: none;
        }

        .goal-phase {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: var(--green);
            background: var(--green-glow);
            border: 1px solid var(--green-dim);
            padding: 2px 6px;
            border-radius: 4px;
            white-space: nowrap;
        }

        .goal-text {
            font-size: 13px;
            flex: 1;
            color: var(--text-dim);
        }

        .goal-pct {
            font-family: 'Syne', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
        }

        /* MACRO */
        .macro-row {
            display: flex;
            gap: 8px;
            margin-top: 12px;
        }

        .macro-chip {
            flex: 1;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 10px;
            text-align: center;
        }

        .macro-val {
            font-family: 'Syne', sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--text);
        }

        .macro-name {
            font-size: 10px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* MUSIC CARD */
        .lyric-line {
            font-family: 'DM Sans', sans-serif;
            font-style: italic;
            font-size: 14px;
            color: var(--text-dim);
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            line-height: 1.5;
        }

        .lyric-line:last-child {
            border-bottom: none;
        }

        .tag {
            display: inline-block;
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 20px;
            margin: 3px 2px;
        }

        .tag-green {
            background: var(--green-glow);
            color: var(--green);
            border: 1px solid var(--green-dim);
        }

        .tag-gold {
            background: rgba(240, 192, 64, 0.1);
            color: var(--gold);
            border: 1px solid rgba(240, 192, 64, 0.3);
        }

        .tag-blue {
            background: rgba(91, 184, 245, 0.1);
            color: var(--blue);
            border: 1px solid rgba(91, 184, 245, 0.3);
        }

        /* PERSONALITY */
        .persona-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .persona-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            border: 1.5px solid var(--border);
            flex-shrink: 0;
        }

        .persona-info {
            flex: 1;
        }

        .persona-name {
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
        }

        .persona-trait {
            font-size: 11px;
            color: var(--text-muted);
        }

        .persona-score {
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: var(--green);
        }

        /* TIMER */
        .timer-display {
            font-family: 'JetBrains Mono', monospace;
            font-size: 48px;
            font-weight: 500;
            color: var(--green);
            text-align: center;
            letter-spacing: 0.05em;
            margin: 16px 0;
            text-shadow: 0 0 30px rgba(78, 202, 139, 0.3);
        }

        .btn {
            background: transparent;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 8px 16px;
            font-family: 'DM Sans', sans-serif;
            font-size: 12px;
            font-weight: 500;
            color: var(--text-dim);
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn:hover {
            border-color: var(--green-dim);
            color: var(--green);
        }

        .btn-primary {
            background: var(--green);
            border-color: var(--green);
            color: #0e1010;
            font-weight: 600;
        }

        .btn-primary:hover {
            background: #5ad99a;
            color: #0e1010;
            border-color: #5ad99a;
        }

        .btn-row {
            display: flex;
            gap: 8px;
            justify-content: center;
        }

        /* SECTION DIVIDER */
        .section-label {
            font-family: 'Syne', sans-serif;
            font-size: 11px;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.14em;
            margin: 24px 0 12px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        /* MINI SCORE */
        .score-ring {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            border: 3px solid var(--surface2);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            flex-shrink: 0;
        }

        .score-num {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 800;
            color: var(--green);
        }

        /* SCROLLBAR */
        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 2px;
        }

        /* ANIMATIONS */
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card {
            animation: fadeUp 0.5s ease both;
        }

        .card:nth-child(1) {
            animation-delay: 0.05s;
        }

        .card:nth-child(2) {
            animation-delay: 0.1s;
        }

        .card:nth-child(3) {
            animation-delay: 0.15s;
        }

        .card:nth-child(4) {
            animation-delay: 0.2s;
        }

        .card:nth-child(5) {
            animation-delay: 0.25s;
        }

        .card:nth-child(6) {
            animation-delay: 0.3s;
        }

        /* INPUT INLINE */
        input[type="number"],
        input[type="time"],
        select {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 6px 10px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            color: var(--text);
            outline: none;
            width: 100%;
            transition: border-color 0.2s;
        }

        input[type="number"]:focus,
        input[type="time"]:focus,
        select:focus {
            border-color: var(--green-dim);
        }

        .input-group {
            display: flex;
            gap: 8px;
            align-items: center;
            margin-bottom: 8px;
        }

        .input-group label {
            font-size: 12px;
            color: var(--text-muted);
            width: 90px;
            flex-shrink: 0;
        }

        /* PHASE BANNER */
        .phase-banner {
            background: linear-gradient(135deg, rgba(78, 202, 139, 0.1), rgba(78, 202, 139, 0.03));
            border: 1px solid var(--green-dim);
            border-radius: var(--radius-sm);
            padding: 12px 14px;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .phase-num {
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 800;
            color: var(--green);
            line-height: 1;
        }

        .phase-info p {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 2px;
        }

        .phase-info strong {
            font-size: 13px;
            color: var(--text);
        }

        /* RESPONSIVE */
        @media (max-width: 1100px) {

            .col-4,
            .col-3 {
                grid-column: span 6;
            }

            .col-8 {
                grid-column: span 12;
            }
        }

        @media (max-width: 720px) {
            .main {
                padding: 16px;
            }

            .col-4,
            .col-3,
            .col-6 {
                grid-column: span 12;
            }
        }
    </style>
</head>

<body>

    <nav class="sidebar">
        <div class="logo">KONTEY</div>
        <div class="nav-icon active" onclick="showSection('dashboard')">🏠<span class="tooltip">Dashboard</span></div>
        <div class="nav-icon" onclick="showSection('gym')">🏋️<span class="tooltip">Gym & Body</span></div>
        <div class="nav-icon" onclick="showSection('habits')">✅<span class="tooltip">Habits</span></div>
        <div class="nav-icon" onclick="showSection('sleep')">🌙<span class="tooltip">Sleep</span></div>
        <div class="nav-icon" onclick="showSection('journal')">📓<span class="tooltip">Journal</span></div>
        <div class="nav-icon" onclick="showSection('eat')">🥗<span class="tooltip">Nutrition</span></div>
        <div class="nav-icon" onclick="showSection('music')">🎤<span class="tooltip">Hip-Hop & Music</span></div>
        <div class="nav-icon" onclick="showSection('persona')">🧠<span class="tooltip">Personality OS</span></div>
        <div class="nav-icon" onclick="showSection('badminton')">🏸<span class="tooltip">Badminton</span></div>
        <div class="nav-icon" onclick="showSection('writing')">✍️<span class="tooltip">Daily Writing</span></div>
        <div style="flex:1"></div>
        <div class="nav-icon" onclick="alert('Settings coming soon')">⚙️<span class="tooltip">Settings</span></div>
    </nav>

    <main class="main" id="main">

        <div id="section-dashboard">
            <div class="topbar">
                <div class="topbar-left">
                    <h1>Good morning, Mayank ⚡</h1>
                    <p id="dateStr">Loading date...</p>
                </div>
                <div class="topbar-right">
                    <div class="date-chip" id="clockStr">00:00</div>
                    <div class="streak-badge">🔥 Day <span id="streakDay">1</span></div>
                </div>
            </div>

            <div class="grid">
                <div class="card col-4">
                    <div class="card-header">
                        <div class="card-title"><span class="icon">🎯</span> Today's Score</div>
                    </div>
                    <div style="display:flex;align-items:center;gap:16px;">
                        <div class="score-ring" id="scoreRing">
                            <span class="score-num" id="scoreNum">0</span>
                        </div>
                        <div>
                            <div style="font-size:12px;color:var(--text-muted)">out of 10</div>
                            <div style="font-size:12px;color:var(--text-dim);margin-top:4px" id="scoreTip">Complete habits to score</div>
                        </div>
                    </div>
                    <div style="margin-top:14px;">
                        <div class="progress-wrap">
                            <div class="progress-label"><span>Habits done</span><span id="habitsDone">0/8</span></div>
                            <div class="progress-bar">
                                <div class="progress-fill fill-green" id="habitsBar" style="width:0%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card col-4">
                    <div class="card-header">
                        <div class="card-title"><span class="icon">⚖️</span> Weight Journey</div>
                        <span class="tag tag-blue">100→70kg</span>
                    </div>
                    <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:12px;">
