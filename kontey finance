            },
            Health: {
                e: '💪',
                c: '#00D68F',
                bg: 'rgba(0,214,143,0.12)'
            },
            Education: {
                e: '📚',
                c: '#FFB030',
                bg: 'rgba(255,176,48,0.12)'
            },
            Subscriptions: {
                e: '📱',
                c: '#FF4466',
                bg: 'rgba(255,68,102,0.12)'
            },
            Living: {
                e: '🏠',
                c: '#00C8E0',
                bg: 'rgba(0,200,224,0.12)'
            },
            Business: {
                e: '💼',
                c: '#8888A8',
                bg: 'rgba(136,136,168,0.12)'
            },
            Others: {
                e: '🧾',
                c: '#5A5A78',
                bg: 'rgba(90,90,120,0.12)'
            },
        };
        const ISRC = {
            'Pocket Money (Dad)': '👨',
            'Pocket Money (Mom)': '👩',
            Salary: '💼',
            Freelance: '🧑‍💻',
            Business: '🏢',
            Gift: '🎁',
            Investment: '📈',
            Other: '📦',
        };
        const ISRC_COLORS = ['#FF6B35', '#4D8EFF', '#00D68F', '#FFB030', '#A070FF', '#FF4466', '#00C8E0', '#8888A8'];

        // ═══════════════════════════════════════════════════════
        // STATE
        // ═══════════════════════════════════════════════════════
        let txns = JSON.parse(localStorage.getItem('kontey_v4') || '[]');
        let budgets = JSON.parse(localStorage.getItem('kontey_budgets') || '{}');
        let goals = JSON.parse(localStorage.getItem('kontey_goals') || '[]');
        let selCat = localStorage.getItem('kontey_last_cat') || 'Food';
        let selPay = localStorage.getItem('kontey_last_pay') || 'UPI';
        let filt = 'month';
        let activeTab = 'expense';
        let activePage = 'dashboard';
        let editBudgetCat = null;
        let editGoalId = null;
        let selectedGoalEmoji = '🎯';
        let selectedGoalColor = '#FF6B35';
        let streak = 0;

        // Chart refs
        let bChart, dChart, lChart, iChart, rChart, payChart, ocChart;

        // ═══════════════════════════════════════════════════════
        // INIT
        // ═══════════════════════════════════════════════════════
        function init() {
            const tod = new Date().toISOString().split('T')[0];
            document.getElementById('e-date').value = tod;
            document.getElementById('i-date').value = tod;

            // Set deadline default to 3 months from now
            const d3 = new Date();
            d3.setMonth(d3.getMonth() + 3);
            document.getElementById('gm-deadline').value = d3.toISOString().slice(0, 7);

            // Greeting
            const h = new Date().getHours();
            const greet = h < 12 ? 'Good Morning' : h < 17 ? 'Good Afternoon' : 'Good Evening';
            document.getElementById('dash-greeting').textContent = greet + ' 👋';
            document.getElementById('dash-date').textContent = new Date().toLocaleDateString('en-IN', {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });

            // Set last-used cat/pay
            setLastCat();

            // Streak
            streak = updateStreak();
            document.getElementById('sb-streak').textContent = streak;
            document.getElementById('sb-streak-sub').textContent = streak > 1 ? `${streak} days in a row!` : 'Start tracking daily!';

            initCharts();
            renderAll();
        }

        function updateStreak() {
            const today = new Date().toISOString().split('T')[0];
            const data = JSON.parse(localStorage.getItem('kontey_streak_data') || '{"count":0,"last":""}');
            if (data.last === today) return data.count;
            const yd = new Date();
            yd.setDate(yd.getDate() - 1);
            const yStr = yd.toISOString().split('T')[0];
            const newCount = data.last === yStr ? data.count + 1 : 1;
            localStorage.setItem('kontey_streak_data', JSON.stringify({
                count: newCount,
                last: today
            }));
            return newCount;
        }

        function setLastCat() {
            document.querySelectorAll('.cp').forEach(el => {
                el.classList.toggle('active', el.dataset.cat === selCat);
            });
            document.querySelectorAll('.pm').forEach(el => {
                el.classList.toggle('active', el.dataset.pay === selPay);
            });
        }

        function uid() {
            return Math.random().toString(36).slice(2, 10) + Date.now().toString(36);
        }

        function save() {
            localStorage.setItem('kontey_v4', JSON.stringify(txns));
            localStorage.setItem('kontey_budgets', JSON.stringify(budgets));
            localStorage.setItem('kontey_goals', JSON.stringify(goals));
            localStorage.setItem('kontey_last_cat', selCat);
            localStorage.setItem('kontey_last_pay', selPay);
        }

        // ═══════════════════════════════════════════════════════
        // FORMAT
        // ═══════════════════════════════════════════════════════
        function fm(n) {
            const a = Math.abs(n),
                neg = n < 0;
            let s = a >= 1e5 ? '₹' + (a / 1e5).toFixed(1) + 'L' : a >= 1000 ? '₹' + (a / 1000).toFixed(1) + 'k' : '₹' + Math.round(a);
            return neg ? '-' + s.slice(1) : s;
        }

        function ff(n) {
            return '₹' + Math.round(Math.abs(n)).toLocaleString('en-IN');
        }

        function fdate(d) {
            const today = new Date().toISOString().split('T')[0];
            const yd = new Date();
            yd.setDate(yd.getDate() - 1);
            if (d === today) return 'Today';
            if (d === yd.toISOString().split('T')[0]) return 'Yesterday';
            return new Date(d).toLocaleDateString('en-IN', {
                weekday: 'short',
                month: 'short',
                day: 'numeric'
            });
        }

        // ═══════════════════════════════════════════════════════
        // FILTER
        // ═══════════════════════════════════════════════════════
        function getF(f = filt) {
            const now = new Date(),
                tod = now.toISOString().split('T')[0];
            return txns.filter(t => {
                if (f === 'all') return true;
                const d = new Date(t.date);
                if (f === 'today') return t.date === tod;
                if (f === 'week') {
                    const w = new Date(now);
                    w.setDate(w.getDate() - 7);
                    return d >= w;
                }
                if (f === 'month') return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
                return true;
            });
        }

        function getWeekTotal(daysBack, daysSpan = 7) {
            const end = new Date();
            end.setDate(end.getDate() - daysBack);
            const start = new Date(end);
            start.setDate(start.getDate() - daysSpan);
            return txns.filter(t => t.type === 'expense').reduce((sum, t) => {
                const d = new Date(t.date);
                return d >= start && d <= end ? sum + t.amount : sum;
            }, 0);
        }

        // ═══════════════════════════════════════════════════════
        // SMART INSIGHTS ENGINE
        // ═══════════════════════════════════════════════════════
        function generateInsights(ft, inc, exp) {
            const insights = [];
            const now = new Date();
            const allExp = txns.filter(t => t.type === 'expense');

            // 1. Week-over-week
            const thisWeek = getWeekTotal(0);
            const lastWeek = getWeekTotal(7);
            if (lastWeek > 0 && thisWeek > 0) {
                const chg = ((thisWeek - lastWeek) / lastWeek * 100).toFixed(0);
                insights.push({
                    type: chg > 15 ? 'alert' : chg > 0 ? 'warn' : 'good',
                    ico: chg > 0 ? '📈' : '📉',
                    bg: chg > 0 ? 'var(--red-dim)' : 'var(--green-dim)',
                    title: `Spending ${chg > 0 ? 'up' : 'down'} ${Math.abs(chg)}% vs last week`,
                    text: `This week: ${ff(thisWeek)} — Last week: ${ff(lastWeek)}`,
                });
            }

            // 2. Top category this period
            const cm = {};
            ft.filter(t => t.type === 'expense').forEach(t => {
                cm[t.category] = (cm[t.category] || 0) + t.amount;
            });
            const top = Object.entries(cm).sort((a, b) => b[1] - a[1])[0];
            if (top && exp > 0) {
                const pct = ((top[1] / exp) * 100).toFixed(0);
                insights.push({
                    type: 'info',
                    ico: CATS[top[0]]?.e || '📊',
                    bg: CATS[top[0]]?.bg || 'var(--blue-dim)',
                    title: `${top[0]} is your biggest expense`,
                    text: `${ff(top[1])} · ${pct}% of spending this period`,
                });
            }

            // 3. Savings rate alert
            if (inc > 0) {
                const rate = ((inc - exp) / inc * 100).toFixed(0);
                insights.push({
                    type: rate >= 20 ? 'good' : rate >= 0 ? 'warn' : 'alert',
                    ico: rate >= 20 ? '🏆' : rate >= 0 ? '💡' : '⚠️',
                    bg: rate >= 20 ? 'var(--green-dim)' : rate >= 0 ? 'var(--gold-dim)' : 'var(--red-dim)',
                    title: rate >= 20 ? `Excellent! Saving ${rate}%` : rate >= 0 ? `Saving ${rate}% — aim for 20%` : `Spending more than earning!`,
                    text: rate >= 20 ? 'You are building great financial habits.' : rate >= 0 ? `Save ${ff(inc * 0.2 - (inc-exp))} more to hit 20% goal.` : `You're over budget by ${ff(exp - inc)} this period.`,
                });
            }

            // 4. Budget overages
            const overCats = Object.entries(budgets).filter(([cat, lim]) => {
                if (!lim) return false;
                const spent = txns.filter(t => t.type === 'expense' && t.category === cat &&
                    new Date(t.date).getMonth() === now.getMonth() && new Date(t.date).getFullYear() === now.getFullYear()
                ).reduce((a, b) => a + b.amount, 0);
                return spent > lim;
            });
            if (overCats.length > 0) {
                insights.push({
                    type: 'alert',
                    ico: '🚨',
                    bg: 'var(--red-dim)',
                    title: `${overCats.length} budget${overCats.length>1?'s':''} exceeded!`,
                    text: overCats.map(([cat]) => cat).join(', ') + ' — review your spending.',
                });
            }

            // 5. Unusual expense detection
            const catAvg = {};
            allExp.forEach(t => {
                if (!catAvg[t.category]) catAvg[t.category] = {
                    sum: 0,
                    n: 0
                };
                catAvg[t.category].sum += t.amount;
                catAvg[t.category].n++;
            });
            const recent7days = new Date();
            recent7days.setDate(recent7days.getDate() - 7);
            const unusual = allExp.filter(t => {
                const avg = catAvg[t.category] ? catAvg[t.category].sum / catAvg[t.category].n : 0;
                return avg > 0 && t.amount > avg * 2.5 && t.amount > 500 && new Date(t.date) >= recent7days;
            }).sort((a, b) => b.amount - a.amount)[0];
            if (unusual) {
                insights.push({
                    type: 'warn',
                    ico: '👀',
                    bg: 'var(--gold-dim)',
                    title: `Unusual expense in ${unusual.category}`,
                    text: `${ff(unusual.amount)} — ${unusual.note || unusual.category} on ${fdate(unusual.date)}`,
                });
            }

            // 6. Daily average
            const days = filt === 'today' ? 1 : filt === 'week' ? 7 : filt === 'month' ? 30 : 30;
            if (exp > 0 && days > 1) {
                const daily = exp / days;
                insights.push({
                    type: 'info',
                    ico: '📅',
                    bg: 'var(--blue-dim)',
                    title: `Daily average: ${ff(daily)}`,
                    text: `Based on ${filt === 'all' ? 'all time' : 'this ' + filt} spending of ${ff(exp)}`,
                });
            }

            return insights.slice(0, 3);
        }

        // ═══════════════════════════════════════════════════════
        // RENDER ALL
        // ═══════════════════════════════════════════════════════
        function renderAll() {
            const ft = getF();
            const all = txns;
            const allInc = all.filter(t => t.type === 'income').reduce((a, b) => a + b.amount, 0);
            const allExp = all.filter(t => t.type === 'expense').reduce((a, b) => a + b.amount, 0);
            const net = allInc - allExp;
            const inc = ft.filter(t => t.type === 'income').reduce((a, b) => a + b.amount, 0);
            const exp = ft.filter(t => t.type === 'expense').reduce((a, b) => a + b.amount, 0);
            const sav = inc - exp;
            const now = new Date();
            const mTxns = txns.filter(t => {
                const d = new Date(t.date);
                return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
            });
            const mInc = mTxns.filter(t => t.type === 'income').reduce((a, b) => a + b.amount, 0);
            const mExp = mTxns.filter(t => t.type === 'expense').reduce((a, b) => a + b.amount, 0);

            // Balance Hero
            const bal = document.getElementById('bh-amount');
            bal.textContent = fm(net);
            bal.className = 'bh-amount' + (net < 0 ? ' negative' : '');
            document.getElementById('bh-subtitle').textContent = allInc > 0 ?
                `${ff(allInc)} earned · ${ff(allExp)} spent all time` :
                'Add your first income or expense to start';
            document.getElementById('bh-month').textContent = fm(mInc - mExp);
            document.getElementById('bhs-inc').textContent = fm(allInc);
            document.getElementById('bhs-exp').textContent = fm(allExp);
            document.getElementById('bhs-sav').textContent = fm(net);
            document.getElementById('bhs-rate').textContent = allInc > 0 ? ((net / allInc) * 100).toFixed(0) + '%' : '0%';

            // Sidebar
            document.getElementById('sb-val').textContent = fm(net);
            document.getElementById('sb-sub').textContent = txns.length === 0 ? 'Start adding transactions' : net >= 0 ? 'You\'re in profit ↑' : 'Review spending ↓';

            // Week compare
            const thisW = getWeekTotal(0),
                lastW = getWeekTotal(7);
            const wcEl = document.getElementById('week-compare');
            if (thisW > 0 || lastW > 0) {
                const chg = lastW > 0 ? ((thisW - lastW) / lastW * 100).toFixed(0) : 100;
                const isUp = thisW >= lastW;
                wcEl.innerHTML = `
      <div><div class="wc-title">This Week</div><div class="wc-val" style="color:var(--red)">${ff(thisW)}</div></div>
      <div class="wc-divider"></div>
      <div class="wc-change">
        <span class="wc-arrow">${isUp ? '⬆️' : '⬇️'}</span>
        <div><div class="wc-pct" style="color:${isUp?'var(--red)':'var(--green)'}">${Math.abs(chg)}%</div><div class="wc-change-label">vs last week</div></div>
      </div>
      <div class="wc-divider"></div>
      <div style="text-align:right"><div class="wc-title">Last Week</div><div class="wc-val" style="color:var(--text2)">${ff(lastW)}</div></div>`;
                wcEl.style.display = 'flex';
            } else {
                wcEl.style.display = 'none';
            }

            // Stat cards
            const pL = {
                today: 'Today',
                week: 'This Week',
                month: 'This Month',
                all: 'All Time'
            } [filt];
            document.getElementById('sc1').textContent = fm(inc);
            document.getElementById('sc2').textContent = fm(exp);
            document.getElementById('sc3').textContent = fm(sav);
            document.getElementById('sc3').style.color = sav < 0 ? 'var(--red)' : '';
            document.getElementById('sc4').textContent = ft.length;
            document.getElementById('sc1b').textContent = ft.filter(t => t.type === 'income').length + ' entries';
            document.getElementById('sc2b').textContent = inc > 0 ? ((exp / inc) * 100).toFixed(0) + '% of income' : '—';
            document.getElementById('sc3b').textContent = inc > 0 ? ((Math.max(sav, 0) / inc) * 100).toFixed(0) + '% saved' : '—';
            document.getElementById('sc4b').textContent = pL;

            // Subscription banner
            const subTotal = txns.filter(t => t.type === 'expense' && t.category === 'Subscriptions' &&
                new Date(t.date).getMonth() === now.getMonth() && new Date(t.date).getFullYear() === now.getFullYear()
            ).reduce((a, b) => a + b.amount, 0);
            const subCount = txns.filter(t => t.type === 'expense' && t.category === 'Subscriptions' &&
                new Date(t.date).getMonth() === now.getMonth() && new Date(t.date).getFullYear() === now.getFullYear()
            ).length;
            const subBanner = document.getElementById('sub-banner');
            if (subTotal > 0) {
                document.getElementById('sub-banner-sub').textContent = `${subCount} subscription${subCount>1?'s':''} this month`;
                document.getElementById('sub-banner-amt').textContent = ff(subTotal) + '/mo';
                subBanner.style.display = 'flex';
            } else {
                subBanner.style.display = 'none';
            }

            // Smart insights
            const insights = generateInsights(ft, inc, exp);
            document.getElementById('ins-grid').innerHTML = insights.length > 0 ?
                insights.map(x => `<div class="ins-card ${x.type}"><div class="ins-ico" style="background:${x.bg}">${x.ico}</div><div><div class="ins-title">${x.title}</div><div class="ins-text">${x.text}</div></div></div>`).join('') :
                `<div class="ins-card info" style="grid-column:1/-1"><div class="ins-ico" style="background:var(--blue-dim)">🚀</div><div><div class="ins-title">Add transactions to unlock insights</div><div class="ins-text">Your AI-powered financial patterns will appear here once you track income and expenses.</div></div></div>`;

            // Payment breakdown
            renderPayBreakdown();

            // Recent txns
            renderDashTxns(ft);

            // Update charts
            updateCharts();

            // Re-render pages if visible
            if (activePage === 'transactions') renderHist();
            if (activePage === 'categories') renderCats();
            if (activePage === 'analytics') renderIncSources();
            if (activePage === 'budget') renderBudgetPage();
            if (activePage === 'goals') renderGoalsPage();

            document.getElementById('c-pill').textContent = pL;
        }

        // ═══════════════════════════════════════════════════════
        // PAYMENT BREAKDOWN
        // ═══════════════════════════════════════════════════════
        function renderPayBreakdown() {
            const exps = txns.filter(t => t.type === 'expense');
            const total = exps.reduce((a, b) => a + b.amount, 0);
            const pm = {
                UPI: {
                    a: 0,
                    n: 0
                },
                Cash: {
                    a: 0,
                    n: 0
                },
                Card: {
                    a: 0,
                    n: 0
                }
            };
            exps.forEach(t => {
                const p = t.payment || 'UPI';
                if (pm[p]) {
                    pm[p].a += t.amount;
                    pm[p].n++;
                }
            });
            const max = Math.max(pm.UPI.a, pm.Cash.a, pm.Card.a, 1);
            [
                ['UPI', 'pupi'],
                ['Cash', 'pcash'],
                ['Card', 'pcard']
            ].forEach(([k, id]) => {
                const d = pm[k],
                    pct = total > 0 ? ((d.a / total) * 100).toFixed(0) : 0;
                document.getElementById(id).textContent = ff(d.a);
                document.getElementById(id + '-m').textContent = `${d.n} txn${d.n!==1?'s':''} · ${pct}%`;
                document.getElementById(id + '-b').style.width = (d.a / max * 100).toFixed(0) + '%';
            });
        }

        // ═══════════════════════════════════════════════════════
        // TRANSACTION CARD
        // ═══════════════════════════════════════════════════════
        function tCard(t, del = false) {
            const db = del ? `<button class="txn-del" onclick="delTxn('${t.id}')" title="Delete">🗑</button>` : '';
            if (t.type === 'income') {
                return `<div class="txn"><div class="txn-ico" style="background:var(--green-dim)">${ISRC[t.source]||'💰'}</div><div class="txn-info"><div class="txn-name">${t.source}${t.note?' · '+t.note:''}</div><div class="txn-meta"><span>Income</span><span class="dot"></span><span>${t.date}</span></div></div><div class="txn-r"><div class="txn-amt pos">+${ff(t.amount)}</div></div>${db}</div>`;
            }
            const c = CATS[t.category] || CATS.Others;
            return `<div class="txn"><div class="txn-ico" style="background:${c.bg}">${c.e}</div><div class="txn-info"><div class="txn-name">${t.note||t.category}</div><div class="txn-meta"><span>${t.category}</span><span class="dot"></span><span class="pay-chip">${t.payment||'UPI'}</span><span class="dot"></span><span>${t.date}</span></div></div><div class="txn-r"><div class="txn-amt neg">-${ff(t.amount)}</div></div>${db}</div>`;
        }

        function renderDashTxns(ft) {
            const sorted = [...ft].sort((a, b) => new Date(b.date) - new Date(a.date)).slice(0, 7);
            const el = document.getElementById('dash-txns');
            if (!sorted.length) {
                el.innerHTML = `<div class="empty"><div class="empty-ico">📭</div><div class="empty-t">Nothing here yet</div><div class="empty-s">Start by adding income (pocket money from Dad or Mom!) or your first expense.</div><button class="empty-btn" onclick="openModal()">+ Add Transaction</button></div>`;
                return;
            }
            el.innerHTML = `<div class="txn-list">${sorted.map(t => tCard(t,true)).join('')}</div>`;
        }

        function delTxn(id) {
            txns = txns.filter(t => t.id !== id);
            save();
            renderAll();
            toast('🗑 Deleted', 'ok');
        }

        // ═══════════════════════════════════════════════════════
        // HISTORY (Transactions Page)
        // ═══════════════════════════════════════════════════════
        function renderHist() {
            const type = document.getElementById('af-type').value;
            const cat = document.getElementById('af-cat').value;
            const pay = document.getElementById('af-pay').value;
            const sort = document.getElementById('af-sort').value;
            const q = (document.getElementById('af-search').value || '').toLowerCase();
            const minA = parseFloat(document.getElementById('af-min').value) || 0;
            const maxA = parseFloat(document.getElementById('af-max').value) || Infinity;
            const from = document.getElementById('af-from').value;
            const to = document.getElementById('af-to').value;

            let list = [...txns];
            if (type !== 'all') list = list.filter(t => t.type === type);
            if (cat !== 'all') list = list.filter(t => t.category === cat);
            if (pay !== 'all') list = list.filter(t => (t.payment || 'UPI') === pay);
            if (q) list = list.filter(t => [(t.note || ''), (t.category || ''), (t.source || '')].join(' ').toLowerCase().includes(q));
            if (minA > 0) list = list.filter(t => t.amount >= minA);
            if (isFinite(maxA)) list = list.filter(t => t.amount <= maxA);
            if (from) list = list.filter(t => t.date >= from);
            if (to) list = list.filter(t => t.date <= to);

            if (sort === 'newest') list.sort((a, b) => new Date(b.date) - new Date(a.date));
            else if (sort === 'oldest') list.sort((a, b) => new Date(a.date) - new Date(b.date));
            else if (sort === 'high') list.sort((a, b) => b.amount - a.amount);
            else list.sort((a, b) => a.amount - b.amount);

            const el = document.getElementById('hist-list');
            if (!list.length) {
                el.innerHTML = `<div class="empty"><div class="empty-ico">🔍</div><div class="empty-t">No results</div><div class="empty-s">Try adjusting your filters</div></div>`;
                return;
            }

            if (sort === 'high' || sort === 'low') {
                el.innerHTML = `<div class="txn-list">${list.map(t=>tCard(t,true)).join('')}</div>`;
                return;
            }
            const grp = {};
            list.forEach(t => {
                grp[t.date] = grp[t.date] || [];
                grp[t.date].push(t);
            });
            const dates = Object.keys(grp).sort((a, b) => sort === 'oldest' ? new Date(a) - new Date(b) : new Date(b) - new Date(a));
            el.innerHTML = dates.map(dt => {
                const dayTotal = grp[dt].reduce((a, t) => t.type === 'expense' ? a - t.amount : a + t.amount, 0);
                const sign = dayTotal >= 0 ? '+' : '';
                return `<div class="date-div" style="display:flex;justify-content:space-between"><span>${fdate(dt)}</span><span style="color:${dayTotal>=0?'var(--green)':'var(--red)'}">${sign}${ff(Math.abs(dayTotal))}</span></div><div class="txn-list" style="margin-bottom:6px">${grp[dt].map(t=>tCard(t,true)).join('')}</div>`;
            }).join('');
        }

        function clearFilters() {
            ['af-search', 'af-min', 'af-max', 'af-from', 'af-to'].forEach(id => document.getElementById(id).value = '');
            ['af-type', 'af-cat', 'af-pay', 'af-sort'].forEach(id => document.getElementById(id).selectedIndex = 0);
            renderHist();
        }

        // ═══════════════════════════════════════════════════════
        // CATEGORIES
        // ═══════════════════════════════════════════════════════
        function renderCats() {
            const exps = txns.filter(t => t.type === 'expense');
            const total = exps.reduce((a, b) => a + b.amount, 0);
            const cm = {};
            exps.forEach(t => {
                cm[t.category] = cm[t.category] || {
                    a: 0,
                    n: 0
                };
                cm[t.category].a += t.amount;
                cm[t.category].n++;
            });
            document.getElementById('cat-grid').innerHTML = Object.entries(CATS).map(([name, c]) => {
                const d = cm[name] || {
                        a: 0,
                        n: 0
                    },
                    pct = total > 0 ? ((d.a / total) * 100).toFixed(1) : 0;
                return `<div class="cat-card"><div class="cat-top"><div class="cat-ico">${c.e}</div><div class="cat-pct" style="background:${c.bg};color:${c.c}">${pct}%</div></div><div class="cat-name">${name}</div><div class="cat-cnt">${d.n} transaction${d.n!==1?'s':''}</div><div class="cat-amt" style="color:${c.c}">${ff(d.a)}</div><div class="cat-bar"><div class="cat-bar-fill" style="width:${pct}%;background:${c.c}"></div></div></div>`;
            }).join('');
        }

        // ═══════════════════════════════════════════════════════
        // ANALYTICS - INCOME SOURCES
        // ═══════════════════════════════════════════════════════
        function renderIncSources() {
            const incomes = txns.filter(t => t.type === 'income');
            const total = incomes.reduce((a, b) => a + b.amount, 0);
            const sm = {};
            incomes.forEach(t => {
                sm[t.source] = sm[t.source] || {
                    a: 0,
                    n: 0
                };
                sm[t.source].a += t.amount;
                sm[t.source].n++;
            });
            const sorted = Object.entries(sm).sort((a, b) => b[1].a - a[1].a);
            const el = document.getElementById('inc-src-grid');
            if (!sorted.length) {
                el.innerHTML = `<div class="src-card" style="grid-column:1/-1;text-align:center;padding:30px"><div style="font-size:36px;margin-bottom:8px">💰</div><div style="font-weight:800;font-size:15px;margin-bottom:4px">No income yet</div><div style="font-size:12px;color:var(--muted)">Add income to see source breakdown</div></div>`;
                return;
            }
            el.innerHTML = sorted.map(([src, d], i) => {
                const pct = total > 0 ? ((d.a / total) * 100).toFixed(0) : 0;
                return `<div class="src-card${i===0?' top':''}">
      ${i===0?'<div class="src-badge">👑 TOP SOURCE</div>':''}
      <div class="src-ico">${ISRC[src]||'💰'}</div>
      <div class="src-name">${src}</div>
      <div class="src-amt">${ff(d.a)}</div>
      <div class="src-pct">${d.n} txn${d.n!==1?'s':''} · ${pct}% of income</div>
      <div class="src-bar"><div class="src-bar-fill" style="width:${pct}%"></div></div>
    </div>`;
            }).join('');
        }

        // ═══════════════════════════════════════════════════════
        // BUDGET PAGE
        // ═══════════════════════════════════════════════════════
        function renderBudgetPage() {
            const now = new Date();
            let totalBudget = 0,
                totalSpent = 0;
            Object.entries(budgets).forEach(([cat, lim]) => {
                if (lim > 0) totalBudget += lim;
            });
            const expsThisMonth = txns.filter(t => t.type === 'expense' && new Date(t.date).getMonth() === now.getMonth() && new Date(t.date).getFullYear() === now.getFullYear());
            expsThisMonth.forEach(t => {
                totalSpent += t.amount;
            });

            const catSpent = {};
            expsThisMonth.forEach(t => {
                catSpent[t.category] = (catSpent[t.category] || 0) + t.amount;
            });

            const usedBudget = Object.entries(budgets).reduce((s, [cat, lim]) => s + Math.min(catSpent[cat] || 0, lim || 0), 0);
            const rem = Math.max(totalBudget - usedBudget, 0);
            const pct = totalBudget > 0 ? ((usedBudget / totalBudget) * 100).toFixed(0) : 0;

            document.getElementById('bov-total').textContent = ff(totalBudget) || '₹0';
            document.getElementById('bov-spent').textContent = ff(totalSpent);
            document.getElementById('bov-rem').textContent = ff(rem);
            document.getElementById('bov-pct').textContent = pct + '%';

            document.getElementById('budget-grid').innerHTML = Object.entries(CATS).map(([name, c]) => {
                const lim = budgets[name] || 0;
                const spent = catSpent[name] || 0;
                const p = lim > 0 ? Math.min((spent / lim) * 100, 100).toFixed(0) : 0;
                const status = p >= 100 ? 'over' : p >= 80 ? 'warn' : 'safe';
                const rem2 = Math.max(lim - spent, 0);
                return `<div class="budget-card ${p >= 100 ? 'over' : p >= 80 ? 'warn' : ''}">
      <div class="bc-top">
        <div class="bc-cat"><div class="bc-ico">${c.e}</div><div><div class="bc-name">${name}</div><div class="bc-spent">${ff(spent)} spent</div></div></div>
        <button class="bc-edit" onclick="openBudgetEdit('${name}')">${lim > 0 ? '✏️ '+ff(lim) : '+ Set'}</button>
      </div>
      ${lim > 0 ? `
        <div class="bc-bar-wrap">
          <div class="bc-bar"><div class="bc-bar-fill ${status}" style="width:${p}%"></div></div>
          <div class="bc-bar-row"><span class="bc-pct">${p}% used</span><span class="bc-rem ${status}">${p>=100?'Over '+ff(spent-lim):ff(rem2)+' left'}</span></div>
        </div>` 
      : `<div class="bc-no-budget" onclick="openBudgetEdit('${name}')">Tap to set a monthly limit →</div>`}
    </div>`;
            }).join('');
        }

        // ═══════════════════════════════════════════════════════
        // GOALS PAGE
        // ═══════════════════════════════════════════════════════
        function renderGoalsPage() {
            const totalTarget = goals.reduce((a, g) => a + g.target, 0);
            const totalSaved = goals.reduce((a, g) => a + g.saved, 0);
            const overallPct = totalTarget > 0 ? ((totalSaved / totalTarget) * 100).toFixed(0) : 0;

            document.getElementById('gs-count').textContent = goals.length;
            document.getElementById('gs-target').textContent = ff(totalTarget);
            document.getElementById('gs-saved').textContent = ff(totalSaved);
            document.getElementById('gs-pct').textContent = overallPct + '%';

            const el = document.getElementById('goals-grid');
            if (!goals.length) {
                el.innerHTML = `<div class="empty"><div class="empty-ico">⭐</div><div class="empty-t">No savings goals yet</div><div class="empty-s">Create a goal like "Emergency Fund", "New Laptop", or "Trip to Goa" and track your progress.</div><button class="empty-btn" onclick="openGoalModal()">+ Create First Goal</button></div>`;
                return;
            }
            el.innerHTML = goals.map(g => {
                const pct = g.target > 0 ? Math.min((g.saved / g.target) * 100, 100).toFixed(0) : 0;
                const done = pct >= 100;
                let daysLabel = '';
                if (g.deadline) {
                    const dl = new Date(g.deadline + '-01');
                    const diff = Math.ceil((dl - new Date()) / 864e5);
                    daysLabel = diff < 0 ? '⚠️ Overdue' : diff === 0 ? 'Due today!' : `${diff} days left`;
                }
                return `<div class="goal-card" style="border-color:${g.color}22">
      <div class="gc-top">
        <div class="gc-info">
          <div class="gc-emoji">${g.emoji}</div>
          <div><div class="gc-name">${g.name}</div>${g.deadline?`<div class="gc-deadline">📅 ${g.deadline}</div>`:''}</div>
        </div>
        <div class="gc-actions">
          ${!done?`<button class="gc-add-btn" onclick="openGoalSave('${g.id}')">+ Add</button>`:''}
          <button class="gc-del-btn" onclick="delGoal('${g.id}')">🗑</button>
        </div>
      </div>
      <div class="gc-amounts">
        <div class="gc-saved" style="color:${g.color}">${ff(g.saved)}</div>
        <div class="gc-target">of ${ff(g.target)}</div>
      </div>
      <div class="gc-bar"><div class="gc-bar-fill" style="width:${pct}%;background:linear-gradient(90deg,${g.color},${g.color}99)"></div></div>
      <div class="gc-meta">
        <span class="gc-pct" style="color:${g.color}">${pct}% complete</span>
        ${done ? '<span class="gc-done">🎉 Goal Achieved!</span>' : `<span class="gc-days">${daysLabel}</span>`}
      </div>
    </div>`;
            }).join('');
        }

