            position: fixed;
            inset: 0;
            background: rgba(7, 7, 15, 0.7);
            backdrop-filter: blur(10px);
            z-index: 300;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s;
        }

        .mini-overlay.open {
            opacity: 1;
            pointer-events: all;
        }

        .mini-modal {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: var(--r-lg);
            padding: 24px;
            width: 340px;
            max-width: 92vw;
            box-shadow: var(--shadow-lg);
            transform: scale(.95);
            transition: transform .2s cubic-bezier(.34, 1.2, .64, 1);
        }

        .mini-overlay.open .mini-modal {
            transform: scale(1);
        }

        .mm-title {
            font-size: 16px;
            font-weight: 900;
            margin-bottom: 4px;
        }

        .mm-sub {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 16px;
        }

        .mm-actions {
            display: flex;
            gap: 8px;
            margin-top: 16px;
        }

        /* ── CONFIRM DIALOG ── */
        .confirm-ov {
            position: fixed;
            inset: 0;
            background: rgba(7, 7, 15, 0.7);
            backdrop-filter: blur(10px);
            z-index: 500;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s;
        }

        .confirm-ov.open {
            opacity: 1;
            pointer-events: all;
        }

        .confirm-box {
            background: var(--surface);
            border: 1px solid var(--border2);
            border-radius: var(--r-lg);
            padding: 24px 22px;
            width: 320px;
            max-width: 92vw;
            box-shadow: var(--shadow-lg);
            transform: scale(.95);
            transition: transform .2s cubic-bezier(.34, 1.2, .64, 1);
        }

        .confirm-ov.open .confirm-box {
            transform: scale(1);
        }

        .confirm-title {
            font-size: 17px;
            font-weight: 900;
            margin-bottom: 6px;
        }

        .confirm-msg {
            font-size: 12.5px;
            color: var(--muted);
            margin-bottom: 18px;
            line-height: 1.5;
