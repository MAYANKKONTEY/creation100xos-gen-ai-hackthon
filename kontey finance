        .src-card {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 16px;
            text-align: center;
            transition: all .2s;
        }

        .src-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        .src-card.top {
            border-color: rgba(255, 176, 48, 0.3);
            background: rgba(255, 176, 48, 0.04);
        }

        .src-badge {
            font-size: 9px;
            background: var(--gold-dim);
            color: var(--gold);
            padding: 2px 7px;
            border-radius: 10px;
            font-weight: 800;
            letter-spacing: .5px;
            display: inline-block;
            margin-bottom: 6px;
            border: 1px solid rgba(255, 176, 48, 0.2);
        }

        .src-ico {
            font-size: 26px;
            margin-bottom: 6px;
        }

        .src-name {
            font-size: 11px;
            font-weight: 700;
            color: var(--text2);
            margin-bottom: 4px;
        }

        .src-amt {
            font-size: 18px;
            font-weight: 900;
            font-family: 'DM Mono', monospace;
            color: var(--green);
            margin-bottom: 4px;
