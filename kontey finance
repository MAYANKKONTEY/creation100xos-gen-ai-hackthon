        }

        .modal-body {
            padding: 20px 22px;
            overflow-y: auto;
            flex: 1;
        }

        .fg {
            margin-bottom: 14px;
        }

        .fl {
            display: block;
            font-size: 10px;
            font-weight: 800;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .fi {
            width: 100%;
            background: var(--surface2);
            border: 1px solid var(--border);
