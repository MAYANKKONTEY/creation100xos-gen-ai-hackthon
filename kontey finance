            background: var(--surface2);
            border: 1.5px solid var(--border);
            border-radius: 9px;
            padding: 9px;
            cursor: pointer;
            text-align: center;
            font-size: 11.5px;
            font-weight: 700;
            color: var(--text2);
            font-family: 'Plus Jakarta Sans', sans-serif;
            transition: all .15s;
        }

        .pm:hover {
            border-color: var(--border2);
        }

        .pm.active {
            background: var(--orange-dim);
            border-color: var(--orange);
            color: var(--orange);
        }

        .sub-btn {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, var(--orange), var(--orange2));
            border: none;
            border-radius: 11px;
            color: #fff;
            font-size: 14px;
            font-weight: 800;
            font-family: 'Plus Jakarta Sans', sans-serif;
            cursor: pointer;
            transition: all .2s;
            box-shadow: var(--glow-o);
            margin-top: 4px;
            letter-spacing: .2px;
        }

        .sub-btn:hover {
            opacity: .92;
            transform: translateY(-1px);
        }

        .sub-btn:active {
            transform: translateY(0) scale(.98);
        }

        .cancel-btn {
            flex: 1;
            padding: 11px;
            background: var(--surface3);
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text2);
            transition: all .15s;
