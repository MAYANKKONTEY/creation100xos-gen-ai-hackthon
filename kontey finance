    <script>
        // ═══════════════════════════════════════════════════════
        // CONSTANTS
        // ═══════════════════════════════════════════════════════
        const CATS = {
            Food: {
                e: '🍔',
                c: '#FF6B35',
                bg: 'rgba(255,107,53,0.12)'
            },
            Travel: {
                e: '✈️',
