        function updateCharts() {
            if (!bChart) return;
            const now = new Date();

            // Bar chart - last 7 days by day of week
            const id = new Array(7).fill(0),
                ed = new Array(7).fill(0);
            txns.forEach(t => {
                const d = new Date(t.date),
                    diff = Math.round((now - d) / 864e5);
                if (diff >= 0 && diff < 7) {
                    const i = d.getDay();
                    if (t.type === 'income') id[i] += t.amount;
                    else ed[i] += t.amount;
                }
            });
            bChart.data.datasets[0].data = id;
            bChart.data.datasets[1].data = ed;
            bChart.update('none');

            // Donut - categories
            const allExp = txns.filter(t => t.type === 'expense');
            const cm = {};
            allExp.forEach(t => {
                cm[t.category] = (cm[t.category] || 0) + t.amount;
            });
            const s = Object.entries(cm).sort((a, b) => b[1] - a[1]);
            dChart.data.labels = s.map(([k]) => k);
            dChart.data.datasets[0].data = s.map(([, v]) => v);
            dChart.data.datasets[0].backgroundColor = s.map(([k]) => CATS[k]?.c || '#5A5A78');
            dChart.update('none');

            // Line - 14 days
            const ll = [],
                ld = [];
            for (let i = 13; i >= 0; i--) {
                const d = new Date();
                d.setDate(d.getDate() - i);
                const ds = d.toISOString().split('T')[0];
                ll.push(d.toLocaleDateString('en', {
                    month: 'short',
                    day: 'numeric'
                }));
                ld.push(txns.filter(t => t.type === 'expense' && t.date === ds).reduce((a, b) => a + b.amount, 0));
            }
            lChart.data.labels = ll;
            lChart.data.datasets[0].data = ld;
            lChart.update('none');

            // Income sources
            const sm = {};
            txns.filter(t => t.type === 'income').forEach(t => {
                sm[t.source] = (sm[t.source] || 0) + t.amount;
            });
            iChart.data.labels = Object.keys(sm);
            iChart.data.datasets[0].data = Object.values(sm);
            iChart.update('none');

            // Radar
            rChart.data.datasets[0].data = Object.keys(CATS).map(k => cm[k] || 0);
            rChart.update('none');

            // Pay charts
            const upi = allExp.filter(t => t.payment === 'UPI').reduce((a, b) => a + b.amount, 0);
            const cash = allExp.filter(t => t.payment === 'Cash').reduce((a, b) => a + b.amount, 0);
            const card = allExp.filter(t => t.payment === 'Card').reduce((a, b) => a + b.amount, 0);
            payChart.data.datasets[0].data = [upi, cash, card];
            payChart.update('none');
            ocChart.data.datasets[0].data = [upi + card, cash];
            ocChart.update('none');
        }

        // ═══════════════════════════════════════════════════════
        // ADD TRANSACTIONS
        // ═══════════════════════════════════════════════════════
        function addExp() {
            const amt = parseFloat(document.getElementById('e-amt').value);
            if (!amt || amt <= 0) {
                toast('⚠️ Enter a valid amount');
                return;
            }
            const date = document.getElementById('e-date').value || new Date().toISOString().split('T')[0];
            txns.unshift({
                id: uid(),
                type: 'expense',
                amount: amt,
                category: selCat,
                note: document.getElementById('e-note').value.trim(),
                payment: selPay,
                date
            });
            save();
            closeModal();
            renderAll();
            showSuccess();
            toast(`✓ -${ff(amt)} added`, 'ok');
            document.getElementById('e-amt').value = '';
            document.getElementById('e-note').value = '';
        }

        function addInc() {
            const amt = parseFloat(document.getElementById('i-amt').value);
            if (!amt || amt <= 0) {
                toast('⚠️ Enter a valid amount');
                return;
            }
            const date = document.getElementById('i-date').value || new Date().toISOString().split('T')[0];
            txns.unshift({
                id: uid(),
                type: 'income',
                amount: amt,
                source: document.getElementById('i-src').value,
                note: document.getElementById('i-note').value.trim(),
                date
            });
            save();
            closeModal();
            renderAll();
            showSuccess();
            toast(`✓ +${ff(amt)} income added`, 'ok');
            document.getElementById('i-amt').value = '';
            document.getElementById('i-note').value = '';
        }

        // ═══════════════════════════════════════════════════════
        // BUDGET ACTIONS
        // ═══════════════════════════════════════════════════════
        function openBudgetEdit(cat) {
            editBudgetCat = cat;
            document.getElementById('bm-title').textContent = (budgets[cat] ? 'Edit' : 'Set') + ` Budget — ${cat}`;
            document.getElementById('bm-sub').textContent = `${CATS[cat]?.e||''} Monthly spending limit for ${cat}`;
            document.getElementById('bm-amt').value = budgets[cat] || '';
            document.getElementById('budget-ov').classList.add('open');
            setTimeout(() => document.getElementById('bm-amt').focus(), 200);
        }

        function closeBudgetEdit() {
            document.getElementById('budget-ov').classList.remove('open');
            editBudgetCat = null;
        }

        function saveBudget() {
            const amt = parseFloat(document.getElementById('bm-amt').value);
            if (editBudgetCat && amt > 0) {
                budgets[editBudgetCat] = amt;
                save();
                renderBudgetPage();
                toast(`✓ Budget set for ${editBudgetCat}`, 'ok');
            }
            closeBudgetEdit();
        }

        // ═══════════════════════════════════════════════════════
        // GOAL ACTIONS
        // ═══════════════════════════════════════════════════════
        function openGoalModal() {
            selectedGoalEmoji = '🎯';
            selectedGoalColor = '#FF6B35';
            document.getElementById('gm-name').value = '';
            document.getElementById('gm-target').value = '';
            document.getElementById('gm-saved').value = '';
            document.getElementById('goal-ov').classList.add('open');
            setTimeout(() => document.getElementById('gm-name').focus(), 200);
        }

        function closeGoalModal() {
            document.getElementById('goal-ov').classList.remove('open');
        }

        function pickGoalEmoji(el) {
            document.querySelectorAll('.goal-emoji-opt').forEach(e => e.style.background = 'var(--surface2)');
            el.style.background = 'var(--orange-dim)';
            selectedGoalEmoji = el.dataset.e;
        }

        function pickGoalColor(el) {
            document.querySelectorAll('.goal-color-opt').forEach(e => e.style.border = '2.5px solid transparent');
            el.style.border = `2.5px solid ${el.dataset.c}`;
            selectedGoalColor = el.dataset.c;
        }

        function saveGoal() {
            const name = document.getElementById('gm-name').value.trim();
            const target = parseFloat(document.getElementById('gm-target').value);
            if (!name) {
                toast('⚠️ Enter a goal name');
                return;
            }
            if (!target || target <= 0) {
                toast('⚠️ Enter a target amount');
                return;
            }
            const saved = parseFloat(document.getElementById('gm-saved').value) || 0;
            const deadline = document.getElementById('gm-deadline').value;
            goals.push({
                id: uid(),
                emoji: selectedGoalEmoji,
                name,
                target,
                saved,
                deadline,
                color: selectedGoalColor
            });
            save();
            closeGoalModal();
            renderGoalsPage();
            toast(`✓ Goal "${name}" created!`, 'ok');
        }

        function openGoalSave(id) {
            const g = goals.find(g => g.id === id);
            if (!g) return;
            document.getElementById('gsave-name').textContent = `${g.emoji} ${g.name} — currently ${ff(g.saved)}`;
            document.getElementById('gsave-amt').value = g.saved || '';
            document.getElementById('gsave-id').value = id;
            document.getElementById('goal-save-ov').classList.add('open');
            setTimeout(() => document.getElementById('gsave-amt').focus(), 200);
        }

        function saveGoalProgress() {
            const id = document.getElementById('gsave-id').value;
            const amt = parseFloat(document.getElementById('gsave-amt').value);
            if (!isNaN(amt) && amt >= 0) {
                const g = goals.find(g => g.id === id);
                if (g) {
                    g.saved = amt;
                    save();
                    renderGoalsPage();
                    const pct = g.target > 0 ? ((amt / g.target) * 100).toFixed(0) : 0;
                    toast(amt >= g.target ? '🎉 Goal achieved!' : `✓ Progress: ${pct}% of goal`, 'ok');
                }
            }
            document.getElementById('goal-save-ov').classList.remove('open');
        }

        function delGoal(id) {
            goals = goals.filter(g => g.id !== id);
            save();
            renderGoalsPage();
            toast('🗑 Goal deleted', 'ok');
        }

        // ═══════════════════════════════════════════════════════
        // UI HELPERS
        // ═══════════════════════════════════════════════════════
        function pickCat(el) {
            document.querySelectorAll('.cp').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            selCat = el.dataset.cat;
        }

        function pickPay(el) {
            document.querySelectorAll('.pm').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            selPay = el.dataset.pay;
        }

        function setF(f, el) {
            filt = f;
            document.querySelectorAll('.tf').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            renderAll();
        }

        function go(page, el) {
            activePage = page;
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item,.mn-item').forEach(n => n.classList.remove('active'));
            document.getElementById('page-' + page).classList.add('active');
            // Highlight matching nav items
            document.querySelectorAll('.nav-item').forEach(n => {
                if (n.textContent.toLowerCase().includes(page.toLowerCase().replace('transactions', 'txn').replace('transactions', 'transactions'))) n.classList.add('active');
            });
            document.querySelectorAll('.mn-item').forEach(n => {
                if (n.dataset.page === page) n.classList.add('active');
            });
            if (el) el.classList.add('active');

            if (page === 'analytics') {
                setTimeout(() => {
                    lChart?.update();
                    iChart?.update();
                    rChart?.update();
                    payChart?.update();
                    ocChart?.update();
                    renderIncSources();
                }, 60);
            }
            if (page === 'transactions') renderHist();
            if (page === 'categories') renderCats();
            if (page === 'budget') renderBudgetPage();
            if (page === 'goals') renderGoalsPage();
        }

        function switchTab(t) {
            activeTab = t;
            document.getElementById('form-e').style.display = t === 'expense' ? '' : 'none';
            document.getElementById('form-i').style.display = t === 'income' ? '' : 'none';
            document.getElementById('tab-e').classList.toggle('active', t === 'expense');
            document.getElementById('tab-i').classList.toggle('active', t === 'income');
        }

        function openModal() {
            document.getElementById('ov').classList.add('open');
            setTimeout(() => document.getElementById(activeTab === 'expense' ? 'e-amt' : 'i-amt').focus(), 280);
        }

        function closeModal() {
            document.getElementById('ov').classList.remove('open');
        }

        function outsideClose(e, id) {
            if (e.target.id === id) document.getElementById(id).classList.remove('open');
        }

        function toast(msg, type = 'warn') {
            const el = document.getElementById('toast');
            el.textContent = msg;
            el.style.borderLeft = type === 'ok' ? '3px solid var(--green)' : '3px solid var(--gold)';
            el.classList.add('show');
            clearTimeout(el._t);
            el._t = setTimeout(() => el.classList.remove('show'), 3000);
        }

        function showSuccess() {
            const el = document.getElementById('success-flash');
            el.classList.add('show');
            setTimeout(() => el.classList.remove('show'), 600);
        }

        function confirmReset() {
            document.getElementById('confirm-ov').classList.add('open');
        }

        function closeConfirm() {
            document.getElementById('confirm-ov').classList.remove('open');
        }

        function resetAll() {
            txns = [];
            save();
            closeConfirm();
            renderAll();
            toast('✓ All transactions cleared', 'ok');
        }

        function exportCSV() {
            const rows = [
                ['Date', 'Type', 'Category/Source', 'Note', 'Payment', 'Amount']
            ];
            txns.forEach(t => rows.push([t.date, t.type, t.category || t.source, t.note || '', t.payment || '', t.amount]));
            const a = document.createElement('a');
            a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(rows.map(r => r.join(',')).join('\n'));
            a.download = 'kontey-' + new Date().toISOString().split('T')[0] + '.csv';
            a.click();
            toast('✓ CSV exported', 'ok');
        }

        // ═══════════════════════════════════════════════════════
        // KEYBOARD SHORTCUTS
        // ═══════════════════════════════════════════════════════
        document.addEventListener('keydown', e => {
            const tag = e.target.tagName;
            const inInput = ['INPUT', 'SELECT', 'TEXTAREA'].includes(tag);

            if (e.key === 'Escape') {
                ['ov', 'budget-ov', 'goal-ov', 'goal-save-ov', 'confirm-ov'].forEach(id => document.getElementById(id).classList.remove('open'));
            }
            if (!inInput) {
                if (e.key === '+' || e.key === '=') openModal();
                if (e.key === 'e' || e.key === 'E') {
                    openModal();
                    switchTab('expense');
                }
                if (e.key === 'i' || e.key === 'I') {
                    openModal();
                    switchTab('income');
                }
            }
            if (e.key === 'Enter' && document.getElementById('ov').classList.contains('open')) {
                if (activeTab === 'expense') addExp();
                else addInc();
            }
            if (e.key === 'Enter' && document.getElementById('budget-ov').classList.contains('open')) saveBudget();
        });

        // ═══════════════════════════════════════════════════════
        // START
        // ═══════════════════════════════════════════════════════
        init();
    </script>
