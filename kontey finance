        /* ── FAB ── */
        .fab {
            position: fixed;
            bottom: 30px;
            right: 28px;
            width: 52px;
            height: 52px;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--orange), var(--orange2));
            border: none;
            cursor: pointer;
            color: #fff;
            font-size: 28px;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: var(--glow-o), var(--shadow);
            transition: all .2s;
            z-index: 100;
        }

        .fab:hover {
            transform: scale(1.08) rotate(90deg);
            box-shadow: 0 0 40px rgba(255, 107, 53, 0.5), var(--shadow-lg);
        }

        .fab:active {
            transform: scale(0.93);
        }

        /* ── MODALS ── */
        .overlay {
            position: fixed;
            inset: 0;
            background: rgba(7, 7, 15, 0.75);
            backdrop-filter: blur(12px);
            z-index: 200;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .22s;
        }

        .overlay.open {
            opacity: 1;
            pointer-events: all;
