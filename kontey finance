<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Kontey — Smart Finance</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <style>
        :root {
            --bg: #07070F;
            --bg2: #0C0C1A;
            --surface: #101020;
            --surface2: #14142A;
            --surface3: #1C1C38;
            --border: rgba(255, 255, 255, 0.07);
            --border2: rgba(255, 255, 255, 0.13);
            --border-o: rgba(255, 107, 53, 0.3);
            --text: #E2E2F0;
            --text2: #8888A8;
            --muted: #4A4A68;
            --orange: #FF6B35;
            --orange2: #FF8A55;
            --orange3: #FFAD80;
            --orange-dim: rgba(255, 107, 53, 0.12);
            --orange-glow: rgba(255, 107, 53, 0.3);
            --green: #00D68F;
            --green-dim: rgba(0, 214, 143, 0.12);
            --red: #FF4466;
            --red-dim: rgba(255, 68, 102, 0.12);
            --blue: #4D8EFF;
            --blue-dim: rgba(77, 142, 255, 0.12);
            --purple: #A070FF;
            --purple-dim: rgba(160, 112, 255, 0.12);
            --gold: #FFB030;
            --gold-dim: rgba(255, 176, 48, 0.12);
            --shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
            --shadow-lg: 0 16px 60px rgba(0, 0, 0, 0.7);
            --glow-o: 0 0 28px rgba(255, 107, 53, 0.25);
            --glow-g: 0 0 28px rgba(0, 214, 143, 0.2);
            --r: 16px;
            --r-sm: 10px;
            --r-lg: 22px;
            --r-xl: 28px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            font-size: 15px;
            -webkit-font-smoothing: antialiased;
        }

        /* ── LAYOUT ── */
        .shell {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 22px 12px 20px;
            position: sticky;
            top: 0;
            height: 100vh;
            flex-shrink: 0;
        }

        .main {
            flex: 1;
            overflow-y: auto;
            min-width: 0;
            scroll-behavior: smooth;
        }

        .page {
            display: none;
            padding: 28px 30px 100px;
            animation: pgIn .3s cubic-bezier(.4, 0, .2, 1);
        }

        .page.active {
            display: block;
        }

        @keyframes pgIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ── SIDEBAR ── */
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 4px 8px 22px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 16px;
        }

        .logo-mark {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--orange), var(--orange2));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            font-weight: 900;
            color: #fff;
            box-shadow: var(--glow-o);
        }

        .logo-name {
            font-size: 15px;
            font-weight: 800;
            letter-spacing: -.3px;
        }

        .logo-pro {
            font-size: 9px;
            background: var(--orange-dim);
            color: var(--orange);
            padding: 1px 6px;
            border-radius: 20px;
            border: 1px solid var(--border-o);
            font-weight: 700;
            letter-spacing: .5px;
        }

        .nav-sec {
            font-size: 9.5px;
            letter-spacing: 1.8px;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0 10px;
            margin: 12px 0 4px;
            font-weight: 700;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 11px;
            cursor: pointer;
            color: var(--text2);
            font-size: 13px;
            font-weight: 600;
            transition: all .18s;
            margin-bottom: 2px;
            user-select: none;
            position: relative;
        }

        .nav-item:hover {
            background: var(--surface2);
            color: var(--text);
        }

        .nav-item.active {
            background: var(--orange-dim);
            color: var(--orange);
            border: 1px solid var(--border-o);
        }

        .nav-ico {
            font-size: 14px;
            width: 18px;
            text-align: center;
            flex-shrink: 0;
        }

        .nav-badge {
            position: absolute;
            right: 10px;
            background: var(--red);
            color: #fff;
            font-size: 9px;
            font-weight: 800;
            padding: 1px 5px;
            border-radius: 10px;
            min-width: 18px;
            text-align: center;
        }

        .streak-widget {
            margin: auto 0 14px;
            background: linear-gradient(135deg, rgba(255, 176, 48, 0.1), rgba(255, 107, 53, 0.08));
            border: 1px solid rgba(255, 176, 48, 0.2);
            border-radius: var(--r);
            padding: 14px;
            text-align: center;
        }

        .streak-fire {
            font-size: 28px;
            margin-bottom: 2px;
        }

        .streak-count {
            font-size: 26px;
            font-weight: 900;
            font-family: 'DM Mono', monospace;
            background: linear-gradient(135deg, var(--gold), var(--orange));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .streak-label {
            font-size: 10px;
            color: var(--text2);
            font-weight: 600;
            letter-spacing: .5px;
            text-transform: uppercase;
        }

        .streak-sub {
            font-size: 9px;
            color: var(--muted);
            margin-top: 3px;
        }

        .sb-bal {
            background: linear-gradient(135deg, var(--surface2), var(--surface3));
            border: 1px solid var(--border2);
            border-radius: var(--r);
            padding: 14px 13px;
        }

        .sbb-label {
            font-size: 9px;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .sbb-val {
            font-size: 22px;
            font-weight: 800;
            font-family: 'DM Mono', monospace;
            background: linear-gradient(135deg, var(--orange), var(--orange3));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .sbb-sub {
            font-size: 10px;
            color: var(--muted);
            margin-top: 3px;
        }

        /* ── TOPBAR ── */
        .topbar {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 22px;
            gap: 12px;
            flex-wrap: wrap;
        }

        .page-title {
            font-size: 24px;
            font-weight: 900;
            letter-spacing: -1px;
            background: linear-gradient(135deg, var(--text) 60%, var(--text2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .page-sub {
            font-size: 12px;
            color: var(--muted);
            margin-top: 2px;
        }

        .topbar-actions {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .tf-group {
            display: flex;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 11px;
            padding: 3px;
            gap: 2px;
        }

        .tf {
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 11.5px;
            font-weight: 700;
            cursor: pointer;
            color: var(--text2);
            border: none;
            background: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
            transition: all .15s;
            letter-spacing: .2px;
        }

        .tf.active {
            background: var(--orange);
            color: #fff;
            box-shadow: var(--glow-o);
        }

        .icon-btn {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 8px 14px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text2);
            cursor: pointer;
            font-family: 'Plus Jakarta Sans', sans-serif;
            transition: all .15s;
            display: flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
        }

        .icon-btn:hover {
            border-color: var(--border2);
            color: var(--text);
        }

        .icon-btn.danger:hover {
            border-color: var(--red);
            color: var(--red);
            background: var(--red-dim);
        }

        /* ── BALANCE HERO ── */
        .balance-hero {
            background: linear-gradient(135deg, #0D0D22 0%, #141432 50%, #0A0A1E 100%);
            border: 1px solid var(--border-o);
            border-radius: var(--r-xl);
            padding: 28px 30px;
            margin-bottom: 18px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.06);
        }

        .balance-hero::before {
            content: '';
            position: absolute;
            top: -120px;
            right: -80px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255, 107, 53, 0.18) 0%, transparent 65%);
            border-radius: 50%;
            pointer-events: none;
        }

        .balance-hero::after {
            content: '';
            position: absolute;
            bottom: -100px;
            left: -60px;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(77, 142, 255, 0.08) 0%, transparent 65%);
            border-radius: 50%;
            pointer-events: none;
        }

        .bh-inner {
            position: relative;
            z-index: 1;
        }

        .bh-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 18px;
            gap: 12px;
            flex-wrap: wrap;
        }

        .bh-label {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.4);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .bh-amount {
            font-size: 48px;
            font-weight: 900;
            font-family: 'DM Mono', monospace;
            letter-spacing: -2px;
            line-height: 1;
            background: linear-gradient(135deg, #FFFFFF 0%, rgba(255, 200, 160, 0.9) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .bh-amount.negative {
            background: linear-gradient(135deg, var(--red), rgba(255, 100, 120, 0.8));
            -webkit-background-clip: text;
            background-clip: text;
        }

        .bh-subtitle {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.3);
            margin-top: 5px;
        }

        .bh-right {
            text-align: right;
        }

        .bh-month-label {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.4);
            margin-bottom: 3px;
        }

        .bh-month-val {
            font-size: 18px;
            font-weight: 800;
            font-family: 'DM Mono', monospace;
            color: rgba(255, 255, 255, 0.85);
        }

        .bh-stats {
            display: flex;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 14px;
            overflow: hidden;
            backdrop-filter: blur(20px);
        }

        .bhs {
            flex: 1;
            padding: 13px 16px;
            text-align: center;
            position: relative;
        }

        .bhs+.bhs::before {
            content: '';
            position: absolute;
            left: 0;
            top: 25%;
            height: 50%;
            width: 1px;
            background: rgba(255, 255, 255, 0.07);
        }

        .bhs-label {
            font-size: 9px;
            color: rgba(255, 255, 255, 0.35);
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .bhs-val {
            font-size: 16px;
            font-weight: 800;
            font-family: 'DM Mono', monospace;
        }

        .bhs-val.g {
            color: var(--green);
        }

        .bhs-val.r {
            color: var(--red);
        }

        .bhs-val.o {
            color: var(--orange3);
        }

        /* ── INSIGHTS ── */
        .insights-header {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .insights-header-title {
            font-size: 13px;
            font-weight: 800;
            color: var(--text2);
            letter-spacing: .3px;
            text-transform: uppercase;
        }

        .insights-header-dot {
            width: 6px;
            height: 6px;
            background: var(--orange);
            border-radius: 50%;
            box-shadow: var(--glow-o);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: .5;
                transform: scale(.8);
            }
        }

        .ins-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }

        .ins-card {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 14px;
            display: flex;
            gap: 11px;
            align-items: flex-start;
            transition: all .2s;
            position: relative;
            overflow: hidden;
        }

        .ins-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            border-radius: 3px 0 0 3px;
        }

        .ins-card.good::before {
            background: var(--green);
        }

        .ins-card.warn::before {
            background: var(--gold);
        }

        .ins-card.alert::before {
            background: var(--red);
        }

        .ins-card.info::before {
            background: var(--blue);
        }

        .ins-card:hover {
            border-color: var(--border2);
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        .ins-ico {
            width: 32px;
            height: 32px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .ins-title {
            font-size: 12.5px;
            font-weight: 800;
            margin-bottom: 2px;
            color: var(--text);
        }

        .ins-text {
            font-size: 11px;
            color: var(--text2);
            line-height: 1.4;
        }

        /* ── WEEK COMPARE ── */
        .week-compare {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 16px 18px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .wc-title {
            font-size: 11px;
            font-weight: 700;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 4px;
        }

        .wc-val {
            font-size: 22px;
            font-weight: 900;
            font-family: 'DM Mono', monospace;
        }

        .wc-divider {
            width: 1px;
            height: 40px;
            background: var(--border);
            flex-shrink: 0;
        }

        .wc-change {
            display: flex;
            align-items: center;
            gap: 6px;
            flex: 1;
            justify-content: center;
        }

        .wc-arrow {
            font-size: 22px;
        }

        .wc-pct {
            font-size: 18px;
            font-weight: 900;
            font-family: 'DM Mono', monospace;
        }

        .wc-change-label {
            font-size: 11px;
            color: var(--muted);
        }

        /* ── STAT CARDS ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-bottom: 18px;
        }

        .s-card {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 16px;
            transition: all .2s;
            cursor: default;
        }

        .s-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow);
            border-color: var(--border2);
        }

        .s-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .s-ico {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .s-badge {
            font-size: 9.5px;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 20px;
            letter-spacing: .3px;
        }

        .bg {
            background: var(--green-dim);
            color: var(--green);
        }

        .br {
            background: var(--red-dim);
            color: var(--red);
        }

        .bb {
            background: var(--blue-dim);
            color: var(--blue);
        }

        .bo {
            background: var(--orange-dim);
            color: var(--orange);
        }

        .s-label {
            font-size: 10px;
            color: var(--muted);
            letter-spacing: .5px;
            text-transform: uppercase;
            font-weight: 700;
            margin-bottom: 3px;
        }

        .s-val {
            font-size: 20px;
            font-weight: 800;
            font-family: 'DM Mono', monospace;
            letter-spacing: -.5px;
        }

        /* ── SUBSCRIPTION BANNER ── */
        .sub-banner {
            background: linear-gradient(135deg, rgba(255, 176, 48, 0.08), rgba(255, 107, 53, 0.06));
            border: 1px solid rgba(255, 176, 48, 0.2);
            border-radius: var(--r);
            padding: 14px 18px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sub-banner-ico {
            font-size: 24px;
            flex-shrink: 0;
        }

        .sub-banner-content {
            flex: 1;
        }

        .sub-banner-title {
            font-size: 13px;
            font-weight: 800;
            color: var(--gold);
            margin-bottom: 2px;
        }

        .sub-banner-sub {
            font-size: 11.5px;
            color: var(--text2);
        }

        .sub-banner-amt {
            font-size: 20px;
            font-weight: 900;
            font-family: 'DM Mono', monospace;
            color: var(--gold);
            flex-shrink: 0;
        }

        /* ── PAYMENT BREAKDOWN ── */
        .pay-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }

        .pay-card {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 16px;
            transition: all .2s;
            position: relative;
            overflow: hidden;
        }

        .pay-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        .pay-card-accent {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            border-radius: 0 0 var(--r) var(--r);
        }

        .pay-ico {
            font-size: 22px;
            margin-bottom: 8px;
        }

        .pay-name {
            font-size: 10px;
            color: var(--muted);
            font-weight: 700;
            letter-spacing: .7px;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .pay-amt {
            font-size: 20px;
            font-weight: 800;
            font-family: 'DM Mono', monospace;
            margin-bottom: 3px;
        }

        .pay-meta {
            font-size: 10.5px;
            color: var(--text2);
        }

        .pay-bar {
            height: 3px;
            background: var(--surface3);
            border-radius: 2px;
            overflow: hidden;
            margin-top: 10px;
        }

        .pay-bar-fill {
            height: 100%;
            border-radius: 2px;
            transition: width 1s cubic-bezier(.4, 0, .2, 1);
        }

        /* ── CHARTS ── */
        .charts-row {
            display: grid;
            grid-template-columns: 1fr 280px;
            gap: 14px;
            margin-bottom: 18px;
        }

        .cc {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 20px;
        }

        .cc-hd {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }

        .cc-title {
            font-size: 13px;
            font-weight: 800;
            color: var(--text);
        }

        .cc-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 2px;
        }

        .cc-badge {
            font-size: 10px;
            font-weight: 700;
            background: var(--orange-dim);
            color: var(--orange);
            padding: 3px 9px;
            border-radius: 20px;
            border: 1px solid var(--border-o);
        }

        .cw {
            position: relative;
        }

        /* ── SECTION HEADER ── */
        .sec-hd {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .sec-title {
            font-size: 14px;
            font-weight: 800;
            color: var(--text);
        }

        .sec-link {
            font-size: 11.5px;
            color: var(--orange);
            cursor: pointer;
            font-weight: 700;
            transition: opacity .15s;
        }

        .sec-link:hover {
            opacity: .75;
        }

        /* ── TRANSACTIONS ── */
        .txn-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .txn {
            display: flex;
            align-items: center;
            gap: 11px;
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 14px;
            transition: all .18s;
            position: relative;
            overflow: hidden;
        }

        .txn::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 0;
            background: var(--orange);
            transition: width .2s;
            border-radius: 12px 0 0 12px;
        }

        .txn:hover {
            border-color: var(--border2);
            background: var(--surface3);
            transform: translateX(3px);
        }

        .txn:hover::before {
            width: 3px;
        }

        .txn-ico {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
        }

        .txn-info {
            flex: 1;
            min-width: 0;
        }

        .txn-name {
            font-size: 13px;
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .txn-meta {
            font-size: 10px;
            color: var(--muted);
            margin-top: 2px;
            display: flex;
            gap: 5px;
            align-items: center;
            flex-wrap: wrap;
        }

        .dot {
            width: 3px;
            height: 3px;
            background: var(--surface3);
            border-radius: 50%;
            flex-shrink: 0;
        }

        .pay-chip {
            font-size: 9px;
            font-weight: 700;
            padding: 1px 6px;
            border-radius: 20px;
            background: var(--surface3);
            color: var(--text2);
            border: 1px solid var(--border);
        }

        .txn-r {
            text-align: right;
            flex-shrink: 0;
        }

        .txn-amt {
            font-size: 14px;
            font-weight: 800;
            font-family: 'DM Mono', monospace;
        }

        .txn-amt.neg {
            color: var(--red);
        }

        .txn-amt.pos {
            color: var(--green);
        }

        .txn-del {
            width: 26px;
            height: 26px;
            border-radius: 7px;
            background: none;
            border: none;
            cursor: pointer;
            color: var(--muted);
            font-size: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .15s;
            flex-shrink: 0;
            opacity: 0;
        }

        .txn:hover .txn-del {
            opacity: 1;
        }

        .txn-del:hover {
            background: var(--red-dim);
            color: var(--red);
        }

        /* ── EMPTY STATE ── */
        .empty {
            text-align: center;
            padding: 50px 20px;
        }

        .empty-ico {
            font-size: 52px;
            margin-bottom: 14px;
            opacity: .8;
        }

        .empty-t {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 6px;
        }

        .empty-s {
            font-size: 12.5px;
            color: var(--muted);
            margin-bottom: 20px;
            max-width: 260px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.5;
        }

        .empty-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: linear-gradient(135deg, var(--orange), var(--orange2));
            color: #fff;
            border: none;
            padding: 11px 22px;
            border-radius: 11px;
            font-size: 13px;
            font-weight: 800;
            cursor: pointer;
            font-family: 'Plus Jakarta Sans', sans-serif;
            box-shadow: var(--glow-o);
            transition: all .2s;
        }

        .empty-btn:hover {
            opacity: .9;
            transform: translateY(-2px);
        }

        /* ── DATE DIVIDER ── */
        .date-div {
            font-size: 10px;
            font-weight: 800;
            color: var(--muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 10px 0 6px;
