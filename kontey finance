        .gc-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .gc-pct {
            font-size: 12px;
            font-weight: 800;
        }

        .gc-days {
            font-size: 11px;
            color: var(--muted);
        }

        .gc-done {
            font-size: 11px;
            font-weight: 700;
            color: var(--green);
