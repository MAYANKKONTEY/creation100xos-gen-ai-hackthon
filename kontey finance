            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }

        .cp {
            background: var(--surface2);
            border: 1.5px solid var(--border);
            border-radius: 9px;
            padding: 9px 5px 7px;
            cursor: pointer;
            text-align: center;
            transition: all .15s;
        }

        .cp:hover {
            border-color: var(--orange3);
            background: var(--surface3);
        }

        .cp.active {
            background: var(--orange-dim);
            border-color: var(--orange);
        }

        .cp-e {
            font-size: 18px;
            display: block;
            margin-bottom: 3px;
        }

        .cp-l {
            font-size: 9px;
            font-weight: 800;
            color: var(--text2);
            letter-spacing: .3px;
        }

        .cp.active .cp-l {
            color: var(--orange);
        }

        .pay-row {
            display: flex;
            gap: 6px;
        }

