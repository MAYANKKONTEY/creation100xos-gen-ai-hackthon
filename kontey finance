            flex: 1;
            padding: 10px;
            background: var(--red);
            border: none;
            border-radius: 9px;
            font-size: 13px;
            font-weight: 800;
            cursor: pointer;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #fff;
        }

        /* ── TOAST ── */
        .toast {
            position: fixed;
            bottom: 90px;
            right: 24px;
            background: var(--surface3);
            color: var(--text);
            border: 1px solid var(--border2);
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 12.5px;
            font-weight: 700;
            transform: translateY(10px);
            opacity: 0;
            transition: all .3s cubic-bezier(.34, 1.2, .64, 1);
            z-index: 400;
            max-width: 260px;
            box-shadow: var(--shadow-lg);
        }

        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }

        /* ── SUCCESS FLASH ── */
        .success-flash {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            pointer-events: none;
            z-index: 999;
            opacity: 0;
            transition: opacity .3s;
        }

        .success-flash.show {
            opacity: 1;
        }

        .success-flash-inner {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 72px;
            animation: successPop .5s cubic-bezier(.34, 1.4, .64, 1);
        }

        @keyframes successPop {
            from {
                transform: translate(-50%, -50%) scale(0);
                opacity: 0;
            }

            50% {
                opacity: 1;
            }

            to {
                transform: translate(-50%, -50%) scale(1.2);
                opacity: 0;
            }
        }

        /* ── MOBILE NAV ── */
        .mobile-nav {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(16, 16, 32, 0.95);
            backdrop-filter: blur(24px);
            border-top: 1px solid var(--border);
            padding: 8px 0 calc(8px + env(safe-area-inset-bottom));
            z-index: 99;
        }

        .mn-inner {
            display: flex;
            justify-content: space-around;
        }

        .mn-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 3px;
            padding: 6px 12px;
            border-radius: 10px;
            cursor: pointer;
            color: var(--muted);
            font-size: 10px;
            font-weight: 700;
            transition: all .15s;
            border: none;
            background: none;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .mn-item.active {
            color: var(--orange);
        }

        .mn-item.active .mn-ico {
            text-shadow: 0 0 12px var(--orange);
        }

        .mn-ico {
            font-size: 20px;
            transition: transform .15s;
        }

        .mn-item:active .mn-ico {
            transform: scale(0.85);
        }

        /* ── RESPONSIVE ── */
        @media(max-width:1100px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .charts-row {
                grid-template-columns: 1fr;
            }

            .ins-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .budget-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .inc-src-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media(max-width:768px) {
            .sidebar {
                display: none;
            }

            .mobile-nav {
                display: block;
            }

            .page {
                padding: 16px 14px 90px;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .cat-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .bh-amount {
                font-size: 36px;
            }

            .bh-stats {
                flex-wrap: wrap;
            }

            .ins-grid {
                grid-template-columns: 1fr;
            }

            .pay-grid {
                grid-template-columns: 1fr 1fr;
            }

            .budget-grid {
                grid-template-columns: 1fr 1fr;
            }

            .inc-src-grid {
                grid-template-columns: 1fr 1fr;
            }

            .fab {
                bottom: 80px;
            }
        }

        @media(max-width:480px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }

            .pay-grid {
                grid-template-columns: 1fr;
            }

            .budget-grid {
                grid-template-columns: 1fr;
            }

            .bh-stats {
                gap: 0;
            }

            .bh-amount {
                font-size: 30px;
            }
        }
    </style>
</head>

