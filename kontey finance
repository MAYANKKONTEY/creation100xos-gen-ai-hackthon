        /* ── ADVANCED FILTERS ── */
        .adv-filters {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 14px 16px;
            margin-bottom: 16px;
        }

        .af-row {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

        .af-input {
            background: var(--surface3);
            border: 1px solid var(--border);
            border-radius: 9px;
            padding: 8px 12px;
            color: var(--text);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 13px;
            outline: none;
            transition: border-color .15s;
        }

        .af-input:focus {
            border-color: var(--orange);
        }

        .af-input::placeholder {
            color: var(--muted);
        }

        .af-search {
