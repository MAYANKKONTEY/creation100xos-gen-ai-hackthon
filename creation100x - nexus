    </div>`;
            }).join('');
        }

        function showPlanPopup(e, day) {
            const p = getPlan(day);
            if (!p) return;
            const isDone = S.doneDays.includes(day);
            let html = `<div class="popup-t" style="color:${p.col}">Day ${day}: ${p.sub.toUpperCase()} <span class="popup-close" onclick="document.getElementById('planPopup').style.display='none'">✕</span></div>`;
            html += `<div style="font-size:10.5px;font-weight:600;margin-bottom:5px">${p.title}</div>`;
            if (p.obj) html += `<div style="font-size:9.5px;color:var(--t2);font-style:italic;margin-bottom:7px;line-height:1.5">🎯 ${p.obj}</div>`;
            html += `<ul class="popup-list">`;
            p.tasks.forEach(t => {
                html += `<li>${t}</li>`;
            });
            html += '</ul>';
            html += isDone ? `<div style="color:var(--green);font-size:10.5px;margin-top:7px;text-align:center;font-weight:600">✅ Completed!</div>` : `<button class="btn btn-orange btn-sm" style="width:100%;margin-top:7px;justify-content:center" onclick="markSpecificDay(${day})">✅ Mark Complete</button>`;
            const pp = document.getElementById('planPopup');
            pp.innerHTML = html;
            pp.style.display = 'block';
            const r = e.currentTarget.getBoundingClientRect();
            pp.style.left = Math.min(r.left, window.innerWidth - 290) + 'px';
            pp.style.top = (r.bottom + 5) + 'px';
        }

        function markSpecificDay(day) {
