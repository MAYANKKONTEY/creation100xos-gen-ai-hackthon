<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXMIND × CREATION100X — Cosmic Command Center</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=JetBrains+Mono:wght@300;400;500;600&family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,300&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        :root {
            --bg: #020308;
            --s1: #060b16;
            --s2: #0a1020;
            --s3: #0f1830;
            --s4: #141e38;
            --accent: #6366f1;
            --accent2: #818cf8;
            --cyan: #06b6d4;
            --orange: #ff5200;
            --orange2: #ff7a40;
            --green: #10b981;
            --gold: #f59e0b;
            --red: #ef4444;
            --purple: #a855f7;
            --pink: #f472b6;
            --t1: #e8eeff;
            --t2: #8b9ac8;
            --t3: #4a5580;
            --t4: #1e2640;
            --border: rgba(99, 102, 241, 0.12);
            --border2: rgba(99, 102, 241, 0.25);
            --glow-a: rgba(99, 102, 241, 0.2);
            --glow-c: rgba(6, 182, 212, 0.15);
            --glow-o: rgba(255, 82, 0, 0.2);
            --r: 12px;
            --r-lg: 18px;
            --r-xl: 26px;
            --r-sm: 8px;
            --sidebar: 60px;
            --sidebar-w: 240px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-font-smoothing: antialiased
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg);
            color: var(--t1);
            overflow: hidden;
            height: 100vh;
            cursor: default
        }

        ::-webkit-scrollbar {
            width: 3px;
            height: 3px
        }

        ::-webkit-scrollbar-track {
            background: transparent
        }

        ::-webkit-scrollbar-thumb {
            background: var(--border2);
            border-radius: 2px
        }

        button,
        input,
        textarea,
        select {
            font-family: inherit
        }

        /* === 3D CANVAS === */
        #space-canvas {
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none
        }

        /* === TICKER === */
        .ticker {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 26px;
            background: linear-gradient(90deg, var(--accent), var(--cyan), var(--orange), var(--purple), var(--accent));
            background-size: 400% 100%;
            animation: tickerGrad 8s linear infinite;
            z-index: 300;
            overflow: hidden;
            display: flex;
            align-items: center
        }

        @keyframes tickerGrad {
            0% {
                background-position: 0% 50%
            }

            100% {
                background-position: 400% 50%
            }
        }

        .ticker-inner {
            display: flex;
            gap: 0;
            white-space: nowrap;
            animation: tickMove 60s linear infinite;
            will-change: transform
        }

        .ticker-inner span {
            font-family: 'Syne', sans-serif;
            font-size: 8.5px;
            font-weight: 800;
            letter-spacing: 2.5px;
            color: #000;
            padding: 0 20px
        }

        .ticker-inner span::after {
            content: '◆';
            margin-left: 20px
        }

        @keyframes tickMove {
            from {
                transform: translateX(0)
            }

            to {
                transform: translateX(-50%)
            }
        }

        /* === SHELL === */
        .shell {
            display: flex;
            height: calc(100vh - 26px);
            margin-top: 26px;
            position: relative;
            z-index: 1
        }

        /* === SIDEBAR === */
        .sidebar {
            width: var(--sidebar);
            flex-shrink: 0;
            background: rgba(6, 11, 22, 0.85);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 10px 0 8px;
            gap: 1px;
            z-index: 10;
            transition: width 0.3s cubic-bezier(.4, 0, .2, 1);
            overflow: hidden
        }

        .sidebar.expanded {
            width: var(--sidebar-w)
        }

        .sb-logo {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--accent), var(--cyan));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
            margin-bottom: 10px;
            flex-shrink: 0;
            box-shadow: 0 0 28px var(--glow-a);
            position: relative;
            overflow: hidden
        }

        .sb-logo::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, transparent, rgba(255, 255, 255, 0.1));
            pointer-events: none
        }

        .ni {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 16px;
            color: var(--t3);
            transition: all .2s;
            border: 1px solid transparent;
            position: relative;
            flex-shrink: 0;
            white-space: nowrap;
            overflow: hidden;
            gap: 10px
        }

        .sidebar.expanded .ni {
            width: calc(var(--sidebar-w) - 16px);
            padding: 0 12px;
            justify-content: flex-start
        }

        .ni:hover {
            background: rgba(99, 102, 241, 0.08);
            color: var(--t2);
            border-color: var(--border)
        }

        .ni.active {
            background: rgba(99, 102, 241, 0.12);
            border-color: var(--border2);
            color: var(--accent2)
        }

        .ni .ni-label {
            font-size: 11px;
            font-weight: 600;
            display: none;
            opacity: 0;
            transition: opacity 0.2s
        }

        .sidebar.expanded .ni .ni-label {
            display: block;
            opacity: 1
        }

        .ni-div {
            width: 36px;
            height: 1px;
            background: var(--border);
            margin: 4px 0;
            flex-shrink: 0;
            transition: width 0.3s
        }

        .sidebar.expanded .ni-div {
            width: calc(var(--sidebar-w) - 16px)
        }

        .sb-toggle {
            width: 44px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--t3);
            background: none;
            border: 1px solid var(--border);
            font-size: 13px;
            margin-top: auto;
            transition: all .2s;
            flex-shrink: 0
        }

        .sb-toggle:hover {
            color: var(--t2);
            border-color: var(--border2)
        }

        .day-badge {
            margin-top: 8px;
            background: linear-gradient(135deg, rgba(255, 82, 0, 0.12), rgba(255, 82, 0, 0.05));
            border: 1px solid rgba(255, 82, 0, 0.25);
            border-radius: 10px;
            padding: 8px 4px;
            text-align: center;
            flex-shrink: 0;
            width: 44px;
            transition: width 0.3s
        }

        .sidebar.expanded .day-badge {
            width: calc(var(--sidebar-w) - 16px);
            padding: 8px 12px;
            display: flex;
            align-items: center;
            gap: 10px
        }

        .day-num {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: var(--orange);
            line-height: 1
        }

        .day-lbl {
            font-size: 7px;
            color: var(--t3);
            letter-spacing: 2px;
            text-transform: uppercase;
            font-weight: 700;
            margin-top: 1px
        }

        .day-prog-bar {
            height: 2px;
            background: rgba(255, 82, 0, 0.1);
            border-radius: 1px;
            margin-top: 5px;
            overflow: hidden
        }

        .day-prog-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--orange), var(--orange2));
            border-radius: 1px;
            transition: width 0.5s
        }

        /* === MAIN === */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            min-width: 0
        }

        /* === TOPBAR === */
        .topbar {
            height: 48px;
            background: rgba(6, 11, 22, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 16px;
            gap: 10px;
            flex-shrink: 0
        }

        .tb-title {
            font-family: 'Syne', sans-serif;
            font-size: 14px;
            font-weight: 800;
            flex: 1;
            letter-spacing: -0.2px
        }

        .tb-clock {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
            color: var(--t3)
        }

        .pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 9.5px;
            font-weight: 700;
            border: 1px solid
        }

        .pill-a {
            background: rgba(99, 102, 241, 0.1);
            border-color: var(--border2);
            color: var(--accent2)
        }

        .pill-c {
            background: rgba(6, 182, 212, 0.08);
            border-color: rgba(6, 182, 212, 0.2);
            color: var(--cyan)
        }

        .pill-o {
            background: rgba(255, 82, 0, 0.08);
            border-color: rgba(255, 82, 0, 0.2);
            color: var(--orange)
        }

        .pill-g {
            background: rgba(16, 185, 129, 0.08);
            border-color: rgba(16, 185, 129, 0.2);
            color: var(--green)
        }

        .pill-p {
            background: rgba(168, 85, 247, 0.08);
            border-color: rgba(168, 85, 247, 0.2);
            color: var(--purple)
        }

        /* === CONTENT === */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 14px;
            min-height: 0
        }

        .panel {
            display: none;
            animation: panelIn .3s cubic-bezier(.4, 0, .2, 1) both
        }

        .panel.active {
            display: block
        }

        @keyframes panelIn {
            from {
                opacity: 0;
                transform: translateY(10px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        /* === CARDS === */
        .card {
            background: rgba(10, 16, 32, 0.7);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 16px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
            transition: border-color .25s, box-shadow .25s
        }

        .card:hover {
            border-color: var(--border2)
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(99, 102, 241, 0.25), transparent);
            opacity: 0;
            transition: opacity .3s
        }

        .card:hover::before {
            opacity: 1
        }

        .card-glow {
            box-shadow: 0 0 40px var(--glow-a)
        }

        .ct {
            font-family: 'JetBrains Mono', monospace;
            font-size: 8px;
            font-weight: 600;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 5px
        }

        .ct-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor;
            margin-right: 2px
        }

        /* === GRIDS === */
        .g2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px
        }

        .g3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 12px
        }

        .g4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px
        }

        .g12 {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 12px
        }

        .g21 {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 12px
        }

        /* === STAT CARDS === */
        .sc {
            background: rgba(10, 16, 32, 0.7);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 14px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px)
        }

        .sc-glow {
            position: absolute;
            top: -30px;
            right: -30px;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            filter: blur(28px);
            opacity: .25
        }

        .sc-v {
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 800;
            line-height: 1
        }

        .sc-l {
            font-size: 9.5px;
            color: var(--t3);
            margin-top: 3px
        }

        .sc-icon {
            font-size: 18px;
            margin-bottom: 5px
        }

        /* === PROGRESS === */
        .pr {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 6px
        }

        .pr-l {
            font-size: 9px;
            color: var(--t2);
            width: 72px;
            flex-shrink: 0;
            font-family: 'JetBrains Mono', monospace
        }

        .pr-bar {
            flex: 1;
            height: 3px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 2px;
            overflow: hidden
        }

        .pr-fill {
            height: 100%;
            border-radius: 2px;
            transition: width .8s cubic-bezier(.4, 0, .2, 1)
        }

        .pr-pct {
            font-size: 8.5px;
            color: var(--t3);
            width: 28px;
            text-align: right;
            font-family: 'JetBrains Mono', monospace
        }

        /* === BUTTONS === */
        .btn {
            padding: 8px 16px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 700;
            border: 1px solid;
            cursor: pointer;
            transition: all .2s;
            letter-spacing: .3px;
            display: inline-flex;
            align-items: center;
            gap: 6px
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border-color: transparent;
            color: #fff;
            box-shadow: 0 0 24px var(--glow-a)
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 0 40px var(--glow-a)
        }

        .btn-orange {
            background: var(--orange);
            border-color: var(--orange);
            color: #000
        }

        .btn-orange:hover {
            background: var(--orange2);
            transform: translateY(-1px)
        }

        .btn-ghost {
            background: rgba(255, 255, 255, 0.03);
            border-color: var(--border);
            color: var(--t2)
        }

        .btn-ghost:hover {
            border-color: var(--border2);
            color: var(--t1)
        }

        .btn-sm {
            padding: 4px 11px;
            font-size: 9.5px
        }

        .btn-danger {
            background: rgba(239, 68, 68, 0.08);
            border-color: rgba(239, 68, 68, 0.2);
            color: var(--red)
        }

        /* === INPUTS === */
        .inp {
            background: rgba(6, 11, 22, 0.8);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            padding: 8px 12px;
            font-size: 11px;
            color: var(--t1);
            outline: none;
            transition: border-color .15s;
            font-family: 'JetBrains Mono', monospace
        }

        .inp:focus {
            border-color: var(--accent)
        }

        .inp::placeholder {
            color: var(--t3)
        }

        textarea.inp {
            resize: vertical;
            line-height: 1.6
        }

        .sel {
            background: rgba(6, 11, 22, 0.8);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            padding: 7px 10px;
            font-size: 11px;
            color: var(--t1);
            outline: none;
            cursor: pointer;
            font-family: 'JetBrains Mono', monospace
        }

        .sel:focus {
            border-color: var(--accent)
        }

        input[type="range"] {
            accent-color: var(--accent)
        }

        /* === TAGS === */
        .tag {
            font-size: 8px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 3px;
            letter-spacing: .5px;
            display: inline-block;
            text-transform: uppercase
        }

        .tg-dsa {
            background: rgba(6, 182, 212, 0.1);
            color: var(--cyan)
        }

        .tg-dbms {
            background: rgba(168, 85, 247, 0.1);
            color: var(--purple)
        }

        .tg-llm {
            background: rgba(255, 82, 0, 0.1);
            color: var(--orange)
        }

        .tg-webdev {
            background: rgba(16, 185, 129, 0.1);
            color: var(--green)
        }

        .tg-english {
            background: rgba(244, 114, 182, 0.1);
            color: var(--pink)
        }

        .tg-numerical {
            background: rgba(245, 158, 11, 0.1);
            color: var(--gold)
        }

        .tg-personal {
            background: rgba(255, 255, 255, 0.04);
            color: var(--t3)
        }

        .tg-high {
            background: rgba(239, 68, 68, 0.1);
            color: var(--red)
        }

        .tg-medium {
            background: rgba(245, 158, 11, 0.1);
            color: var(--gold)
        }

        .tg-low {
            background: rgba(16, 185, 129, 0.1);
            color: var(--green)
        }

        /* === SECTION HEADER === */
        .sec-h {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px
        }

        .sec-h h2 {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: -0.3px
        }

        .sec-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(99, 102, 241, 0.08);
            border: 1px solid rgba(99, 102, 241, 0.18);
            border-radius: 100px;
            padding: 4px 12px;
            margin-bottom: 14px
        }

        .sec-badge-text {
            font-size: 10px;
            font-weight: 700;
            color: var(--accent2);
            letter-spacing: 1.5px;
            text-transform: uppercase
        }

        .glow-div {
            width: 80px;
            height: 1.5px;
            margin: 0 auto 16px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            border-radius: 2px
        }

        .sec-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(22px, 3.5vw, 38px);
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 10px
        }

        .sec-sub {
            font-size: 14px;
            color: var(--t2);
            max-width: 480px;
            margin: 0 auto;
            line-height: 1.7
        }

        /* === FILTER CHIPS === */
        .fc-bar {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
            margin-bottom: 12px
        }

        .fc {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 9px;
            font-weight: 600;
            border: 1px solid rgba(255, 255, 255, 0.06);
            background: transparent;
            color: var(--t3);
            cursor: pointer;
            transition: all .15s;
            font-family: 'JetBrains Mono', monospace
        }

        .fc.on {
            border-color: var(--border2);
            color: var(--accent2);
            background: rgba(99, 102, 241, 0.1)
        }

        .fc:hover {
            border-color: var(--border);
            color: var(--t2)
        }

        /* === HERO SECTION === */
        .hero-section {
            min-height: calc(100vh - 74px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 80px 24px 60px;
            position: relative
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(99, 102, 241, 0.08);
            border: 1px solid rgba(99, 102, 241, 0.2);
            border-radius: 100px;
            padding: 6px 16px;
            margin-bottom: 24px;
            font-size: 11px;
            font-weight: 600;
            color: var(--accent2);
            animation: fadeUp .8s ease both
        }

        .badge-pulse {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent2);
            animation: pulse 2s infinite
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1)
            }

            50% {
                opacity: .4;
                transform: scale(.8)
            }
        }

        .hero-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(44px, 6.5vw, 88px);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 20px;
            animation: fadeUp .8s ease 0.1s both
        }

        .hero-title .grad {
            background: linear-gradient(135deg, var(--accent2), var(--cyan), var(--orange));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-style: italic
        }

        .hero-sub {
            font-size: clamp(14px, 1.8vw, 18px);
            color: var(--t2);
            max-width: 540px;
            margin: 0 auto 36px;
            line-height: 1.8;
            font-weight: 300;
            animation: fadeUp .8s ease 0.2s both
        }

        .hero-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
            animation: fadeUp .8s ease 0.3s both
        }

        .hero-stats {
            display: flex;
            gap: 40px;
            justify-content: center;
            margin-top: 56px;
            flex-wrap: wrap;
            animation: fadeUp .8s ease 0.4s both
        }

        .hs-item {
            text-align: center
        }

        .hs-val {
            font-family: 'Syne', sans-serif;
            font-size: 34px;
            font-weight: 800;
            line-height: 1;
            background: linear-gradient(135deg, var(--t1), var(--t2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text
        }

        .hs-lbl {
            font-size: 10px;
            color: var(--t3);
            margin-top: 4px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            font-weight: 600
        }

        .stat-div {
            width: 1px;
            height: 32px;
            background: var(--border);
            align-self: center
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(18px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .orb {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
            z-index: 0
        }

        .orb1 {
            width: 500px;
            height: 500px;
            top: -180px;
            left: -200px;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.1), transparent 70%);
            filter: blur(50px)
        }

        .orb2 {
            width: 400px;
            height: 400px;
            bottom: -120px;
            right: -160px;
            background: radial-gradient(circle, rgba(6, 182, 212, 0.08), transparent 70%);
            filter: blur(50px)
        }

        .orb3 {
            width: 300px;
            height: 300px;
            top: 40%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: radial-gradient(circle, rgba(255, 82, 0, 0.04), transparent 70%);
            filter: blur(60px)
        }

        /* === ROADMAP PATH === */
        .roadmap-path {
            display: flex;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
            gap: 0;
            margin-top: 40px;
            position: relative
        }

        .rm-node {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            position: relative;
            padding: 0 14px
        }

        .rm-circle {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            border: 2px solid;
            transition: all .3s;
            position: relative;
            z-index: 1
        }

        .rm-circle:hover {
            transform: scale(1.12);
            box-shadow: 0 0 30px currentColor
        }

        .rm-label {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            text-align: center;
            width: 80px;
            line-height: 1.3
        }

        .rm-code {
            font-family: 'JetBrains Mono', monospace;
            font-size: 8.5px;
            color: var(--t3);
            margin-top: 2px
        }

        .rm-connector {
            width: 50px;
            height: 2px;
            background: linear-gradient(90deg, rgba(99, 102, 241, 0.3), rgba(6, 182, 212, 0.3));
            align-self: center;
            margin-bottom: 26px;
            flex-shrink: 0;
            position: relative
        }

        .rm-connector::after {
            content: '';
            position: absolute;
            top: 50%;
            right: -4px;
            transform: translateY(-50%);
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--cyan);
            box-shadow: 0 0 8px var(--cyan)
        }

        /* === COURSE CARDS === */
        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 16px
        }

        .course-card {
            background: rgba(10, 16, 32, 0.7);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 24px;
            cursor: pointer;
            transition: all .3s;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px)
        }

        .course-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: var(--r-lg);
            background: radial-gradient(circle at 30% 20%, rgba(99, 102, 241, 0.06), transparent 60%);
            opacity: 0;
            transition: opacity .3s
        }

        .course-card:hover {
            border-color: var(--border2);
            transform: translateY(-4px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5)
        }

        .course-card:hover::before {
            opacity: 1
        }

        .cc-icon {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0
        }

        .cc-title {
            font-family: 'Syne', sans-serif;
            font-size: 17px;
            font-weight: 700;
            margin-bottom: 6px
        }

        .cc-desc {
            font-size: 12px;
            color: var(--t2);
            line-height: 1.65;
            margin-bottom: 14px
        }

        .cc-tag {
            font-size: 9px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 5px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border);
            color: var(--t2)
        }

        .cc-prog-row {
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            color: var(--t3);
            margin-bottom: 5px;
            font-family: 'JetBrains Mono', monospace
        }

        .cc-prog-bar {
            height: 2.5px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 2px;
            overflow: hidden
        }

        .cc-prog-fill {
            height: 100%;
            border-radius: 2px;
            transition: width 1s ease
        }

        /* === AI CHAT === */
        .ai-wrap {
            background: rgba(8, 13, 24, 0.8);
            border: 1px solid var(--border);
            border-radius: var(--r-xl);
            display: grid;
            grid-template-columns: 260px 1fr;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
            min-height: 560px;
            backdrop-filter: blur(20px)
        }

        .ai-sidebar {
            background: rgba(6, 11, 22, 0.8);
            border-right: 1px solid var(--border);
            padding: 18px;
            display: flex;
            flex-direction: column;
            gap: 8px
        }

        .ai-mode-btn {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 10px 12px;
            border-radius: 10px;
            cursor: pointer;
            border: 1px solid transparent;
            background: none;
            transition: all .15s;
            width: 100%;
            text-align: left;
            color: var(--t2)
        }

        .ai-mode-btn:hover {
            background: rgba(255, 255, 255, 0.04);
            color: var(--t1)
        }

        .ai-mode-btn.active {
            background: rgba(99, 102, 241, 0.1);
            border-color: var(--border2);
            color: var(--accent2)
        }

        .ai-mode-name {
            font-size: 11.5px;
            font-weight: 600
        }

        .ai-mode-desc {
            font-size: 9.5px;
            color: var(--t3);
            margin-top: 1px
        }

        .ai-quick-btn {
            padding: 7px 10px;
            border-radius: 7px;
            font-size: 10px;
            font-weight: 600;
            cursor: pointer;
            border: 1px solid var(--border);
            background: rgba(255, 255, 255, 0.02);
            color: var(--t2);
            transition: all .15s;
            text-align: left;
            width: 100%
        }

        .ai-quick-btn:hover {
            border-color: var(--accent);
            color: var(--accent2)
        }

        .ai-main {
            display: flex;
            flex-direction: column
        }

        .ai-topbar {
            padding: 14px 18px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0
        }

        .ai-avatar {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--accent), var(--cyan));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
            box-shadow: 0 0 20px var(--glow-a)
        }

        .ai-messages {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            min-height: 300px;
            max-height: 380px
        }

        .ai-msg {
            display: flex;
            gap: 8px;
            max-width: 90%
        }

        .ai-msg.user {
            align-self: flex-end;
            flex-direction: row-reverse
        }

        .ai-msg-av {
            width: 24px;
            height: 24px;
            border-radius: 7px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px
        }

        .ai-msg.ai .ai-msg-av {
            background: linear-gradient(135deg, var(--accent), var(--cyan))
        }

        .ai-msg.user .ai-msg-av {
            background: rgba(99, 102, 241, 0.15);
            border: 1px solid rgba(99, 102, 241, 0.25)
        }

        .ai-bubble {
            padding: 9px 13px;
            border-radius: 10px;
            font-size: 12px;
            line-height: 1.65
        }

        .ai-msg.ai .ai-bubble {
            background: rgba(10, 16, 32, 0.9);
            border: 1px solid var(--border)
        }

        .ai-msg.user .ai-bubble {
            background: rgba(99, 102, 241, 0.1);
            border: 1px solid rgba(99, 102, 241, 0.2)
        }

        .ai-bubble code {
            font-family: 'JetBrains Mono', monospace;
            font-size: 10.5px;
            background: rgba(6, 182, 212, 0.1);
            padding: 1px 5px;
            border-radius: 4px;
            color: var(--cyan)
        }

        .ai-bubble strong {
            color: var(--accent2)
        }

        .ai-time {
            font-size: 8.5px;
            color: var(--t3);
            margin-top: 3px;
            align-self: flex-end
        }

        .typing-ind {
            display: flex;
            gap: 4px;
            padding: 9px 13px;
            background: rgba(10, 16, 32, 0.9);
            border: 1px solid var(--border);
            border-radius: 10px;
            width: fit-content
        }

        .t-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--accent2);
            animation: tdot 1.2s infinite
        }

        .t-dot:nth-child(2) {
            animation-delay: .2s
        }

        .t-dot:nth-child(3) {
            animation-delay: .4s
        }

        @keyframes tdot {

            0%,
            60%,
            100% {
                transform: translateY(0)
            }

            30% {
                transform: translateY(-6px)
            }
        }

        .ai-input-row {
            padding: 12px 18px;
            border-top: 1px solid var(--border);
            display: flex;
            gap: 8px;
            align-items: flex-end;
            flex-shrink: 0
        }

        .ai-input {
            flex: 1;
            background: rgba(6, 11, 22, 0.8);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 9px 13px;
            font-size: 12px;
            color: var(--t1);
            outline: none;
            resize: none;
            min-height: 40px;
            max-height: 90px;
            transition: border-color .15s;
            line-height: 1.5
        }

        .ai-input:focus {
            border-color: var(--accent)
        }

        .ai-input::placeholder {
            color: var(--t3)
        }

        .ai-send {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            border: none;
            cursor: pointer;
            font-size: 16px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .2s;
            box-shadow: 0 0 18px var(--glow-a);
            color: #fff
        }

        .ai-send:hover {
            transform: scale(1.05)
        }

        .ai-send:disabled {
            opacity: .4
        }

        /* === HABIT ROW === */
        .hab {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 8px 11px;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.04);
            background: rgba(6, 11, 22, 0.5);
            margin-bottom: 4px;
            cursor: pointer;
            transition: all .15s
        }

        .hab:hover {
            border-color: var(--border)
        }

        .hab.on-good {
            background: rgba(16, 185, 129, 0.05);
            border-color: rgba(16, 185, 129, 0.2)
        }

        .hab.on-bad {
            background: rgba(239, 68, 68, 0.05);
            border-color: rgba(239, 68, 68, 0.2)
        }

        .hab-chk {
            width: 17px;
            height: 17px;
            border: 1.5px solid var(--t4);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all .15s;
            font-size: 8.5px;
            font-weight: 800
        }

        .on-good .hab-chk {
            background: var(--green);
            border-color: var(--green);
            color: #000
        }

        .on-bad .hab-chk {
            background: var(--red);
            border-color: var(--red);
            color: #fff
        }

        /* === TASKS === */
        .task {
            background: rgba(6, 11, 22, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 10px;
            padding: 9px 12px;
            display: flex;
            align-items: center;
            gap: 9px;
            margin-bottom: 4px;
            transition: all .15s;
            animation: slideIn .15s ease
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-6px)
            }

            to {
                opacity: 1;
                transform: translateX(0)
            }
        }

        .task:hover {
            border-color: var(--border)
        }

        .task.done-t {
            opacity: .4
        }

        .task.done-t .task-title {
            text-decoration: line-through;
            color: var(--t3)
        }

        .task-chk {
            width: 17px;
            height: 17px;
            border: 1.5px solid var(--t4);
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .15s;
            flex-shrink: 0;
            font-size: 8.5px
        }

        .task-chk.checked {
            background: var(--green);
            border-color: var(--green);
            color: #000
        }

        .task-chk.checked::after {
            content: '✓';
            font-weight: 800
        }

        .task-title {
            font-size: 11px;
            font-weight: 500;
            flex: 1
        }

        /* === PLAN CARDS === */
        .pcard {
            background: rgba(10, 16, 32, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 10px;
            padding: 8px;
            cursor: pointer;
            transition: all .2s
        }

        .pcard:hover {
            border-color: var(--border);
            transform: translateY(-1px)
        }

        .pcard.today-p {
            border-color: var(--orange) !important;
            box-shadow: 0 0 0 1px var(--orange), 0 0 20px var(--glow-o)
        }

        .pcard.done-p {
            opacity: .6
        }

        .pd-num {
            font-family: 'Syne', sans-serif;
            font-size: 14px;
            font-weight: 800;
            line-height: 1.2
        }

        .pd-dt {
            font-size: 7px;
            color: var(--t3);
            margin-bottom: 3px
        }

        .pd-bar {
            height: 2px;
            background: rgba(255, 255, 255, 0.04);
            border-radius: 1px;
            overflow: hidden;
            margin-bottom: 2px
        }

        .pd-fill {
            height: 100%;
            border-radius: 1px
        }

        .pd-mod {
            font-size: 7.5px;
            color: var(--t3);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        /* === POPUP === */
        .popup {
            position: fixed;
            background: rgba(10, 16, 32, 0.95);
            border: 1px solid var(--border2);
            border-radius: var(--r-lg);
            padding: 16px;
            width: 280px;
            z-index: 500;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
            display: none;
            backdrop-filter: blur(20px)
        }

        .popup-t {
            font-family: 'Syne', sans-serif;
            font-size: 12px;
            font-weight: 800;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center
        }

        .popup-close {
            cursor: pointer;
            color: var(--t3);
            font-size: 16px
        }

        .popup-list {
            list-style: none
        }

        .popup-list li {
            font-size: 9.5px;
            color: var(--t2);
            padding: 3px 0;
            display: flex;
            gap: 5px;
            line-height: 1.5
        }

        .popup-list li::before {
            content: '›';
            color: var(--accent2);
            flex-shrink: 0
        }

        /* === POMODORO === */
        .pomo-ring {
            width: 180px;
            height: 180px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 14px
        }

        .pomo-svg {
            position: absolute;
            inset: 0;
            transform: rotate(-90deg)
        }

        .pomo-track {
            fill: none;
            stroke: rgba(255, 255, 255, 0.05);
            stroke-width: 4
        }

        .pomo-arc {
            fill: none;
            stroke: var(--orange);
            stroke-width: 4;
            stroke-linecap: round;
            transition: stroke-dashoffset .5s ease
        }

        .pomo-time {
            font-family: 'Syne', sans-serif;
            font-size: 36px;
            font-weight: 800;
            color: var(--orange);
            line-height: 1;
            text-align: center
        }

        .pomo-lbl {
            font-size: 8px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-top: 2px;
            text-align: center
        }

        .pb-row {
            display: flex;
            gap: 8px;
            justify-content: center;
            margin-bottom: 12px
        }

        .pb {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: rgba(6, 11, 22, 0.8);
            color: var(--t2);
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .15s
        }

        .pb:hover {
            border-color: var(--border2);
            color: var(--orange)
        }

        .pb.on {
            background: var(--orange);
            color: #000;
            border-color: var(--orange)
        }

        .pm-row {
            display: flex;
            gap: 5px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 12px
        }

        .pm {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 9px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--t3);
            cursor: pointer;
            transition: all .13s;
            font-family: 'JetBrains Mono', monospace
        }

        .pm.on {
            border-color: var(--orange);
            color: var(--orange);
            background: rgba(255, 82, 0, 0.08)
        }

        /* === NOTES === */
        .note-item {
            background: rgba(6, 11, 22, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 10px;
            padding: 9px 12px;
            cursor: pointer;
            transition: all .13s;
            margin-bottom: 4px
        }

        .note-item:hover {
            border-color: var(--border)
        }

        .note-item.active-n {
            background: rgba(99, 102, 241, 0.08);
            border-color: var(--border2)
        }

        .note-title {
            font-size: 11.5px;
            font-weight: 600;
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        .note-preview {
            font-size: 9px;
            color: var(--t3);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        .note-date {
            font-size: 7.5px;
            color: var(--t3);
            margin-top: 2px
        }

        .ne-area {
            flex: 1;
            background: rgba(6, 11, 22, 0.5);
            border: none;
            outline: none;
            resize: none;
            font-size: 12px;
            color: var(--t2);
            line-height: 1.8;
            padding: 14px 16px;
            font-family: 'JetBrains Mono', monospace
        }

        .ne-area::placeholder {
            color: var(--t3)
        }

        /* === JOURNAL === */
        .je {
            background: rgba(6, 11, 22, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 10px;
            padding: 10px 12px;
            margin-bottom: 6px
        }

        .je-date {
            font-size: 7.5px;
            color: var(--t3);
            margin-bottom: 5px;
            font-family: 'JetBrains Mono', monospace
        }

        .je-label {
            font-size: 7.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 5px
        }

        .je-text {
            font-size: 10.5px;
            color: var(--t2);
            line-height: 1.6
        }

        /* === TIMELINE === */
        .tl-item {
            display: flex;
            gap: 12px;
            padding: 7px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03)
        }

        .tl-item:last-child {
            border-bottom: none
        }

        .tl-time {
            font-size: 9px;
            color: var(--t3);
            width: 85px;
            flex-shrink: 0;
            font-family: 'JetBrains Mono', monospace;
            padding-top: 1px
        }

        .tl-title {
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 1px
        }

        .tl-desc {
            font-size: 9px;
            color: var(--t3)
        }

        .tl-item.now-active .tl-title {
            color: var(--orange)
        }

        .tl-item.now-active {
            border-left: 2px solid var(--orange);
            padding-left: 10px;
            margin-left: -12px
        }

        /* === ROADMAP PHASES === */
        .rm-phase {
            background: rgba(10, 16, 32, 0.7);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 18px;
            margin-bottom: 12px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px)
        }

        .rm-phase-num {
