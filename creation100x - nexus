        function updateScore() {
            const today = new Date().toISOString().split('T')[0];
            const gd = GOOD_HABITS.filter(h => S.goodH[`${h.id}-${today}`]).length;
            const bb = BAD_HABITS.filter(h => S.badH[`${h.id}-${today}`]).length;
            const br = BAD_HABITS.length - bb;
            const score = Math.min(100, Math.round((gd / 10) * 50 + (br / 9) * 30 + Math.min(S.pomodoros, 5) * 4));
            const offset = 188.5 - (188.5 * (score / 100));
            const arc = document.getElementById('scoreArc');
            if (arc) arc.style.strokeDashoffset = offset;
            const sn = document.getElementById('scoreNum');
            if (sn) sn.textContent = score;
            const sg = document.getElementById('score-g');
