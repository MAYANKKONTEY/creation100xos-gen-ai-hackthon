                return;
            }
            el.innerHTML = notes.map(n => `<div class="note-item ${S.currentNote===n.id?'active-n':''}" onclick="openNote(${n.id})"><div class="note-title">${n.title||'Untitled'}</div><div class="note-preview">${(n.content||'').replace(/\n/g,' ').substring(0,55)}</div><div class="note-date">${new Date(n.updated).toLocaleDateString('en',{month:'short',day:'numeric'})}</div></div>`).join('');
        }

        function newNote() {
            const n = {
                id: noteId++,
                title: '',
                content: '',
                created: Date.now(),
                updated: Date.now()
            };
            S.notes.unshift(n);
            save();
            openNote(n.id);
            renderNotes();
        }

        function openNote(id) {
            S.currentNote = id;
            const n = S.notes.find(n => n.id === id);
            if (!n) return;
            document.getElementById('noteTitleInp').value = n.title;
            document.getElementById('noteContent').value = n.content;
            document.getElementById('noteStatus').textContent = 'All changes saved';
            renderNotes();
        }

        function autoSave() {
            clearTimeout(autoSaveT);
            document.getElementById('noteStatus').textContent = 'Saving…';
            autoSaveT = setTimeout(() => {
                const n = S.notes.find(n => n.id === S.currentNote);
                if (n) {
                    n.title = document.getElementById('noteTitleInp').value;
                    n.content = document.getElementById('noteContent').value;
                    n.updated = Date.now();
                    save();
                    renderNotes();
                    document.getElementById('noteStatus').textContent = 'All changes saved';
                }
            }, 800);
        }

        function deleteNote() {
            if (!S.currentNote || !confirm('Delete this note?')) return;
            S.notes = S.notes.filter(n => n.id !== S.currentNote);
            S.currentNote = null;
            save();
            document.getElementById('noteTitleInp').value = '';
            document.getElementById('noteContent').value = '';
            renderNotes();
        }

        function searchNotes() {
            noteSearchStr = document.getElementById('noteSearch').value.toLowerCase();
            renderNotes();
        }

        function fmtNote(pre, suf) {
            const ta = document.getElementById('noteContent');
            const sel = ta.value.substring(ta.selectionStart, ta.selectionEnd) || 'text';
            document.execCommand('insertText', false, pre + sel + suf);
            autoSave();
        }

        // ═══════════════════════════════════════════════
        // JOURNAL
        // ═══════════════════════════════════════════════
        function saveJournal() {
            const e = {
                hook: document.getElementById('j-hook').value.trim(),
                story: document.getElementById('j-story').value.trim(),
                insight: document.getElementById('j-insight').value.trim(),
                action: document.getElementById('j-action').value.trim(),
                date: new Date().toLocaleDateString()
            };
            if (!e.hook && !e.story) return alert('Write something first!');
            S.journalEntries.unshift(e);
            if (S.journalEntries.length > 50) S.journalEntries = S.journalEntries.slice(0, 50);
            save();
            ['j-hook', 'j-story', 'j-insight', 'j-action'].forEach(id => document.getElementById(id).value = '');
            renderJournal();
        }

        function renderJournal() {
            const el = document.getElementById('journalEntries');
            if (!el) return;
            if (!S.journalEntries.length) {
                el.innerHTML = '<div class="empty-state">No entries yet. Write your first!</div>';
                return;
            }
            el.innerHTML = S.journalEntries.slice(0, 10).map(e => `<div class="je"><div class="je-date">${e.date}</div>${e.hook?`<div><div class="je-label" style="color:var(--orange)">HOOK</div><div class="je-text">${e.hook}</div></div>`:''} ${e.insight?`<div><div class="je-label" style="color:var(--cyan)">INSIGHT</div><div class="je-text">${e.insight}</div></div>`:''}</div>`).join('');
        }

        // ═══════════════════════════════════════════════
        // BODY & GYM
        // ═══════════════════════════════════════════════
        function renderBody() {
            const lost = S.startWeight - S.weight;
            const td = S.startWeight - 70;
            const wpct = Math.max(0, Math.min(100, Math.round((lost / td) * 100)));
            document.getElementById('body-cw').textContent = S.weight;
            document.getElementById('body-wl').textContent = Math.max(0, lost).toFixed(1);
            document.getElementById('body-wbar').style.width = wpct + '%';
            document.getElementById('body-wpct').textContent = wpct + '%';
            const wh = document.getElementById('weightHistory');
            if (wh) wh.innerHTML = S.weightLog.slice(0, 5).map(w => `<div class="weight-entry"><span style="font-size:8.5px;color:var(--t3)">${w.date}</span><span style="font-family:'Syne',sans-serif;font-size:13px;font-weight:800;color:var(--cyan);margin-left:auto">${w.w}kg</span></div>`).join('');
            const last7 = S.sleepLog.slice(-7);
            const sbars = document.getElementById('body-sleepbars');
            if (sbars) sbars.innerHTML = last7.map(s => {
                const h = s.hours;
                const cls = h >= 7 ? 'sb-good' : h >= 5 ? 'sb-ok' : 'sb-bad';
                const p = Math.min(100, (h / 9) * 100);
                return `<div class="sb ${cls}" style="height:${p}%" title="${h}h"></div>`;
            }).join('');
            const avg = last7.length ? last7.reduce((a, b) => a + b.hours, 0) / last7.length : 7.5;
            document.getElementById('body-sleep-avg').textContent = avg.toFixed(1);
            document.getElementById('gymSplit').innerHTML = GYM_SPLIT.map(g => `<div style="display:flex;gap:8px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.03);font-size:10.5px"><span style="font-family:'JetBrains Mono';font-size:8.5px;color:var(--orange);width:42px;flex-shrink:0">${g.day}</span><div><div style="font-weight:600">${g.focus}</div><div style="font-size:8.5px;color:var(--t3)">${g.ex}</div></div></div>`).join('');
        }

        function logSleep() {
            const bed = document.getElementById('sleepBed').value;
            const wake = document.getElementById('sleepWake').value;
            const qual = document.getElementById('sleepQual').value;
            if (!bed || !wake) return;
            const [bh, bm] = bed.split(':').map(Number);
            const [wh, wm] = wake.split(':').map(Number);
            let hours = (wh + wm / 60) - (bh + bm / 60);
            if (hours < 0) hours += 24;
            S.sleepLog.push({
                hours: parseFloat(hours.toFixed(1)),
                quality: qual,
                date: new Date().toLocaleDateString()
            });
            if (S.sleepLog.length > 50) S.sleepLog = S.sleepLog.slice(-50);
            save();
            renderBody();
            alert(`Sleep logged: ${hours.toFixed(1)} hours`);
        }

        // ═══════════════════════════════════════════════
        // MUSIC
        // ═══════════════════════════════════════════════
        function saveBars() {
            const text = document.getElementById('barInp').value.trim();
            const tech = document.getElementById('barTech').value;
            if (!text) return;
            S.bars.unshift({
                text,
                tech,
                date: new Date().toLocaleDateString()
            });
            if (S.bars.length > 50) S.bars = S.bars.slice(0, 50);
            save();
            document.getElementById('barInp').value = '';
            renderMusic();
        }

        function renderMusic() {
            const el = document.getElementById('savedBars');
            if (!el) return;
            if (!S.bars.length) {
                el.innerHTML = '<div class="empty-state">No bars saved yet. Write your first 4!</div>';
                return;
            }
            el.innerHTML = S.bars.slice(0, 20).map(b => `<div class="bars-entry"><div class="bars-date">${b.date} · <span style="color:var(--gold)">${b.tech}</span></div><div class="bars-text">${b.text.replace(/\n/g,'<br>')}</div></div>`).join('');
        }

        // ═══════════════════════════════════════════════
        // REFLECT
        // ═══════════════════════════════════════════════
        let currentMood = 3;
        const RF_Q = ['What is the ONE thing that — if done today — would make everything else easier?', 'Where did you lose time today? What pattern do you see?', 'What did you learn today that you didn\'t know yesterday?', 'Are you moving toward your goals or just feeling busy?'];

        function renderReflect() {
            document.getElementById('reflectDate').textContent = new Date().toLocaleDateString('en', {
                weekday: 'long',
                month: 'long',
                day: 'numeric'
            });
            document.getElementById('rfQuote').textContent = RF_Q[new Date().getDay() % RF_Q.length];
            const el = document.getElementById('reflectHistory');
            const me = ['', '😴', '😔', '😐', '😊', '🔥'];
            const sorted = [...S.reflections].reverse().slice(0, 10);
            if (!sorted.length) {
                el.innerHTML = '<div class="empty-state">🌱 Complete your first reflection</div>';
                return;
            }
            el.innerHTML = sorted.map(r => `<div class="je" style="margin-bottom:6px"><div class="je-date">${r.date} ${me[r.mood||3]}</div>${r.win?`<div class="je-text"><strong style="color:var(--green)">Win:</strong> ${r.win}</div>`:''} ${r.tomorrow?`<div class="je-text"><strong style="color:var(--orange)">Tomorrow:</strong> ${r.tomorrow}</div>`:''}</div>`).join('');
        }

        function setMood(v, btn) {
            currentMood = v;
            document.querySelectorAll('.mood-btn').forEach(b => b.classList.remove('on'));
            btn.classList.add('on');
        }

        function saveReflection() {
            const today = new Date().toDateString();
            const e = {
                date: today,
                mood: currentMood,
                win: document.getElementById('rf-win').value.trim(),
                improve: document.getElementById('rf-improve').value.trim(),
                tomorrow: document.getElementById('rf-tomorrow').value.trim(),
                focus: parseInt(document.getElementById('rf-focus').value),
                created: Date.now()
            };
            const idx = S.reflections.findIndex(r => r.date === today);
            if (idx >= 0) S.reflections[idx] = e;
            else S.reflections.push(e);
            save();
            renderReflect();
            ['rf-win', 'rf-improve', 'rf-tomorrow'].forEach(id => document.getElementById(id).value = '');
            alert('Reflection saved ✓');
        }

        // ═══════════════════════════════════════════════
        // ROADMAP
        // ═══════════════════════════════════════════════
        function renderRoadmap() {
            document.getElementById('roadmapContent').innerHTML = ROADMAP.map(rm => `<div class="rm-phase"><div class="rm-phase-num">${rm.phase}</div><div class="rm-tag">PHASE ${rm.phase} — ${rm.duration}</div><div class="rm-ph-title">${rm.title}</div><div class="rm-goal">${rm.goal}</div><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:7px">${rm.items.map(i=>`<div class="res-card"><div class="res-type">${i.label}</div><div class="res-name">${i.name}</div>${i.link?`<a href="${i.link}" class="res-link" target="_blank">${i.link.replace('https://','')}</a>`:''}</div>`).join('')}</div></div>`).join('');
        }

        // ═══════════════════════════════════════════════
        // MANIFESTO
        // ═══════════════════════════════════════════════
        function renderManifesto() {
            document.getElementById('manifestoRules').innerHTML = MANIFESTO_RULES.map((r, i) => `<div class="rule-row" style="${i===MANIFESTO_RULES.length-1?'border-bottom:none':''}"><div class="rule-n">${r.n}</div><div><div class="rule-title">${r.title}</div><div class="rule-desc">${r.desc}</div></div></div>`).join('');
        }

        // ═══════════════════════════════════════════════
        // SEED TASKS
        // ═══════════════════════════════════════════════
        if (S.tasks.length === 0) {
            const plan = getPlan(getDayNum());
            plan.tasks.forEach((t, i) => {
                S.tasks.push({
                    id: taskId++,
                    title: t,
                    subject: plan.sub === 'review' ? 'dsa' : plan.sub,
                    priority: i === 0 ? 'high' : 'medium',
                    due: '',
                    done: false,
                    created: Date.now()
                });
            });
            save();
        }

        // ═══════════════════════════════════════════════
        // INIT
        // ═══════════════════════════════════════════════
        renderManifesto();
        renderRoadmap();
        updateBadge();
        updatePomoDisp();
        renderDash();
    </script>
</body>

</html>
