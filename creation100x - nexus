                    },
                    body: JSON.stringify({
                        model: 'claude-sonnet-4-20250514',
                        max_tokens: 1000,
                        system: AI_MODES[S.aiMode] || AI_MODES.tutor,
                        messages: aiHistory.slice(-18)
                    })
                });
                const data = await res.json();
                typingEl.remove();
                const reply = data.content?. [0]?.text || 'I had trouble processing that. Please try again.';
                aiHistory.push({
                    role: 'assistant',
                    content: reply
