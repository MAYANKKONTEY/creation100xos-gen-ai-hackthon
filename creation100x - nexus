        function updatePomoDisp() {
            document.getElementById('pomoDisp').textContent = `${fmt(pomo.mins)}:${fmt(pomo.secs)}`;
            const rem = pomo.mins * 60 + pomo.secs;
            const offset = POMO_CIRC - (POMO_CIRC * (rem / pomo.total));
            document.getElementById('pomoArc').style.strokeDashoffset = offset;
            document.getElementById('pomoLbl').textContent = pomo.mode;
        }

        function togglePomo() {
            if (pomo.running) {
                clearInterval(pomo.iv);
                pomo.running = false;
                document.getElementById('pomoPlayBtn').textContent = '▶';
                document.getElementById('pomoPlayBtn').classList.remove('on');
            } else {
                pomo.running = true;
                document.getElementById('pomoPlayBtn').textContent = '⏸';
                document.getElementById('pomoPlayBtn').classList.add('on');
                pomo.iv = setInterval(() => {
                    if (pomo.secs === 0) {
                        if (pomo.mins === 0) {
                            clearInterval(pomo.iv);
                            pomo.running = false;
                            document.getElementById('pomoPlayBtn').textContent = '▶';
                            document.getElementById('pomoPlayBtn').classList.remove('on');
                            if (pomo.mode === 'FOCUS') {
                                S.pomodoros++;
                                S.xp += 20;
                                save();
                                logFocusSession();
                                updateTopbar();
                                updateScore();
                            }
                            beepSound();
                            return;
                        }
                        pomo.mins--;
                        pomo.secs = 59;
                    } else pomo.secs--;
                    updatePomoDisp();
                }, 1000);
            }
        }

        function resetPomo() {
            clearInterval(pomo.iv);
            pomo.running = false;
            setPomoMode(pomo.total / 60, pomo.mode, null);
        }

