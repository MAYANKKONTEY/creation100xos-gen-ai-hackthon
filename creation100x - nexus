            el.innerHTML = tasks.map(t => `<div class="task ${t.done?'done-t':''}"><div class="task-chk ${t.done?'checked':''}" onclick="toggleTask(${t.id})"></div><div class="task-title">${t.title}</div><div style="display:flex;gap:5px;align-items:center;flex-wrap:wrap"><span class="tag tg-${t.subject}">${t.subject==='numerical'?'Num':t.subject==='webdev'?'Web':t.subject.toUpperCase()}</span><span class="tag tg-${t.priority}">${t.priority}</span>${t.due?`<span style="font-size:8px;color:var(--t3)">📅${t.due}</span>`:''}</div><button class="btn btn-danger btn-sm" onclick="deleteTask(${t.id})">✕</button></div>`).join('');
