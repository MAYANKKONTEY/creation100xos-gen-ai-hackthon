            const renderer = new THREE.WebGLRenderer({
                canvas,
                alpha: true,
                antialias: true
            });
            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 2000);
            camera.position.z = 40;
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(devicePixelRatio, 1.5));

            // Stars
            const starCount = 1200;
            const starGeo = new THREE.BufferGeometry();
            const starPos = new Float32Array(starCount * 3);
            const starColors = new Float32Array(starCount * 3);
            for (let i = 0; i < starCount; i++) {
                starPos[i * 3] = (Math.random() - 0.5) * 200;
                starPos[i * 3 + 1] = (Math.random() - 0.5) * 200;
                starPos[i * 3 + 2] = (Math.random() - 0.5) * 100;
                const t = Math.random();
                if (t < 0.33) {
                    starColors[i * 3] = 0.39;
                    starColors[i * 3 + 1] = 0.40;
                    starColors[i * 3 + 2] = 0.97;
                } else if (t < 0.66) {
                    starColors[i * 3] = 0.02;
                    starColors[i * 3 + 1] = 0.71;
                    starColors[i * 3 + 2] = 0.83;
                } else {
                    starColors[i * 3] = 1.0;
                    starColors[i * 3 + 1] = 0.32;
                    starColors[i * 3 + 2] = 0.0;
                }
            }
            starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
            starGeo.setAttribute('color', new THREE.BufferAttribute(starColors, 3));
            const starMat = new THREE.PointsMaterial({
                size: 0.22,
                vertexColors: true,
                transparent: true,
                opacity: 0.8
            });
            scene.add(new THREE.Points(starGeo, starMat));

            // Nebula spheres
            const spheres = [];
            for (let i = 0; i < 8; i++) {
                const r = Math.random() * 3 + 1;
                const g = new THREE.SphereGeometry(r, 8, 8);
                const colors = [0x6366f1, 0x06b6d4, 0xff5200, 0xa855f7];
                const m = new THREE.MeshBasicMaterial({
                    color: colors[i % colors.length],
                    wireframe: true,
                    transparent: true,
                    opacity: 0.04 + Math.random() * 0.06
                });
                const s = new THREE.Mesh(g, m);
                s.position.set((Math.random() - 0.5) * 70, (Math.random() - 0.5) * 60, (Math.random() - 0.5) * 30 - 10);
                s._sx = (Math.random() - 0.5) * 0.004;
                s._sy = (Math.random() - 0.5) * 0.003;
                s._sr = Math.random() * 0.006;
                scene.add(s);
                spheres.push(s);
            }

            // Floating rings
            for (let i = 0; i < 3; i++) {
                const g = new THREE.TorusGeometry(4 + i * 3, 0.08, 8, 60);
                const m = new THREE.MeshBasicMaterial({
                    color: i === 0 ? 0x6366f1 : i === 1 ? 0x06b6d4 : 0xff5200,
                    transparent: true,
                    opacity: 0.08
                });
                const t = new THREE.Mesh(g, m);
                t.position.set((Math.random() - 0.5) * 40, (Math.random() - 0.5) * 30, -15 - i * 5);
                t.rotation.x = Math.random() * Math.PI;
                scene.add(t);
                spheres.push(t);
            }

            let mouse = {
                x: 0,
                y: 0
            };
            window.addEventListener('mousemove', e => {
                mouse.x = (e.clientX / window.innerWidth - 0.5) * 0.5;
                mouse.y = (e.clientY / window.innerHeight - 0.5) * 0.5;
            });
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });

            let t = 0;

            function animate() {
                requestAnimationFrame(animate);
                t += 0.005;
                scene.children[0].rotation.y += 0.0004;
                scene.children[0].rotation.x += 0.0002;
                camera.position.x += (mouse.x * 6 - camera.position.x) * 0.025;
                camera.position.y += (-mouse.y * 6 - camera.position.y) * 0.025;
                spheres.forEach(s => {
                    s.position.x += Math.sin(t * s._sx || 0.003) * 0.015;
                    s.position.y += Math.cos(t * (s._sy || 0.002) * 0.7) * 0.012;
                    s.rotation.x += (s._sx || 0.003);
                    s.rotation.y += (s._sy || 0.002);
                });
                renderer.render(scene, camera);
            }
            animate();
        })();

